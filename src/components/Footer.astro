---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <span class="footer-sig">Sisi</span>
  <span class="footer-copy">© {year} — All rights reserved</span>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px clamp(24px, 6vw, 80px);
    border-top: 1px solid var(--rule);
    margin-top: 14px;
  }
  .footer-sig {
    font-family: var(--serif);
    font-size: 15px;
    font-style: italic;
    font-weight: 300;
    color: var(--stone);
  }
  .footer-copy {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--rule);
  }
  @media (max-width: 600px) {
    .footer-copy { display: none; }
  }
</style>
