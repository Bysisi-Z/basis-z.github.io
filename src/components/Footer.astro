---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-left">
    <span class="footer-sig">Si</span>
  </div>
  <div class="footer-right">
    <span class="footer-copy">© {year} — All rights reserved</span>
    <span class="footer-photo-rights">
      All photographs on this site are the exclusive property of the author.
      Unauthorized reproduction, redistribution, or commercial use is strictly prohibited.
      All rights reserved.
    </span>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 18px clamp(24px, 6vw, 80px);
    border-top: 1px solid var(--rule);
    margin-top: 14px;
  }
  .footer-sig {
    font-family: var(--serif);
    font-size: 15px;
    font-style: italic;
    font-weight: 300;
    color: var(--stone);
  }
  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .footer-copy {
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--stone);
  }
  .footer-photo-rights {
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--stone);
    text-align: right;
    max-width: 520px;
    line-height: 1.6;
  }
  @media (max-width: 600px) {
    .footer-copy,
    .footer-photo-rights { display: none; }
  }
</style>
