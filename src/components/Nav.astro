---
const path = Astro.url.pathname;

const modules = [
  { label: 'Now',              href: '/now' },
  { label: 'Journey',          href: '/career' },
  { label: 'Decoding',         href: '/research' },
  { label: 'Nature Never Judges', href: '/photography' },
  { label: 'Wandering',        href: '/writing' },
  { label: 'Reading List',     href: '/reading' },
];

const current = modules.find(m => path.startsWith(m.href));
---

<header class="top-nav">
  <!-- Row 1: brand + current page -->
  <div class="nav-row-top">
    <a href="/" class="nav-home">Si</a>
    {current && (
      <span class="nav-current">
        <span class="nav-sep">·</span>
        {current.label}
      </span>
    )}
  </div>

  <!-- Row 2 (desktop: same row; mobile: second row) -->
  <nav class="nav-links">
    {modules.map(({ label, href }) => (
      <a
        href={href}
        class={`nav-link ${path.startsWith(href) ? 'active' : ''}`}
      >
        {label}
      </a>
    ))}
  </nav>
</header>

<style>
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    flex-wrap: wrap;          /* allows second row on mobile */
    gap: 0;
    padding: 0 clamp(20px, 6vw, 80px);
    height: 52px;
    background: rgba(250,250,248,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }

  /* ── Row 1: brand + current ── */
  .nav-row-top {
    display: flex;
    align-items: center;
    gap: 14px;
    height: 52px;
  }

  .nav-home {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 300;
    font-style: italic;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }
  .nav-home:hover { opacity: 0.55; }

  .nav-sep { color: var(--rule); }

  .nav-current {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--stone);
    display: flex;
    align-items: center;
    gap: 14px;
  }

  /* ── Module links ── */
  .nav-links {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-link {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--stone);
    text-decoration: none;
    white-space: nowrap;
    padding: 4px 9px;
    border-radius: 2px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover  { color: var(--ink); }
  .nav-link.active {
    background: var(--rose);
    color: #fff;
  }

  /* ── Mobile ≤ 640px: links drop to second row ── */
  @media (max-width: 640px) {
    .top-nav {
      height: auto;
      padding: 0 20px;
    }

    /* Row 1 fills full width, 44px tall */
    .nav-row-top {
      width: 100%;
      height: 44px;
    }

    /* Row 2: links strip, horizontally scrollable */
    .nav-links {
      width: 100%;
      margin-left: 0;
      gap: 0;
      padding: 9px 0;
      border-top: 1px solid var(--rule);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .nav-links::-webkit-scrollbar { display: none; }

    .nav-link {
      font-size: 9.5px;
      padding: 3px 8px;
      flex-shrink: 0;
    }
    /* Separator between links */
    .nav-link + .nav-link {
      margin-left: 6px;
      padding-left: 14px;
      border-left: 1px solid var(--rule);
    }
    .nav-link.active {
      background: var(--rose);
      color: #fff;
    }
  }
</style>
