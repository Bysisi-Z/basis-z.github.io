---
/**
 * ArticleHero — renders the correct hero layout based on photo orientation:
 *   orientation="portrait" → split layout (photo left or right)
 *   orientation="landscape" → full-width hero with text overlay
 */

interface Props {
  src: string;
  alt: string;
  orientation: 'portrait' | 'landscape';
  imagePosition?: 'left' | 'right';   // portrait only, default 'left'
  eyebrow?: string;
  title: string;
  subtitle?: string;
  stats?: { label: string; value: string }[];
}

const {
  src,
  alt,
  orientation,
  imagePosition = 'left',
  eyebrow,
  title,
  subtitle,
  stats = [],
} = Astro.props;
---

{orientation === 'portrait' ? (
  <!-- ── PORTRAIT: split layout ── -->
  <div class={`hero-split img-${imagePosition}`}>
    <div class="split-photo">
      <img src={src} alt={alt} />
    </div>
    <div class="split-text">
      {eyebrow && <div class="split-eyebrow">{eyebrow}</div>}
      <h1 class="split-title" set:html={title} />
      {subtitle && <p class="split-subtitle">{subtitle}</p>}
      {stats.length > 0 && (
        <div class="split-stats">
          {stats.map(s => (
            <div class="stat-item">
              <span class="stat-label">{s.label}</span>
              <span class="stat-value">{s.value}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
) : (
  <!-- ── LANDSCAPE: full-width hero ── -->
  <div class="hero-full">
    <img class="hero-full-img" src={src} alt={alt} />
    <div class="hero-full-gradient"></div>
    <div class="hero-full-content">
      {eyebrow && <span class="hero-eyebrow">{eyebrow}</span>}
      <h1 class="hero-title" set:html={title} />
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    </div>
  </div>
)}

<style>
  :root { --pink: #c17d9d; }

  /* ══ PORTRAIT SPLIT ══ */
  .hero-split {
    display: grid;
    height: calc(100vh - 52px);
    min-height: 540px;
  }
  .hero-split.img-left  { grid-template-columns: 42% 58%; }
  .hero-split.img-right { grid-template-columns: 58% 42%; }

  .split-photo {
    position: relative;
    overflow: hidden;
  }
  .img-right .split-photo { order: 2; }
  .img-right .split-text  { order: 1; }

  .split-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: transform 0.8s ease;
  }
  .split-photo:hover img { transform: scale(1.03); }

  .img-left  .split-photo { border-right: 1px solid var(--rule); }
  .img-right .split-photo { border-left:  1px solid var(--rule); }

  .split-text {
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: clamp(40px, 5vw, 72px);
    padding-bottom: clamp(48px, 5vw, 72px);
    background: var(--bg);
  }

  .split-eyebrow {
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--stone); margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .split-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--pink); }

  .split-title {
    font-family: var(--serif);
    font-size: clamp(34px, 4.5vw, 62px);
    font-weight: 300; font-style: italic;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--ink); margin-bottom: 18px;
  }

  .split-subtitle {
    font-family: var(--serif);
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: 300; font-style: italic;
    color: var(--stone); line-height: 1.55;
    margin-bottom: 44px;
  }

  .split-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px 28px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
  }
  .stat-item { display: flex; flex-direction: column; gap: 4px; }
  .stat-label {
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--rule);
  }
  .stat-value { font-size: 13px; font-weight: 300; color: var(--stone); }

  /* ══ LANDSCAPE FULL WIDTH ══ */
  .hero-full {
    position: relative;
    height: calc(92vh - 52px);
    min-height: 480px;
    overflow: hidden;
  }

  .hero-full-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-full-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      transparent 25%,
      rgba(10,10,10,0.15) 50%,
      rgba(10,10,10,0.65) 80%,
      rgba(10,10,10,0.82) 100%);
  }

  .hero-full-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: clamp(32px, 6vw, 72px);
    padding-bottom: clamp(40px, 5vw, 64px);
  }

  .hero-eyebrow {
    display: block;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.58); margin-bottom: 14px;
  }
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(36px, 7vw, 80px);
    font-weight: 300; font-style: italic;
    line-height: 1.05; letter-spacing: -0.02em;
    color: #fff; margin-bottom: 14px;
    max-width: 700px;
  }
  .hero-subtitle {
    font-family: var(--serif);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 300; font-style: italic;
    color: rgba(255,255,255,0.7); line-height: 1.45;
  }

  /* ══ MOBILE ══ */
  @media (max-width: 700px) {
    .hero-split,
    .hero-split.img-left,
    .hero-split.img-right {
      grid-template-columns: 1fr;
      height: auto;
    }
    .split-photo { order: 1 !important; height: 65vw; min-height: 260px; }
    .split-text  { order: 2 !important; padding: 32px 24px 44px; }
    .img-left .split-photo,
    .img-right .split-photo { border: none; }
    .split-stats { grid-template-columns: repeat(2, 1fr); gap: 14px 20px; }

    .hero-full { height: 72vw; min-height: 280px; }
  }
</style>
