---
import Watermark from './Watermark.astro';

interface Props {
  src: string;
  alt: string;
  orientation: 'portrait' | 'landscape';
  imagePosition?: 'left' | 'right';   // portrait only, default 'left'
  eyebrow?: string;
  title: string;
  subtitle?: string;
  stats?: { label: string; value: string }[];
  webcamUrl?: string;
  webcamHint?: string;
  webcamHintZh?: string;
  webcamNote?: string;
  webcamNoteZh?: string;
  heroIntro?: string[];
  heroIntroZh?: string[];
  routeOverview?: {
    direction: string;
    stats: { label: string; value: string }[];
    note?: string;
  };
  routeOverviewZh?: {
    direction?: string;
    stats?: { label: string; value: string }[];
    note?: string;
  };
}

const {
  src,
  alt,
  orientation,
  imagePosition = 'left',
  eyebrow,
  title,
  subtitle,
  stats = [],
  webcamUrl,
  webcamHint = 'Weather in the Alps changes quickly at altitude. Check the live webcam before your visit to confirm current conditions.',
  webcamHintZh = '阿尔卑斯山高海拔地区天气变化迅速，建议出发前查看实时摄像头，确认当前天气状况。',
  webcamNote,
  webcamNoteZh,
  heroIntro,
  heroIntroZh,
  routeOverview,
  routeOverviewZh,
} = Astro.props;
---

{orientation === 'portrait' ? (
  <!-- ── PORTRAIT: split layout ── -->
  <div class={`hero-split img-${imagePosition}`}>
    <div class="split-photo">
      <img src={src} alt={alt} />
      <Watermark />
    </div>
    <div class="split-text">
      <div class="split-top">
        {eyebrow && <div class="split-eyebrow">{eyebrow}</div>}
        <h1 class="split-title" set:html={title} />
        {subtitle && <p class="split-subtitle">{subtitle}</p>}
        {!webcamUrl && stats.length > 0 && (
          <div class="split-stats">
            {stats.map(s => (
              <div class="stat-item">
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.value}</span>
              </div>
            ))}
          </div>
        )}
      </div>
      {(heroIntro || heroIntroZh) && (
        <div class="split-intro">
          {heroIntro?.map(p => <p class={heroIntroZh ? 'lang-en' : ''}>{p}</p>)}
          {heroIntroZh?.map(p => <p class="lang-zh">{p}</p>)}
        </div>
      )}
      {routeOverview && (
        <div class="route-card">
          <div class="route-direction">
            <span class="route-dir-text">{routeOverview.direction}</span>
            <span class="route-card-label lang-en">Recommended direction</span>
            {routeOverviewZh && <span class="route-card-label lang-zh">推荐方向</span>}
          </div>
          <div class="route-stats lang-en">
            {routeOverview.stats.map(s => (
              <div class="route-stat">
                <span class="route-stat-val">{s.value}</span>
                <span class="route-stat-lbl">{s.label}</span>
              </div>
            ))}
          </div>
          {routeOverviewZh?.stats && (
            <div class="route-stats lang-zh">
              {routeOverviewZh.stats.map(s => (
                <div class="route-stat">
                  <span class="route-stat-val">{s.value}</span>
                  <span class="route-stat-lbl">{s.label}</span>
                </div>
              ))}
            </div>
          )}
          {routeOverview.note && <p class={`route-note${routeOverviewZh?.note ? ' lang-en' : ''}`}>{routeOverview.note}</p>}
          {routeOverviewZh?.note && <p class="route-note lang-zh">{routeOverviewZh.note}</p>}
        </div>
      )}

      {webcamUrl && (
        <div class="split-webcam">
          <p class="split-wc-hint lang-en">{webcamHint}</p>
          <p class="split-wc-hint lang-zh">{webcamHintZh}</p>
          <a class="split-wc-btn" href={webcamUrl} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="16" height="16">
              <rect x="2" y="5" width="12" height="10" rx="2" stroke="currentColor" stroke-width="1.4"/>
              <path d="M14 8.5l4-2.5v7l-4-2.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            </svg>
            View Live Webcam →
          </a>
          {webcamNote && <p class="split-wc-note lang-en">{webcamNote}</p>}
          {webcamNoteZh && <p class="split-wc-note lang-zh">{webcamNoteZh}</p>}
        </div>
      )}
    </div>
  </div>
) : (
  <!-- ── LANDSCAPE: full-width hero ── -->
  <div class="hero-full">
    <img class="hero-full-img" src={src} alt={alt} />
    <div class="hero-full-gradient"></div>
    <Watermark />
    <div class="hero-full-content">
      {eyebrow && <span class="hero-eyebrow">{eyebrow}</span>}
      <h1 class="hero-title" set:html={title} />
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    </div>
  </div>
)}

<style>
  :root { --pink: #c17d9d; }

  /* ══ PORTRAIT SPLIT ══ */
  .hero-split {
    display: grid;
    grid-template-rows: 1fr;
    height: calc(100vh - 52px);
    height: calc(100dvh - 52px);
    min-height: 480px;
  }
  .hero-split.img-left  { grid-template-columns: 42% 58%; }
  .hero-split.img-right { grid-template-columns: 58% 42%; }

  .split-photo {
    position: relative;
    overflow: hidden;
    background: var(--bg);
    height: 100%;
  }
  .img-right .split-photo { order: 2; }
  .img-right .split-text  { order: 1; }

  .split-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    object-position: center center;
    transition: transform 0.8s ease;
  }
  .split-photo:hover img { transform: scale(1.03); }

  .img-left  .split-photo { border-right: 1px solid var(--rule); }
  .img-right .split-photo { border-left:  1px solid var(--rule); }

  .split-text {
    display: flex; flex-direction: column;
    justify-content: flex-start;
    padding: clamp(40px, 5vw, 72px);
    background: var(--bg);
    height: 100%;
    overflow-y: auto;
  }
  .split-top { display: flex; flex-direction: column; }

  .split-eyebrow {
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--stone); margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .split-eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--pink); }

  .split-title {
    font-family: var(--serif);
    font-size: clamp(34px, 4.5vw, 62px);
    font-weight: 300; font-style: italic;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--ink); margin-bottom: 18px;
  }

  .split-subtitle {
    font-family: var(--serif);
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: 300; font-style: italic;
    color: var(--stone); line-height: 1.55;
    margin-bottom: 44px;
  }

  /* Intro text in hero right column */
  .split-intro {
    overflow-y: auto;
    padding: 20px 0 20px 18px;
    border-top: 1px solid var(--rule);
    border-left: 2px solid rgba(193,125,157,0.45);
    scrollbar-width: none;
  }
  .split-intro::-webkit-scrollbar { display: none; }
  .split-intro p {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 21px);
    font-weight: 300; font-style: italic;
    color: var(--ink); line-height: 1.82;
    margin: 0;
  }
  .split-intro p + p { margin-top: 18px; }

  /* Route overview card */
  .route-card {
    background: rgba(193,125,157,0.05);
    border: 1px solid rgba(226,222,219,0.8);
    border-radius: 8px;
    padding: 16px 18px;
    margin-top: 20px;
    flex-shrink: 0;
  }
  .route-card-label {
    font-family: var(--sans); font-size: 9px; font-weight: 400;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--stone); display: block; margin-top: 4px;
  }
  .route-direction {
    display: flex; flex-direction: column; gap: 3px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 12px;
  }
  .route-dir-text {
    font-family: var(--sans); font-size: 15px; font-weight: 400;
    color: var(--rose); letter-spacing: 0.01em;
  }
  .route-stats {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px 16px;
  }
  .route-stat { display: flex; flex-direction: column; gap: 2px; }
  .route-stat-val {
    font-family: var(--sans); font-size: 13px; font-weight: 400;
    color: var(--ink);
  }
  .route-stat-lbl {
    font-family: var(--sans); font-size: 9px; font-weight: 300;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--stone);
  }
  .route-note {
    font-family: var(--sans);
    font-size: 13px; font-weight: 300;
    color: var(--ink); line-height: 1.75;
    margin: 12px 0 0;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
  }

  /* Webcam block in hero right column */
  .split-webcam {
    margin-top: 60px;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
    padding-top: 28px;
    border-top: 1px solid var(--rule);
    text-align: center;
  }
  .split-wc-hint {
    font-family: var(--sans); font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--rose); line-height: 1.6;
    margin: 0;
  }
  .split-wc-btn {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--sans); font-size: 11px; font-weight: 300;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: #fff; background: var(--pink);
    padding: 13px 24px; border-radius: 2px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .split-wc-btn:hover { opacity: 0.82; }
  .split-wc-note {
    font-family: var(--sans); font-size: 11px; font-weight: 300;
    color: var(--stone); line-height: 1.65;
    text-align: center; margin: 0;
    padding: 0 4px;
  }

  .split-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px 28px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
  }
  .stat-item { display: flex; flex-direction: column; gap: 4px; }
  .stat-label {
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--rule);
  }
  .stat-value { font-size: 13px; font-weight: 300; color: var(--stone); }

  /* ══ LANDSCAPE FULL WIDTH ══ */
  .hero-full {
    position: relative;
    height: calc(92vh - 52px);
    min-height: 480px;
    overflow: hidden;
  }

  .hero-full-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-full-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      transparent 25%,
      rgba(10,10,10,0.15) 50%,
      rgba(10,10,10,0.65) 80%,
      rgba(10,10,10,0.82) 100%);
  }

  .hero-full-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: clamp(32px, 6vw, 72px);
    padding-bottom: clamp(40px, 5vw, 64px);
  }

  .hero-eyebrow {
    display: block;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.58); margin-bottom: 14px;
  }
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(36px, 7vw, 80px);
    font-weight: 300; font-style: italic;
    line-height: 1.05; letter-spacing: -0.02em;
    color: #fff; margin-bottom: 14px;
    max-width: 700px;
  }
  .hero-subtitle {
    font-family: var(--serif);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 300; font-style: italic;
    color: rgba(255,255,255,0.7); line-height: 1.45;
  }

  /* ══ MOBILE ══ */
  @media (max-width: 700px) {
    .hero-split,
    .hero-split.img-left,
    .hero-split.img-right {
      grid-template-columns: 1fr;
      height: auto;
    }
    /* Portrait photo: use portrait aspect ratio so image isn't cropped into a landscape box */
    .split-photo {
      order: 1 !important;
      aspect-ratio: 4/5;
      height: auto;
      min-height: 300px;
    }
    .split-text  { order: 2 !important; padding: 32px 24px 44px; }
    .img-left .split-photo,
    .img-right .split-photo { border: none; }
    .split-stats { grid-template-columns: repeat(2, 1fr); gap: 14px 20px; }

    .hero-full { height: 72vw; min-height: 280px; }
  }
</style>
