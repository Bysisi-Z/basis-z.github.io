---
const pageId = Astro.url.pathname;
---

<div class="comments-section">
  <div class="comments-header">
    <h2 class="comments-heading">Comments</h2>
    <p class="comments-notice">Comments are reviewed before they appear publicly. The site owner can see all submissions.</p>
  </div>
  <div class="comments-frame">
    <div id="cusdis_thread"
      data-host="https://cusdis.com"
      data-app-id="33766e5a-7ef9-4b4f-9a01-df1013f36a9d"
      data-page-id={pageId}
      data-page-url=""
      data-page-title=""
    ></div>
  </div>
</div>

<script>
{
  const el = document.getElementById('cusdis_thread');
  if (el) {
    el.dataset.pageUrl   = window.location.href;
    el.dataset.pageTitle = document.title;
  }

  // Auto-resize the Cusdis iframe to its full content height so it never scrolls internally.
  // Cusdis fires a postMessage {from:'cusdis', event:'resize', data:{height}} on any content change.
  function applyNoScroll(iframe: HTMLIFrameElement) {
    iframe.scrolling = 'no';
    iframe.style.overflow = 'hidden';
    iframe.style.display  = 'block';
    iframe.style.width    = '100%';
    iframe.style.border   = 'none';
  }

  // Listen for Cusdis resize messages
  window.addEventListener('message', (e: MessageEvent) => {
    if (!e.data || e.data.from !== 'cusdis') return;
    if (e.data.event === 'resize' && e.data.data?.height) {
      const iframe = document.querySelector<HTMLIFrameElement>('#cusdis_thread iframe');
      if (iframe) {
        iframe.style.height = e.data.data.height + 'px';
        applyNoScroll(iframe);
      }
    }
  });

  // Watch for the iframe being injected by Cusdis, then lock it
  const observer = new MutationObserver(() => {
    const iframe = document.querySelector<HTMLIFrameElement>('#cusdis_thread iframe');
    if (iframe) {
      applyNoScroll(iframe);
      // Once found, check again after a tick in case initial height comes through load
      iframe.addEventListener('load', () => applyNoScroll(iframe), { once: true });
    }
  });
  observer.observe(document.getElementById('cusdis_thread')!, { childList: true, subtree: true });

  const s = document.createElement('script');
  s.src   = 'https://cusdis.com/js/cusdis.es.js';
  s.async = true;
  s.defer = true;
  document.body.appendChild(s);
}
</script>

<style>
  .comments-section {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--rule);
  }

  .comments-header {
    margin-bottom: 20px;
  }

  .comments-heading {
    font-family: var(--serif);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 300; font-style: italic;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .comments-notice {
    font-family: var(--sans);
    font-size: 12px; font-weight: 300;
    color: var(--stone); line-height: 1.6;
  }

  .comments-frame {
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 28px 32px;
    background: #fdfcfb;
    overflow: hidden;
  }
</style>
