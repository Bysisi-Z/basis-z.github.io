---
const pageId = Astro.url.pathname;
---

<div class="comments-section">
  <div class="comments-header">
    <h2 class="comments-heading">Comments</h2>
    <p class="comments-notice">Comments are reviewed before they appear publicly. The site owner can see all submissions.</p>
  </div>
  <div class="comments-frame">
    <div id="cusdis_thread"
      data-host="https://cusdis.com"
      data-app-id="33766e5a-7ef9-4b4f-9a01-df1013f36a9d"
      data-page-id={pageId}
      data-page-url=""
      data-page-title=""
    ></div>
  </div>
</div>

<script>
{
  const el = document.getElementById('cusdis_thread');
  if (el) {
    el.dataset.pageUrl   = window.location.href;
    el.dataset.pageTitle = document.title;
  }

  // Repeatedly strip inline scroll constraints while Cusdis renders
  function stripScroll() {
    const thread = document.getElementById('cusdis_thread');
    if (!thread) return;
    (thread.querySelectorAll('*') as NodeListOf<HTMLElement>).forEach(node => {
      if (node.tagName === 'TEXTAREA') return;
      node.style.removeProperty('overflow');
      node.style.removeProperty('overflow-y');
      node.style.removeProperty('overflow-x');
      node.style.removeProperty('max-height');
      node.style.removeProperty('height');
    });
  }

  // Run repeatedly for 4 seconds to catch Cusdis re-renders
  const iv = setInterval(stripScroll, 80);
  setTimeout(() => clearInterval(iv), 4000);

  const s = document.createElement('script');
  s.src   = 'https://cusdis.com/js/cusdis.es.js';
  s.async = true;
  s.defer = true;
  document.body.appendChild(s);
}
</script>

<style>
  .comments-section {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--rule);
  }

  .comments-header {
    margin-bottom: 20px;
  }

  .comments-heading {
    font-family: var(--serif);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 300; font-style: italic;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .comments-notice {
    font-family: var(--sans);
    font-size: 12px; font-weight: 300;
    color: var(--stone); line-height: 1.6;
  }

  .comments-frame {
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 28px 32px;
    min-height: 480px;
    background: #fdfcfb;
  }
</style>
