---
const pageId = Astro.url.pathname;
---

<div class="comments-section">
  <div class="comments-header">
    <h2 class="comments-heading">Comments</h2>
    <p class="comments-notice">Comments are reviewed before they appear publicly. The site owner can see all submissions.</p>
  </div>
  <div id="cusdis_thread"
    data-host="https://cusdis.com"
    data-app-id="33766e5a-7ef9-4b4f-9a01-df1013f36a9d"
    data-page-id={pageId}
    data-page-url=""
    data-page-title=""
  ></div>
</div>

<script>
{
  const el = document.getElementById('cusdis_thread');
  if (el) {
    el.dataset.pageUrl   = window.location.href;
    el.dataset.pageTitle = document.title;
  }

  // Strip inline overflow/height styles from all Cusdis elements after render
  function stripScrollStyles(root: Element) {
    root.querySelectorAll('*').forEach(node => {
      const el = node as HTMLElement;
      el.style.removeProperty('overflow');
      el.style.removeProperty('overflow-y');
      el.style.removeProperty('overflow-x');
      el.style.removeProperty('max-height');
      // Re-apply scroll only on textarea
      if (el.tagName === 'TEXTAREA') {
        el.style.overflowY = 'auto';
        el.style.maxHeight = '260px';
      }
    });
  }

  // Watch for Cusdis to render its DOM
  const observer = new MutationObserver(() => {
    const thread = document.getElementById('cusdis_thread');
    if (thread && thread.children.length > 0) {
      stripScrollStyles(thread);
    }
  });
  observer.observe(document.body, { childList: true, subtree: true });

  const s = document.createElement('script');
  s.src   = 'https://cusdis.com/js/cusdis.es.js';
  s.async = true;
  s.defer = true;
  document.body.appendChild(s);
}
</script>

<style is:global>
  /* Remove ALL scroll/height constraints inside Cusdis */
  #cusdis_thread,
  #cusdis_thread * {
    max-height: none !important;
    height: auto !important;
    overflow: visible !important;
    overflow-y: visible !important;
    overflow-x: visible !important;
  }

  /* Re-apply scroll ONLY on the textarea */
  #cusdis_thread textarea {
    overflow-y: auto !important;
    height: auto !important;
    min-height: 100px !important;
    max-height: 260px !important;
    resize: vertical !important;
  }
</style>

<style>
  .comments-section {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--rule);
  }

  .comments-header {
    margin-bottom: 28px;
  }

  .comments-heading {
    font-family: var(--serif);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 300; font-style: italic;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .comments-notice {
    font-family: var(--sans);
    font-size: 12px; font-weight: 300;
    color: var(--stone); line-height: 1.6;
  }
</style>
