---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Reading List" description="Books, papers & ideas worth revisiting">
  <div class="content-wrap">

    <div class="page-header">
      <h1 class="page-title">Reading<br /><em>List</em></h1>
      <p class="page-sub">Books, papers & ideas worth revisiting</p>
    </div>

    <div class="reading-body">
      <p class="placeholder">Coming soon.</p>
    </div>

  </div>
</BaseLayout>

<style>
  .content-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(20px, 6vw, 80px);
  }

  .page-header {
    padding-top: 64px;
    padding-bottom: 44px;
    border-bottom: 1px solid var(--rule);
  }

  .page-title {
    font-family: var(--serif);
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 300;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .page-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 300;
    font-style: italic;
    color: var(--stone);
    line-height: 1.5;
  }

  .reading-body {
    padding-top: 64px;
    padding-bottom: 80px;
  }

  .placeholder {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 300;
    color: var(--stone);
    letter-spacing: 0.05em;
  }
</style>
