---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="A Collection of Rabbit Holes" description="Books, papers & ideas worth revisiting">
  <div class="content-wrap">

    <p class="page-intro">Looking back, my reading habits make very little sense. And I am perfectly comfortable with that.</p>

    <div class="reading-body">
      <div class="under-construction">
        <img src="/images/under-construction.png" alt="Under construction illustration" class="construction-img">
        <p class="construction-oops">Oops, you're early.</p>
        <p class="construction-note">Due to time budget constraints, this section is still under construction. Check back soon.</p>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
.content-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(20px, 6vw, 80px);
  }

  .page-header {
    padding-top: 64px;
    padding-bottom: 44px;
    border-bottom: 1px solid var(--rule);
  }

  .page-title {
    font-family: var(--serif);
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 300;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 16px;
  }

  .page-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 300;
    font-style: italic;
    color: var(--stone);
    line-height: 1.5;
  }

  .page-intro {
    font-family: var(--serif);
    font-size: clamp(24px, 2.8vw, 38px);
    font-weight: 300;
    font-style: italic;
    color: var(--ink);
    line-height: 1.6;
    padding: 80px 0 0;
    max-width: 760px;
  }

  .reading-body {
    padding-top: 64px;
    padding-bottom: 80px;
  }

  .under-construction {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding-top: 20px;
  }
  .construction-img {
    width: 280px;
    height: auto;
    opacity: 0.9;
  }
  .construction-oops {
    font-family: var(--serif);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 300;
    font-style: italic;
    color: var(--ink);
  }
  .construction-note {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 300;
    color: var(--stone);
    letter-spacing: 0.02em;
    text-align: center;
    max-width: 380px;
    line-height: 1.7;
  }
</style>
