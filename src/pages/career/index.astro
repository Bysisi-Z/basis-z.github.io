---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Each side is its own independent timeline, ordered oldest → newest (top → bottom)
const leftEvents = [
  { year: '',     title: 'Born in Yunnan, China',        tag: 'Origin', desc: '', born: true },
  { year: '2007', title: 'Move to Chengdu',              tag: 'City',   desc: '', chengdu: true },
  { year: '2016', title: 'First Cat ♂',                  tag: 'Family', desc: '', cat: true },
  { year: '2017', title: 'Move to Shanghai',             tag: 'City',   desc: '', shanghai: true },
  { year: '2019', title: 'Second Cat ♀',                 tag: 'Family', desc: '', cat: true },
  { year: '2022', title: 'Move to Lucerne, Switzerland', tag: 'City',   desc: '', lucerne: true },
];

const rightEvents = [
  { year: '2007', title: 'Southwest University of Finance and Economics', tag: 'Education', desc: '', uni: true },
  { year: '2011', title: 'LG Electronics, China',                         tag: 'Career',    desc: '' },
  { year: '2013', title: 'Cisco, China',                                  tag: 'Career',    desc: '' },
  { year: '2014', title: 'Sanofi, China', tag: 'Career', desc: '', bullets: [
    'Acted as a strategic advisor to the Commercial Head, aligning cross-functional inputs to ensure decision readiness on critical topics.',
    'Entrusted with delegated authority across business operations, making and executing decisions related to field force deployment, resource allocation, and commercial planning.',
    'Led a matrix team of 12 (4 Business Analysts, 8 Business Operations Specialists) supporting a 1,000+ person commercial organization, building analytics-driven decision models across territory design, FTE allocation, budget allocation and sales forecasting.',
    'Led commercial and marketing resource planning and governance for the franchise through a team of BOS, supporting investment decisions and ensuring budget discipline and compliance.',
    'Led commercial transformation initiatives (e.g., reorganization, new product launch), navigating competing stakeholder priorities and driving alignment in complex and fast-changing environment.',
    'Coached analytics, operations, and commercial teams to adopt structured, data-driven decision-making practices.',
  ]},
  { year: '2018', title: 'MSD, China', tag: 'Career', desc: '', bullets: [
    'Built a COVID-19 business tracking and forecasting framework in a highly uncertain environment, providing a critical decision-making foundation for performance monitoring that remained in use through the Organon spin-off.',
    'Invited as a regular contributor to GM-1 leadership weekly reviews, shaping executive decision-making and global performance discussions.',
    'Designed and launched MSD China\'s first enterprise-wide business tracking platform, creating a single source of truth for KPI alignment; led adoption campaigns driving rollout to 3,000+ users across the organization.',
    'Acted as analytics partner to the vaccines business (largest BU), developing competitive intelligence frameworks to support strategy planning in a highly data-constrained environment.',
  ]},
  { year: '2022', title: 'Organon, Global', tag: 'Career', desc: '', bullets: [
    'Synthesized market, competitive, and performance intelligence into executive-level insights, informing strategic discussions and decision-making at CEO and Board level.',
    'Built and institutionalized the global floor price assessment capability, establishing it as a core pillar of global pricing management.',
    'Led two waves of GM-sponsored BD screening (20,000+ marketed, 2,000+ late-stage assets), identifying 33 shortlisted and 11 priority opportunities. Scaled the methodology into a structured decision framework to enable faster and more informed early-stage investment decisions.',
    'Selected for a year-long strategic assignment supporting late-stage BD transactions through valuation modeling, scenario analysis, and commercial assessments, informing deal structure and negotiation strategy.',
    'Built and scaled a global tender analytics capability from scratch, covering 50+ countries and enabling systematic assessment of pricing, access, and competitive risks, particularly in biosimilar-driven markets.',
    'Acted as a key liaison between commercial stakeholders and Global Analytics & Insights team, aligning business questions with analytics, payer, and market research capabilities to support pricing and market access decision-making.',
  ]},
];

// Merge rows by year so same-year events appear side by side.
// No-year entries (Born) go first; numbered years ascend oldest → newest.
// Newest years at top (descending), no-year (Born) at the very bottom.
const numberedYears = [
  ...new Set([
    ...leftEvents.filter(e => e.year).map(e => e.year),
    ...rightEvents.filter(e => e.year).map(e => e.year),
  ]),
].sort((a, b) => Number(b) - Number(a)); // descending: 2022 → 2007

const noYearRows = leftEvents
  .filter(e => !e.year)
  .map(e => ({ left: e, right: null }));

const rows = [
  ...numberedYears.map(year => ({
    left:  leftEvents.find(e => e.year === year)  ?? null,
    right: rightEvents.find(e => e.year === year) ?? null,
  })),
  ...noYearRows, // Born goes last
];
---

<BaseLayout title="Journey" description="A life lived between cities, peaks, and spreadsheets.">

  <div class="wrap">
    <header class="page-header">
      <h1 class="page-title">Journey</h1>
      <p class="page-sub">A life lived between cities, peaks, and spreadsheets.</p>
    </header>
  </div>

  <section>
    <div class="wrap">
      <div class="col-labels">
        <div class="col-label col-label-left">Life &amp; Adventures</div>
        <div></div>
        <div class="col-label col-label-right">Career &amp; Education</div>
      </div>

      <div class="timeline">
        {rows.map(({ left, right }) => (
          <div class={`tl-row${left?.chengdu && right?.uni ? ' tl-row--swap' : ''}`}>

            <div class="tl-left">
              {left
                ? <div class={`tl-card${left.desc ? '' : ' tl-card--static'}${left.born || left.chengdu || left.shanghai || left.lucerne ? ' tl-card--born' : ''}`} role={left.desc || left.born || left.chengdu || left.shanghai || left.lucerne ? 'button' : undefined} tabindex={left.desc || left.born || left.chengdu || left.shanghai || left.lucerne ? 0 : undefined} aria-expanded={left.desc ? 'false' : undefined} data-born={left.born ? 'true' : undefined} data-chengdu={left.chengdu ? 'true' : undefined} data-shanghai={left.shanghai ? 'true' : undefined} data-lucerne={left.lucerne ? 'true' : undefined}>
                    <div class="tl-card-main">
                      {left.year && <span class="tl-year">{left.year}</span>}
                      <h3 class="tl-title">
                        {left.cat && (
                          <svg class="cat-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M4.5 11L2 3L9.5 8.5Z"/>
                            <path d="M19.5 11L22 3L14.5 8.5Z"/>
                            <ellipse cx="12" cy="15" rx="9.5" ry="8"/>
                          </svg>
                        )}
                        {left.title}
                      </h3>
                      <span class="tl-tag">{left.tag}</span>
                      {left.desc && <span class="tl-chevron" aria-hidden="true"></span>}
                    </div>
                    {left.desc && <div class="tl-desc" aria-hidden="true"><p>{left.desc}</p></div>}
                  </div>
                : <div class="tl-empty"></div>
              }
              {left?.lucerne && (
                <div class="lucerne-wrapper" aria-hidden="true">
                  <svg class="lucerne-svg" viewBox="0 -22 260 137" xmlns="http://www.w3.org/2000/svg">
                    {/* Far background hills */}
                    <path d="M0 115 Q40 76 80 82 Q130 65 175 75 Q215 67 260 79 L260 115Z" fill="#ecd2e0"/>
                    {/* Mid-ground peaks */}
                    <path d="M0 115 L0 93 Q22 75 48 81 Q72 65 90 71 Q112 57 132 63 Q150 53 168 61 Q188 65 215 73 Q240 69 260 77 L260 115Z" fill="#d4a0b8"/>
                    {/* Main foreground — Matterhorn centre, flanking peaks */}
                    <path d="M0 115 L0 97 Q12 85 30 89 L44 70 L56 79 L68 61 L78 69 L87 51 L97 29 L107 11 L111 4 L115 11 L123 29 L127 21 L131 37 L139 57 L149 45 L155 37 L159 53 L167 63 Q185 69 206 75 Q233 77 260 85 L260 115Z" fill="#c17d9d"/>
                    {/* Snow cap */}
                    <path d="M109 15 L111 4 L115 11 L119 23 L113 19 L111 8 L109 15Z" fill="#f5e8f0"/>
                    {/* Flag pole */}
                    <rect x="110" y="-21" width="2" height="26" fill="#c17d9d"/>
                    {/* Swiss flag body */}
                    <rect x="112" y="-21" width="16" height="16" fill="#D52B1E"/>
                    {/* Swiss cross — horizontal bar */}
                    <rect x="112" y="-15" width="16" height="4" fill="#FAFAF8"/>
                    {/* Swiss cross — vertical bar */}
                    <rect x="118" y="-21" width="4" height="16" fill="#FAFAF8"/>
                  </svg>
                </div>
              )}
              {left?.chengdu && (
                <div class="panda-wrapper" aria-hidden="true">
                  <svg class="panda-svg" viewBox="-8 0 140 160" xmlns="http://www.w3.org/2000/svg" fill="none">
                    {/* Stalk 1 — tallest, leans left -4° */}
                    <g transform="rotate(-4,22,152)">
                      <rect x="18" y="18" width="8" height="134" rx="3" fill="#c17d9d"/>
                      <rect x="16" y="50"  width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      <rect x="16" y="82"  width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      <rect x="16" y="114" width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      <rect x="16" y="140" width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      {/* top: steep upper-left + drooping left */}
                      <path d="M22 26 Q7 15 3 5 Q15 14 22 26Z"  fill="#d4a0b8"/>
                      <path d="M22 26 Q6 28 2 40 Q14 26 22 26Z" fill="#c17d9d"/>
                      {/* mid: right-upward + right flat */}
                      <path d="M22 86 Q40 74 46 62 Q34 76 22 86Z" fill="#c17d9d"/>
                      <path d="M22 86 Q42 86 48 98 Q35 84 22 86Z" fill="#d4a0b8"/>
                      {/* lower: drooping right */}
                      <path d="M22 120 Q42 125 48 138 Q34 118 22 120Z" fill="#d4a0b8"/>
                    </g>

                    {/* Stalk 2 — medium, leans right +5° */}
                    <g transform="rotate(5,58,152)">
                      <rect x="54" y="36" width="8" height="116" rx="3" fill="#c17d9d"/>
                      <rect x="52" y="66"  width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      <rect x="52" y="96"  width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      <rect x="52" y="126" width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      {/* top: steep left + fanning upper-right */}
                      <path d="M58 44 Q38 32 32 18 Q46 30 58 44Z" fill="#c17d9d"/>
                      <path d="M58 44 Q75 36 78 22 Q67 35 58 44Z" fill="#d4a0b8"/>
                      {/* mid: drooping right + left-upward */}
                      <path d="M58 100 Q78 108 84 122 Q70 100 58 100Z" fill="#d4a0b8"/>
                      <path d="M58 100 Q40 90 36 76 Q48 93 58 100Z" fill="#c17d9d"/>
                    </g>

                    {/* Stalk 3 — shorter, leans right +3° */}
                    <g transform="rotate(3,93,152)">
                      <rect x="89" y="60" width="8" height="92" rx="3" fill="#c17d9d"/>
                      <rect x="87" y="90"  width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      <rect x="87" y="120" width="12" height="2.5" rx="1" fill="#9e6a82"/>
                      {/* top: left + left-drooping */}
                      <path d="M93 68 Q75 58 70 44 Q84 56 93 68Z" fill="#c17d9d"/>
                      <path d="M93 68 Q78 75 72 88 Q86 68 93 68Z" fill="#d4a0b8"/>
                      {/* mid: right-upward + right drooping */}
                      <path d="M93 96 Q112 84 118 70 Q106 84 93 96Z" fill="#c17d9d"/>
                      <path d="M93 96 Q114 100 120 114 Q107 94 93 96Z" fill="#d4a0b8"/>
                    </g>
                  </svg>
                </div>
              )}
            </div>

            <div class="tl-mid"><div class="tl-dot"></div></div>

            <div class="tl-right">
              {right
                ? <div class={`tl-card${(right.desc || right.bullets?.length) ? '' : ' tl-card--static'}${right.bullets?.length ? ' tl-card--bullets' : ''}${right.uni ? ' tl-card--born' : ''}`} role={(right.desc || right.bullets?.length || right.uni) ? 'button' : undefined} tabindex={(right.desc || right.bullets?.length || right.uni) ? 0 : undefined} aria-expanded={(right.desc || right.bullets?.length) ? 'false' : undefined} data-uni={right.uni ? 'true' : undefined}>
                    <div class="tl-card-main">
                      <span class="tl-year">{right.year}</span>
                      <h3 class="tl-title">{right.title}</h3>
                      <span class="tl-tag">{right.tag}</span>
                      {(right.desc || right.bullets?.length) && <span class="tl-chevron" aria-hidden="true"></span>}
                    </div>
                    {right.bullets?.length
                      ? <div class="tl-desc" aria-hidden="true">
                          <div class="vine-list">
                            <svg class="vine-svg" viewBox="0 0 40 400" preserveAspectRatio="xMidYMin meet" fill="none" aria-hidden="true">
                              <path class="vine-stem" stroke="rgba(193,125,157,0.35)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                              <g class="vine-branches"></g>
                              <g class="vine-leaves"></g>
                              <g class="vine-flowers"></g>
                            </svg>
                            {right.bullets.map((b, i) => (
                              <div class="vine-item" style={`--i:${i}`}>
                                <span class="vine-body">{b}</span>
                              </div>
                            ))}
                          </div>
                        </div>
                      : right.desc
                        ? <div class="tl-desc" aria-hidden="true"><p>{right.desc}</p></div>
                        : null
                    }
                  </div>
                : left?.born
                  ? <div class="stork-wrapper" aria-hidden="true">
                      <svg class="stork-svg" viewBox="0 0 220 160" xmlns="http://www.w3.org/2000/svg" fill="none">
                        {/* Wing (lighter pink, swept upward) */}
                        <path d="M100 62 C108 30 155 18 164 44 C148 56 118 62 100 68Z" fill="#d9a8be"/>
                        {/* Body */}
                        <ellipse cx="112" cy="72" rx="38" ry="15" fill="#c17d9d" transform="rotate(-10,112,72)"/>
                        {/* Tail feathers */}
                        <path d="M142 66 L160 56 M143 71 L162 70 M141 77 L158 84" stroke="#c17d9d" stroke-width="3" stroke-linecap="round"/>
                        {/* Neck */}
                        <path d="M80 63 C73 50 66 36 61 24" stroke="#c17d9d" stroke-width="10" stroke-linecap="round"/>
                        {/* Head */}
                        <circle cx="58" cy="18" r="11" fill="#c17d9d"/>
                        {/* Beak */}
                        <path d="M49 13 L16 10 L49 24Z" fill="#c17d9d"/>
                        {/* Legs trailing in flight */}
                        <path d="M106 85 L118 120 M117 84 L131 117" stroke="#c17d9d" stroke-width="3.5" stroke-linecap="round"/>
                        <path d="M118 120 L109 129 M118 120 L125 129" stroke="#c17d9d" stroke-width="2.5" stroke-linecap="round"/>
                        <path d="M131 117 L122 126 M131 117 L138 126" stroke="#c17d9d" stroke-width="2.5" stroke-linecap="round"/>
                        {/* Bundle string from beak tip */}
                        <path d="M16 11 C12 34 15 68 19 90" stroke="#c17d9d" stroke-width="2" stroke-linecap="round"/>
                        {/* Bundle body */}
                        <ellipse cx="22" cy="107" rx="18" ry="16" fill="#ecc8d8"/>
                        {/* Bundle knot */}
                        <path d="M10 96 Q22 91 34 96" stroke="#c17d9d" stroke-width="3.5" stroke-linecap="round"/>
                        <circle cx="22" cy="93" r="5" fill="#c17d9d"/>
                        {/* Baby face peeking out */}
                        <circle cx="22" cy="111" r="7" fill="#f5e0ea"/>
                      </svg>
                    </div>
                  : left?.shanghai
                    ? <div class="shanghai-wrapper" aria-hidden="true">
                        <svg class="shanghai-svg" viewBox="0 0 280 130" xmlns="http://www.w3.org/2000/svg">
                          {/* Depth layer — smaller background buildings */}
                          <rect x="0" y="88" width="18" height="39" fill="#d4a0b8"/>
                          <rect x="224" y="80" width="16" height="47" fill="#d4a0b8"/>
                          <rect x="243" y="70" width="14" height="57" fill="#d4a0b8"/>
                          <rect x="261" y="90" width="19" height="37" fill="#d4a0b8"/>
                          {/* ORIENTAL PEARL TOWER 东方明珠 */}
                          <path d="M22 126 L38 91 L44 91 L44 126Z" fill="#c17d9d"/>
                          <path d="M66 126 L50 91 L44 91 L44 126Z" fill="#c17d9d"/>
                          <ellipse cx="44" cy="76" rx="17" ry="15" fill="#c17d9d"/>
                          <rect x="42" y="50" width="4" height="27" fill="#c17d9d"/>
                          <ellipse cx="44" cy="46" rx="12" ry="11" fill="#c17d9d"/>
                          <rect x="43" y="8" width="2" height="39" fill="#c17d9d"/>
                          <circle cx="44" cy="7" r="4" fill="#c17d9d"/>
                          {/* JIN MAO TOWER 金茂大厦 (pagoda steps) */}
                          <path d="M80 126 L80 111 L82 111 L82 99 L84 99 L84 86 L86 86 L86 73 L88 73 L88 60 L90 60 L90 49 L91 49 L91 39 L92 39 L92 30 L93 30 L93 22 L94 22 L94 16 L95 16 L95 22 L96 22 L96 30 L97 30 L97 39 L98 39 L98 49 L100 49 L100 60 L102 60 L102 73 L104 73 L104 86 L106 86 L106 99 L108 99 L108 111 L110 111 L110 126Z" fill="#c17d9d"/>
                          {/* SWFC 环球金融中心 (bottle opener) */}
                          <rect x="126" y="14" width="22" height="112" fill="#c17d9d"/>
                          <rect x="126" y="4" width="7" height="14" fill="#c17d9d"/>
                          <rect x="141" y="4" width="7" height="14" fill="#c17d9d"/>
                          <rect x="133" y="4" width="8" height="14" fill="#FAFAF8"/>
                          {/* SHANGHAI TOWER 上海中心 (tallest, tapered) */}
                          <path d="M168 126 L172 8 L175 3 L178 8 L182 126Z" fill="#c17d9d"/>
                          <rect x="174" y="0" width="2" height="5" fill="#c17d9d"/>
                          {/* Ground */}
                          <rect x="0" y="125" width="280" height="4" fill="#c17d9d"/>
                        </svg>
                      </div>
                    : <div class="tl-empty"></div>
              }
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<canvas id="confetti-canvas" aria-hidden="true" style="position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9999;"></canvas>

<style>
  :root { --pink: #c17d9d; }

  .wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 60px);
  }

  /* ── Page header ── */
  .page-header {
    padding-top: 64px;
    padding-bottom: 44px;
    border-bottom: 1px solid var(--rule);
  }
  .eyebrow {
    font-size: 10px; font-weight: 300;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--stone);
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
  }
  .eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--pink); }
  .page-title {
    font-family: var(--serif);
    font-size: clamp(48px, 8vw, 88px);
    font-weight: 300; font-style: italic;
    line-height: 1; letter-spacing: -0.02em;
    color: var(--ink); margin-bottom: 16px;
  }
  .page-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 300; font-style: italic;
    color: var(--stone); line-height: 1.5;
  }

  /* ── Column labels ── */
  .col-labels {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    padding: 36px 0 4px;
  }
  .col-label {
    font-size: 10px; font-weight: 300;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--stone);
  }
  .col-label-left  { text-align: right; padding-right: 32px; }
  .col-label-right { padding-left: 32px; }

  /* ── Timeline ── */
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    padding-bottom: 80px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: calc(50% - 0.5px);
    top: 0; bottom: 0;
    width: 1px;
    background: var(--rule);
    z-index: 0;
  }

  .tl-row {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    align-items: start;
    position: relative;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .tl-row.visible { opacity: 1; transform: translateY(0); }

  .tl-left  { text-align: right; padding-right: 32px; }
  .tl-right { padding-left: 32px; }

  .tl-mid {
    display: flex; justify-content: center;
    padding-top: 16px;
    position: relative; z-index: 1;
  }
  .tl-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    border: 1.5px solid var(--rule);
    background: var(--bg);
    flex-shrink: 0;
    transition: border-color 0.25s, background 0.25s, transform 0.25s;
  }
  .tl-row:hover .tl-dot {
    border-color: var(--pink);
    background: var(--pink);
    transform: scale(1.35);
  }

  /* ── Card ── */
  .tl-card {
    display: inline-block;
    text-align: inherit;
    cursor: pointer;
  }
  .tl-card--static {
    cursor: default;
    padding: 10px 0 20px;
    border: none;
    background: none;
    color: inherit;
    font: inherit;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  .tl-left .tl-card { margin-left: auto; }

  .tl-card-main {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Year / title / tag ── */
  .tl-year {
    display: block;
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    margin-bottom: 5px;
  }
  .tl-title {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 22px);
    font-weight: 400; font-style: italic;
    line-height: 1.25;
    margin-bottom: 4px;
    transition: opacity 0.22s;
  }
  .tl-card:hover .tl-title { opacity: 0.65; }
  .tl-tag {
    display: inline-block;
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-top: 2px;
  }

  /* ── Chevron ── */
  .tl-chevron {
    display: inline-block;
    width: 7px; height: 7px;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: rotate(45deg);   /* ▾ down */
    margin-top: 8px;
    opacity: 0.45;
    transition: transform 0.25s ease, opacity 0.25s;
    align-self: flex-start;     /* left side */
    flex-shrink: 0;
  }
  .tl-left .tl-chevron { align-self: flex-end; } /* right-aligned side */
  .tl-card.open .tl-chevron {
    transform: rotate(-135deg); /* ▴ up */
    opacity: 0.8;
  }

  /* ── Expandable description ── */
  .tl-desc {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.38s ease, opacity 0.32s ease;
    opacity: 0;
  }
  .tl-card.open .tl-desc {
    max-height: 160px;
    opacity: 1;
  }
  .tl-card--bullets.open .tl-desc {
    max-height: 800px;
  }
  .tl-desc p {
    font-family: var(--sans);
    font-size: 12.5px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--stone);
    padding-top: 10px;
    border-top: 1px solid var(--rule);
    margin: 8px 0 0;
  }
  /* ── Vine list (Organon expandable bullets) ── */
  .vine-list {
    position: relative;
    padding-left: 48px;
    padding-top: 10px;
    border-top: 1px solid var(--rule);
    margin-top: 10px;
  }
  .vine-svg {
    position: absolute;
    left: 0;
    top: 0;
    width: 40px;
    overflow: visible;
    pointer-events: none;
  }
  .vine-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    margin-bottom: 1.4rem;
    opacity: 0;
  }
  .vine-list.animate .vine-item {
    animation: dropIn 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards;
    animation-delay: calc(var(--i) * 0.15s + 0.3s);
  }
  .vine-body {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink);
  }
  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .vine-flower .petal {
    transform: scale(0);
    transform-origin: 0px 0px;
  }
  .vine-flower.bloom .petal {
    animation: petalBloom 0.55s cubic-bezier(0.34,1.56,0.64,1) forwards;
    animation-delay: calc(var(--pi) * 0.06s);
  }
  .vine-flower .center {
    transform: scale(0);
    transform-origin: 0px 0px;
  }
  .vine-flower.bloom .center {
    animation: petalBloom 0.4s cubic-bezier(0.34,1.56,0.64,1) 0.25s forwards;
  }
  @keyframes petalBloom {
    from { transform: scale(0); }
    to   { transform: scale(1); }
  }

  /* Left side: desc right-aligned to match text direction */
  .tl-left .tl-desc p { text-align: right; }

  /* Colour by side */
  .tl-left  .tl-year,
  .tl-left  .tl-title,
  .tl-left  .tl-tag,
  .tl-left  .tl-chevron { color: var(--pink); }

  .tl-right .tl-year,
  .tl-right .tl-title,
  .tl-right .tl-tag,
  .tl-right .tl-chevron { color: var(--stone); }

  .cat-icon {
    display: inline-block;
    width: 0.85em; height: 0.85em;
    vertical-align: -0.1em;
    margin-right: 0.25em;
    flex-shrink: 0;
  }

  .tl-empty { padding: 10px 0 30px; min-height: 60px; display: block; }

  /* ── Born card ── */
  .tl-card--born { cursor: pointer; }
  .tl-card--born:hover .tl-title { opacity: 0.65; }

  /* ── Lucerne / Swiss Alps animation ── */
  .lucerne-wrapper {
    position: absolute;
    right: calc(100% - 8px);
    top: 0;
    overflow: visible;
    pointer-events: none;
  }
  .lucerne-svg {
    width: 185px;
    height: auto;
    opacity: 0;
    display: block;
  }
  .lucerne-wrapper.playing .lucerne-svg {
    animation: lucerne-arrive 3.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  @keyframes lucerne-arrive {
    0%   { opacity: 0; transform: translateX(-60px) translateY(15px); }
    24%  { opacity: 1; transform: translateX(0) translateY(0); }
    60%  { opacity: 1; transform: translateX(0) translateY(-4px); }
    78%  { opacity: 0.8; transform: translateX(-10px) translateY(-16px); }
    100% { opacity: 0; transform: translateX(-70px) translateY(-48px); }
  }
  @media (max-width: 700px) {
    .lucerne-wrapper {
      right: -8px;
      top: -8px;
    }
    .lucerne-svg { width: 135px; }
  }

  /* ── Panda + hotpot animation ── */
  .tl-left { position: relative; }

  .panda-wrapper {
    position: absolute;
    right: calc(100% - 8px);
    top: 0;
    overflow: visible;
    pointer-events: none;
  }
  .panda-svg {
    width: 100px;
    height: auto;
    opacity: 0;
    display: block;
  }
  .panda-wrapper.playing .panda-svg {
    animation: panda-arrive 3.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  @keyframes panda-arrive {
    0%   { opacity: 0; transform: translateX(-80px) translateY(12px); }
    22%  { opacity: 1; transform: translateX(0) translateY(0); }
    58%  { opacity: 1; transform: translateX(0) translateY(-5px); }
    76%  { opacity: 0.9; transform: translateX(-12px) translateY(-18px); }
    100% { opacity: 0; transform: translateX(-80px) translateY(-48px); }
  }
  @media (max-width: 700px) {
    .panda-wrapper {
      right: -8px;
      top: -8px;
    }
    .panda-svg { width: 85px; }
  }

  /* ── Shanghai skyline animation ── */
  .shanghai-wrapper {
    padding-top: 4px;
    min-height: 60px;
    overflow: visible;
  }
  .shanghai-svg {
    width: 200px;
    height: auto;
    opacity: 0;
    pointer-events: none;
  }
  .shanghai-wrapper.playing .shanghai-svg {
    animation: shanghai-arrive 3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  @keyframes shanghai-arrive {
    0%   { opacity: 0; transform: translateX(160px); }
    25%  { opacity: 1; transform: translateX(0); }
    65%  { opacity: 1; transform: translateX(0); }
    80%  { opacity: 0.8; transform: translateX(-8px) translateY(-6px); }
    100% { opacity: 0; transform: translateX(-60px) translateY(-28px); }
  }
  @media (max-width: 700px) {
    .shanghai-wrapper {
      position: absolute;
      right: -8px;
      top: -8px;
      min-height: 0;
      overflow: visible;
    }
    .shanghai-svg { width: 140px; }
  }

  /* ── Stork animation ── */
  .stork-wrapper {
    padding-top: 4px;
    min-height: 60px;
    overflow: visible;
  }
  .stork-svg {
    width: 140px;
    height: auto;
    opacity: 0;
    pointer-events: none;
  }
  .stork-wrapper.playing .stork-svg {
    animation: stork-arrive 3.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
  @keyframes stork-arrive {
    0%   { opacity: 0;   transform: translateX(180px) translateY(-50px); }
    22%  { opacity: 1;   transform: translateX(0)      translateY(0); }
    55%  { opacity: 1;   transform: translateX(0)      translateY(-8px); }
    72%  { opacity: 1;   transform: translateX(-12px)  translateY(-20px); }
    100% { opacity: 0;   transform: translateX(-80px)  translateY(-60px); }
  }
  @media (max-width: 700px) {
    .stork-wrapper {
      position: absolute;
      right: -8px;
      top: -8px;
      min-height: 0;
      overflow: visible;
    }
    .stork-svg { width: 100px; }
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .tl-row {
      opacity: 1 !important; transform: none !important;
      transition: none !important;
      display: block; padding-left: 36px; position: relative;
    }
    .tl-row--swap {
      display: flex;
      flex-direction: column-reverse;
    }
    .timeline::before { left: 8px; }
    .tl-mid { display: none; }
    .tl-left, .tl-right { display: block; text-align: left; padding: 0; }
    .tl-empty { display: none; }
    .tl-card {
      display: block; position: relative;
      padding: 8px 0 16px; max-width: 100%;
    }
    .tl-left .tl-card { margin-left: 0; }
    .tl-card::before {
      content: '';
      position: absolute;
      left: -28px; top: 13px;
      width: 9px; height: 9px;
      border-radius: 50%;
      border: 1.5px solid var(--rule);
      background: var(--bg);
      z-index: 1;
      transition: border-color 0.25s, background 0.25s;
    }
    .tl-left  .tl-card:hover::before { border-color: var(--pink);  background: var(--pink); }
    .tl-right .tl-card:hover::before { border-color: var(--stone); background: var(--stone); }
    .tl-left  .tl-chevron { align-self: flex-start; }
    .tl-left  .tl-desc p  { text-align: left; }
    .tl-title { font-size: clamp(17px, 4.8vw, 22px); }
    .col-labels { display: none; }
    .page-title { font-size: clamp(40px, 12vw, 64px); }
  }

  @media (max-width: 390px) {
    .wrap { padding: 0 16px; }
    .tl-row { padding-left: 28px; }
    .timeline::before { left: 6px; }
    .tl-card::before { left: -22px; }
  }
</style>

<script>
  /* ── Scroll reveal (desktop only) ── */
  if (window.innerWidth > 700) {
    const rows = document.querySelectorAll('.tl-row');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = [...rows].indexOf(entry.target);
          setTimeout(() => entry.target.classList.add('visible'), idx < 5 ? idx * 70 : 0);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    rows.forEach(r => io.observe(r));
  }

  /* ── University card → full-screen confetti ── */
  (() => {
    const uniCard = document.querySelector('[data-uni]');
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    if (!uniCard || !canvas) return;
    const ctx = canvas.getContext('2d')!;
    const colors = ['#c17d9d','#d4a0b8','#ecc8d8','#f0dce6','#e8a8c0','#b86d8a','#f5d0e0','#ffffff'];
    type P = { x:number;y:number;vx:number;vy:number;size:number;color:string;angle:number;spin:number;life:number;decay:number;shape:'rect'|'circle' };
    let particles: P[] = [];
    let animId = 0;

    function addBurst(ox: number, oy: number) {
      for (let i = 0; i < 28; i++) {
        const a = (Math.PI * 2 * i / 28) + Math.random() * 0.3;
        const spd = Math.random() * 6 + 3;
        particles.push({ x:ox, y:oy, vx:Math.cos(a)*spd, vy:Math.sin(a)*spd - 2,
          size:Math.random()*7+3, color:colors[Math.floor(Math.random()*colors.length)],
          angle:Math.random()*Math.PI*2, spin:(Math.random()-0.5)*0.25,
          life:1, decay:Math.random()*0.008+0.004, shape:Math.random()>0.45?'rect':'circle' });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;
      for (const p of particles) {
        p.vy += 0.1; p.x += p.vx; p.y += p.vy;
        p.angle += p.spin; p.life -= p.decay;
        if (p.life <= 0 || p.y > canvas.height + 20) continue;
        alive = true;
        ctx.save();
        ctx.globalAlpha = Math.min(p.life, 1);
        ctx.translate(p.x, p.y); ctx.rotate(p.angle);
        ctx.fillStyle = p.color;
        if (p.shape === 'rect') ctx.fillRect(-p.size/2, -p.size/4, p.size, p.size/2);
        else { ctx.beginPath(); ctx.arc(0,0,p.size/2,0,Math.PI*2); ctx.fill(); }
        ctx.restore();
      }
      if (alive) animId = requestAnimationFrame(draw);
      else ctx.clearRect(0, 0, canvas.width, canvas.height);
    }

    uniCard.addEventListener('click', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      particles = [];
      cancelAnimationFrame(animId);
      const W = canvas.width, H = canvas.height;
      addBurst(W*0.2, H*0.25); addBurst(W*0.8, H*0.25);
      setTimeout(() => { addBurst(W*0.5, H*0.12); draw(); }, 180);
      setTimeout(() => addBurst(W*0.3, H*0.4), 340);
      setTimeout(() => addBurst(W*0.7, H*0.4), 480);
      draw();
    });
    uniCard.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); uniCard.dispatchEvent(new MouseEvent('click')); }
    });
  })();

  /* ── Lucerne card → Swiss Alps animation ── */
  const lucerneCard = document.querySelector('[data-lucerne]');
  const lucerneWrapper = document.querySelector('.lucerne-wrapper');
  if (lucerneCard && lucerneWrapper) {
    lucerneCard.addEventListener('click', () => {
      lucerneWrapper.classList.remove('playing');
      void (lucerneWrapper as HTMLElement).offsetWidth;
      lucerneWrapper.classList.add('playing');
    });
    lucerneCard.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); lucerneCard.dispatchEvent(new MouseEvent('click')); }
    });
  }

  /* ── Shanghai card → skyline animation ── */
  const shanghaiCard = document.querySelector('[data-shanghai]');
  const shanghaiWrapper = document.querySelector('.shanghai-wrapper');
  if (shanghaiCard && shanghaiWrapper) {
    shanghaiCard.addEventListener('click', () => {
      shanghaiWrapper.classList.remove('playing');
      void (shanghaiWrapper as HTMLElement).offsetWidth;
      shanghaiWrapper.classList.add('playing');
    });
    shanghaiCard.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); shanghaiCard.dispatchEvent(new MouseEvent('click')); }
    });
  }

  /* ── Chengdu card → panda + hotpot animation ── */
  const chengduCard = document.querySelector('[data-chengdu]');
  const pandaWrapper = document.querySelector('.panda-wrapper');
  if (chengduCard && pandaWrapper) {
    chengduCard.addEventListener('click', () => {
      pandaWrapper.classList.remove('playing');
      void (pandaWrapper as HTMLElement).offsetWidth;
      pandaWrapper.classList.add('playing');
    });
    chengduCard.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); chengduCard.dispatchEvent(new MouseEvent('click')); }
    });
  }

  /* ── Born card → stork animation ── */
  const bornCard = document.querySelector('[data-born]');
  const storkWrapper = document.querySelector('.stork-wrapper');
  if (bornCard && storkWrapper) {
    bornCard.addEventListener('click', () => {
      storkWrapper.classList.remove('playing');
      void (storkWrapper as HTMLElement).offsetWidth; // reflow to restart
      storkWrapper.classList.add('playing');
    });
    bornCard.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); bornCard.dispatchEvent(new MouseEvent('click')); }
    });
  }

  /* ── Vine SVG builder ── */
  function buildVine(vineList: HTMLElement) {
    const svg = vineList.querySelector('.vine-svg') as SVGSVGElement | null;
    if (!svg) return;
    const stemEl  = svg.querySelector('.vine-stem')    as SVGPathElement;
    const branchG = svg.querySelector('.vine-branches') as SVGGElement;
    const leafG   = svg.querySelector('.vine-leaves')   as SVGGElement;
    const items   = vineList.querySelectorAll('.vine-item');

    const wrapRect = vineList.getBoundingClientRect();
    const points: number[] = [];
    items.forEach(item => {
      const rect = item.getBoundingClientRect();
      points.push(rect.top - wrapRect.top + rect.height / 2);
    });
    if (points.length < 2) return;

    const lastItemRect = (items[items.length - 1] as HTMLElement).getBoundingClientRect();
    const bottomY = lastItemRect.bottom - wrapRect.top;
    const totalH = bottomY + 6;
    svg.setAttribute('viewBox', `0 0 40 ${totalH}`);
    (svg as HTMLElement).style.height = totalH + 'px';

    let d = 'M 20 0 ';
    points.forEach((y, i) => {
      const wobble = (i % 2 === 0) ? 8 : -8;
      const x = 20 + wobble;
      if (i === 0) {
        d += `C 20 ${y * 0.3} ${x} ${y * 0.6} ${x} ${y} `;
      } else {
        const py = points[i - 1];
        const px = 20 + ((i - 1) % 2 === 0 ? 8 : -8);
        d += `C ${px} ${py + (y - py) * 0.4} ${x} ${py + (y - py) * 0.6} ${x} ${y} `;
      }
    });
    const lastY = points[points.length - 1];
    const lastX = 20 + ((points.length - 1) % 2 === 0 ? 8 : -8);
    d += `C ${lastX} ${lastY + (bottomY - lastY) * 0.4} 20 ${lastY + (bottomY - lastY) * 0.7} 20 ${bottomY}`;
    stemEl.setAttribute('d', d);

    let bHTML = '', lHTML = '';
    points.forEach((y, i) => {
      const sx = 20 + (i % 2 === 0 ? 8 : -8);
      const tx = 44;
      const c1x = sx + (tx - sx) * 0.3, c2x = sx + (tx - sx) * 0.7;
      bHTML += `<path d="M ${sx} ${y} C ${c1x} ${y - 4} ${c2x} ${y - 2} ${tx} ${y}" stroke="rgba(193,125,157,0.3)" stroke-width="1" stroke-linecap="round" fill="none"/>`;
      const lx = sx + (tx - sx) * 0.5, ly = y - 7;
      lHTML += `<ellipse cx="${lx}" cy="${ly}" rx="4.5" ry="2.5" fill="rgba(193,125,157,0.2)" stroke="rgba(193,125,157,0.25)" stroke-width="0.8" transform="rotate(-30 ${lx} ${ly})"/>`;
    });
    branchG.innerHTML = bHTML;
    leafG.innerHTML   = lHTML;

    // bloom flowers after all items have animated in
    const bloomDelay = points.length * 150 + 300 + 400;
    setTimeout(() => bloomFlowers(vineList, points), bloomDelay);
  }

  function bloomFlowers(vineList: HTMLElement, points: number[]) {
    const svg = vineList.querySelector('.vine-svg') as SVGSVGElement | null;
    if (!svg) return;
    const flowersEl = svg.querySelector('.vine-flowers') as SVGGElement;
    flowersEl.innerHTML = '';

    // seed a repeatable pseudo-random sequence so re-open looks the same
    let seed = 42;
    const rand = () => { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; };

    // scatter flowers across the full stem length with irregular spacing
    const stemTop = points[0] * 0.3;
    const stemBottom = points[points.length - 1] + 28;
    const stemLength = stemBottom - stemTop;

    // 7–8 flowers at irregular y positions, skipping the exact branch points
    const flowerYs: number[] = [];
    let cursor = stemTop + stemLength * 0.05;
    while (cursor < stemBottom - 10) {
      cursor += stemLength * (0.09 + rand() * 0.11); // uneven gaps
      // avoid landing too close to a branch point (±10px)
      const tooClose = points.some(p => Math.abs(p - cursor) < 10);
      if (!tooClose && cursor < stemBottom - 8) flowerYs.push(cursor);
    }

    flowerYs.forEach((y, fi) => {
      // x follows stem wobble but offset slightly off-stem
      const wobble = Math.sin(y * 0.18) * 7 + (rand() - 0.5) * 5;
      const x = 20 + wobble;
      const scale = 0.7 + rand() * 0.55;          // size variety
      const tilt  = (rand() - 0.5) * 40;           // rotation tilt
      const delay = fi * (160 + rand() * 120);      // irregular timing

      setTimeout(() => {
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.setAttribute('transform', `translate(${x}, ${y}) rotate(${tilt}) scale(${scale})`);
        g.classList.add('vine-flower');
        let html = '';
        for (let p = 0; p < 5; p++) {
          const angle = p * 72 - 90;
          html += `<g transform="rotate(${angle})"><ellipse class="petal" style="--pi:${p}" cx="0" cy="-5" rx="2.6" ry="4" fill="rgba(241,210,225,0.92)" stroke="rgba(193,125,157,0.55)" stroke-width="0.6"/></g>`;
        }
        html += `<circle class="center" r="2" fill="rgba(193,125,157,0.85)"/>`;
        g.innerHTML = html;
        flowersEl.appendChild(g);
        requestAnimationFrame(() => requestAnimationFrame(() => g.classList.add('bloom')));
      }, delay);
    });
  }

  /* ── Click to expand / collapse ── */
  document.querySelectorAll('.tl-card').forEach(card => {
    const open = () => {
      const isOpen = card.classList.contains('open');
      card.classList.toggle('open', !isOpen);
      card.setAttribute('aria-expanded', String(!isOpen));
      const desc = card.querySelector('.tl-desc');
      if (desc) desc.setAttribute('aria-hidden', String(isOpen));

      const vineList = card.querySelector('.vine-list') as HTMLElement | null;
      if (vineList) {
        if (!isOpen) {
          vineList.classList.remove('animate');
          void vineList.offsetWidth;
          vineList.classList.add('animate');
          requestAnimationFrame(() => requestAnimationFrame(() => buildVine(vineList)));
        } else {
          const flowersEl = vineList.querySelector('.vine-flowers');
          if (flowersEl) flowersEl.innerHTML = '';
        }
      }
    };

    card.addEventListener('click', open);
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
    });
  });
</script>
