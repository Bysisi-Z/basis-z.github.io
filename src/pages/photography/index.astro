---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Watermark from '../../components/Watermark.astro';

/**
 * orientation: 'portrait' | 'landscape'
 * Grid behaviour:
 *   portrait  → grid-column: span 2 of 6, aspect-ratio 3/4
 *   landscape → grid-column: span 4 of 6, aspect-ratio 16/9
 */
const entries = [
  {
    slug: 'lucerne',
    category: 'City Guide',
    title: 'Lucerne – The Heart of Switzerland',
    orientation: 'landscape',
    imgSrc: '/images/lucerne/DSC08012.jpg',
    imgAlt: 'Lucerne old town and Hofkirche spires in winter, Switzerland',
  },
  {
    slug: 'stoos-ridge-line',
    category: 'Hiking Guide',
    title: "Stoos Ridge Hike, Switzerland's Most Stunning Ridge Walk",
    orientation: 'portrait',
    imgSrc: '/images/haute-route-alps.jpeg',
    imgAlt: 'Alpine wildflowers, Stoos, Switzerland',
    ph: 'ph-1',
  },
  {
    slug: 'oeschinensee',
    category: 'Hiking Guide',
    title: 'Oeschinensee Panorama Trail',
    orientation: 'portrait',
    imgSrc: '/images/oeschinensee/IMG_3898.jpeg',
    imgAlt: 'Oeschinensee panorama from above, Bernese Oberland, Switzerland',
    note: 'Book in advance — one of the most popular destinations in the Bernese Oberland',
  },
];
---

<BaseLayout
  title="Nature Never Judges"
  description="Trails walked, peaks reached, silences found."
>
  <div class="wrap">
    <header class="page-header">
      <h1 class="page-title">Nature never judges</h1>
      <p class="page-sub">Trails walked, peaks reached, silences found.</p>
      <a href="/trails" class="map-link"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:5px;flex-shrink:0"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>View all trails on the map →</a>
    </header>
  </div>

  <div class="wrap">
    <div class="cards-grid">
      {entries.map((e, i) => (
        <a
          class={`card ${e.orientation}`}
          href={`/photography/${e.slug}`}
          style={`--i:${i}`}
        >
          {e.imgSrc
            ? <><img class="card-img" src={e.imgSrc} alt={e.imgAlt ?? e.title} /><Watermark /></>
            : <div class={`card-img ${e.ph}`}></div>
          }
          <div class="card-overlay">
            <span class="card-category">{e.category}</span>
            <h2 class="card-title">{e.title}</h2>
            {e.note && <p class="card-note">{e.note}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 60px);
  }

  /* ── Header ── */
  .page-header {
    padding-top: 64px;
    padding-bottom: 44px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 44px;
  }
  .eyebrow {
    font-size: 10px; font-weight: 300;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--stone);
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
  }
  .eyebrow::before { content: ''; width: 20px; height: 1px; background: var(--pink); }
  .page-title {
    font-family: var(--serif);
    font-size: clamp(44px, 8vw, 88px);
    font-weight: 300; font-style: italic;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--ink); margin-bottom: 16px;
  }
  .page-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 300; font-style: italic;
    color: var(--stone);
  }
  .map-link {
    display: inline-flex;
    align-items: center;
    margin-top: 24px;
    padding: 9px 20px;
    font-family: var(--sans);
    font-size: 11px; font-weight: 300;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--pink);
    text-decoration: none;
    border: 1px solid var(--pink);
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
  }
  .map-link:hover {
    background: var(--pink);
    color: #fff;
  }

  /* ── Mixed grid ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: auto;
    grid-auto-flow: dense;
    gap: 14px;
    padding-bottom: 80px;
    align-items: start;
  }

  /* Portrait: 2/6 cols, 3:4 ratio — naturally taller */
  .card.portrait  { grid-column: span 2; aspect-ratio: 3/4; }

  /* Landscape: 4/6 cols, 16:9 ratio — wide */
  .card.landscape { grid-column: span 4; aspect-ratio: 16/9; }

  /* ── Card base ── */
  .card {
    position: relative;
    display: block;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    background: #2a3a4a;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .card.visible { opacity: 1; transform: translateY(0); }

  .card-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }
  .card:hover .card-img { transform: scale(1.05); }

  .card-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 48px 18px 18px;
    background: linear-gradient(to top,
      rgba(10,10,10,0.78) 0%,
      rgba(10,10,10,0.32) 55%,
      transparent 100%);
    transition: padding-bottom 0.3s ease;
  }
  .card:hover .card-overlay { padding-bottom: 24px; }

  .card-category {
    display: block; font-size: 9px; font-weight: 300;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.55); margin-bottom: 6px;
  }
  .card-title {
    font-family: var(--serif);
    font-size: clamp(17px, 2vw, 22px);
    font-weight: 400; font-style: italic;
    line-height: 1.2; color: #fff;
  }
  .card-note {
    font-family: var(--sans); font-size: 11px; font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.6);
    margin: 6px 0 0; line-height: 1.5;
  }

  /* ── Gradient placeholders ── */
  .ph-1 { background: linear-gradient(160deg,#3a5068,#4a6a88,#8aafc4,#d0e0ea); }
  .ph-1::before {
    content:''; position:absolute; bottom:0; left:0; right:0; height:55%;
    background:linear-gradient(180deg,transparent,#1e2e3e);
    clip-path:polygon(0% 100%,0% 60%,10% 40%,20% 58%,30% 28%,40% 50%,50% 20%,60% 45%,70% 28%,80% 50%,90% 35%,100% 55%,100% 100%);
  }
  .ph-2 { background: linear-gradient(170deg,#2a4438,#4a7862,#8ab898,#b8d4c0); }
  .ph-3 { background: linear-gradient(180deg,#1a2a4a,#4a68a0,#c8dcea,#e8f0f4); }
  .ph-4 { background: linear-gradient(165deg,#1e3248,#4a7090,#d4e8f0); }
  .ph-5 { background: linear-gradient(175deg,#2a1e38,#7a4878,#d8a898,#f0dcc8); }
  .ph-6 { background: linear-gradient(160deg,#28303c,#5a6878,#d0dce0); }

  /* ── Responsive ── */
  /* Tablet: landscape still wide, portrait smaller */
  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .card.portrait  { grid-column: span 2; }
    .card.landscape { grid-column: span 4; aspect-ratio: 4/3; }
  }

  /* Mobile: single column */
  @media (max-width: 560px) {
    .cards-grid { grid-template-columns: 1fr; gap: 12px; }
    .card.portrait,
    .card.landscape { grid-column: span 1; }
    .card.portrait  { aspect-ratio: 4/5; }
    .card.landscape { aspect-ratio: 4/3; }
    /* Always visible on mobile */
    .card { opacity: 1 !important; transform: none !important; }
  }
</style>

<script>
  const cards = document.querySelectorAll('.card');
  if (window.innerWidth > 560) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = [...cards].indexOf(entry.target);
          setTimeout(() => entry.target.classList.add('visible'), idx * 90);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    cards.forEach(c => io.observe(c));
  }
</script>
