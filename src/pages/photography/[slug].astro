                zhIntro: '文章中附上了相关链接：', zhItems: ['<a href="https://www.stoos.ch/en/" target="_blank" rel="noopener" style="color:var(--rose);text-decoration:underline;text-underline-offset:3px">Stoos 官方网站</a>', '实时摄像头'] },
