---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleHero from '../../components/ArticleHero.astro';
import Comments from '../../components/Comments.astro';

interface DayItem {
  num: string;
  title: string;
  detail: string;
}

type Block =
  | { type: 'p'; text: string; zh?: string }
  | { type: 'ul'; items: string[]; intro?: string; zhItems?: string[]; zhIntro?: string }
  | { type: 'subheading'; num: string; text: string; zh?: string };

interface GalleryImg {
  src: string;
  alt?: string;
  span?: 'full' | 'half';
}

interface Entry {
  slug: string;
  title: string;
  titleHtml: string;
  eyebrow: string;
  subtitle: string;
  orientation: 'portrait' | 'landscape';
  imagePosition?: 'left' | 'right';
  src: string;
  alt: string;
  stats: { label: string; value: string }[];
  meta: { label: string; value: string }[];
  webcamUrl?: string;
  webcamHint?: string;
  webcamHintZh?: string;
  webcamNote?: string;
  webcamNoteZh?: string;
  heroIntro?: string[];
  routeOverview?: {
    direction: string;
    stats: { label: string; value: string }[];
    note?: string;
  };
  heroIntroZh?: string[];
  routeOverviewZh?: {
    direction?: string;
    stats?: { label: string; value: string }[];
    note?: string;
  };
  routeMapSrc?: string;
  routeMapAlt?: string;
  routeMapNote?: string;
  routeMapNoteZh?: string;
  langZh?: boolean;
  gallery?: GalleryImg[];
  body: {
    lead: string;
    paragraphs: string[];
    pullQuote?: string;
    inlineImgSrc?: string;
    inlineImgAlt?: string;
    inlineImgCaption?: string;
    sections: {
      heading: string;
      headingZh?: string;
      paragraphs?: string[];
      blocks?: Block[];
      days?: DayItem[];
      tipLabel?: string;
      tipItems?: { bold: string; text: string }[];
      photos?: { src: string; alt?: string; full?: boolean; pos?: string }[];
    }[];
    closing: string[];
  };
}

export function getStaticPaths() {
  const entries: Entry[] = [
    {
      slug: 'stoos-ridge-line',
      title: "Stoos Ridge Hike, Switzerland's Most Stunning Ridge Walk",
      titleHtml: "Stoos Ridge Hike,<br/>Switzerland's Most Stunning<br/>Ridge Walk",
      eyebrow: 'Hiking Guide · Schwyz · Switzerland',
      subtitle: '',
      webcamUrl: 'https://www.stoos.ch/en/pages/webcams',
      webcamHint: 'Weather in the Alps changes quickly at altitude. Check the live webcam before your visit to confirm current conditions on the ridge.',
      webcamHintZh: '阿尔卑斯山高海拔地区天气变化迅速，建议出发前查看实时摄像头，确认当前的山脊天气状况。',
      heroIntro: [
        'The Stoos Ridge hike is one of my favorite hikes in Switzerland.',
        'I first discovered it through a hiking YouTuber who included it in a list of his top hikes in the country. As soon as I saw the footage, I knew I had to visit.',
        'I completed the hike in early July 2023. Down in the valleys, summer had already arrived, but at higher elevations it still felt like spring. Wildflowers covered the slopes along the ridge, creating some of the most beautiful alpine scenery I have seen in Switzerland.',
        'What impressed me most was how much this trail offers for so little effort. Along the route, you can enjoy panoramic views of Lake Lucerne and the surrounding Alps, while the overall difficulty remains manageable for most reasonably active hikers.',
      ],
      langZh: true,
      heroIntroZh: [
        'Stoos 山脊徒步是我在瑞士最喜欢的徒步路线之一。',
        '我最初是通过一位徒步博主发现这条路线的，他将其列为瑞士最佳徒步线路之一。看到视频画面的那一刻，我就知道自己一定要亲自来走走。',
        '我在 2023 年 7 月初完成了这次徒步。山谷中夏天早已到来，但在高海拔处仍带着春末的清新。山脊沿途的山坡上野花盛开，是我在瑞士见过的最美丽的高山风光之一。',
        '最令我印象深刻的是，这条路线以如此小的体力付出，带来了如此丰富的风景体验。沿途可以欣赏琉森湖和周围阿尔卑斯山脉的全景，而整体难度对大多数有基本体力的徒步者来说都完全可以胜任。',
      ],
      routeOverview: {
        direction: 'Klingenstock → Fronalpstock',
        stats: [
          { label: 'Distance',    value: '~4.5 km' },
          { label: 'Walking',     value: '~2 hours' },
          { label: 'Total time',  value: '4–5 hours' },
          { label: 'Difficulty',  value: 'Moderate' },
        ],
        note: 'Both directions involve similar ascent and descent, but finishing at Fronalpstock makes for a far more satisfying end. The summit has a large viewing platform with panoramic views over Lake Lucerne and the Alps, a mountain restaurant, rest areas, and cable car access back down to Stoos — the perfect place to sit, eat, and soak in the scenery before descending. Klingenstock, by contrast, has fewer facilities and a smaller platform, making it a better starting point than a destination.',
      },
      routeOverviewZh: {
        stats: [
          { label: '距离',    value: '约 4.5 km' },
          { label: '步行时长', value: '约 2 小时' },
          { label: '建议总时长', value: '4–5 小时' },
          { label: '难度',    value: '中等' },
        ],
        note: '两个方向的爬升和下降大致相同，但以 Fronalpstock 为终点会让整段旅程更有成就感。山顶设有宽阔的观景台，可将琉森湖和阿尔卑斯山脉的全景尽收眼底，配有山间餐厅、休息区和缆车下行设施——是在欣赏风景、用餐休息之后再下山的理想收尾地点。Klingenstock 的设施相对有限，平台也较小，更适合作为出发点而非终点。',
      },
      routeMapSrc: '/images/stoos/stoos-route-map.png',
      routeMapAlt: 'Stoos Ridge Hike route map with elevation profile',
      routeMapNote: 'Map from AllTrails app. Recommended direction: start at Klingenstock (right side of map) and hike west towards Fronalpstock (left side of map).',
      routeMapNoteZh: '推荐方向：从地图右侧的 Klingenstock 出发，向西行进至地图左侧的 Fronalpstock。',
      orientation: 'portrait',
      imagePosition: 'left',
      src: '/images/haute-route-alps.jpeg',
      alt: 'Alpine wildflowers, Haute Route, Swiss Alps',
      stats: [],
      meta: [],
      body: {
        lead: '',
        paragraphs: [],
        sections: [
          {
            heading: "A Photographer's Recommendation",
            headingZh: '摄影师的建议',
            blocks: [
              { type: 'p', text: 'As someone who enjoys photography, I always recommend starting alpine hikes <strong class="hl">as early as possible</strong>.', zh: '作为一名摄影爱好者，我始终建议尽可能在<strong class="hl">清晨出发</strong>进行高山徒步。' },
              { type: 'p', text: 'This applies to almost every hike in Switzerland.', zh: '这条建议适用于瑞士几乎所有的徒步路线。' },
              { type: 'ul', intro: 'In the early morning:', items: [
                'Air clarity is usually <strong class="hl">at its best</strong>.',
                'Haze is minimal.',
                'Colors appear <strong class="hl">more saturated</strong>.',
                'Visibility is often <strong class="hl">significantly better</strong> than later in the day.',
                'The light is <strong class="hl">softer and more pleasant</strong> for photography.',
              ], zhIntro: '清晨时分：', zhItems: [
                '能见度通常<strong class="hl">处于最佳状态</strong>。',
                '空气中雾霾最少。',
                '色彩<strong class="hl">更加饱和</strong>。',
                '清晰度通常比一天中晚些时候<strong class="hl">明显更好</strong>。',
                '光线<strong class="hl">更柔和，更适合拍摄</strong>。',
              ]},
