---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleHero from '../../components/ArticleHero.astro';

interface DayItem {
  num: string;
  title: string;
  detail: string;
}

type Block =
  | { type: 'p'; text: string }
  | { type: 'ul'; items: string[]; intro?: string }
  | { type: 'subheading'; num: string; text: string };

interface GalleryImg {
  src: string;
  alt?: string;
  span?: 'full' | 'half';
}

interface Entry {
  slug: string;
  title: string;
  titleHtml: string;
  eyebrow: string;
  subtitle: string;
  orientation: 'portrait' | 'landscape';
  imagePosition?: 'left' | 'right';
  src: string;
  alt: string;
  stats: { label: string; value: string }[];
  meta: { label: string; value: string }[];
  webcamUrl?: string;
  heroIntro?: string[];
  routeOverview?: {
    direction: string;
    stats: { label: string; value: string }[];
    note?: string;
  };
  routeMapSrc?: string;
  routeMapAlt?: string;
  routeMapNote?: string;
  gallery?: GalleryImg[];
  body: {
    lead: string;
    paragraphs: string[];
    pullQuote?: string;
    inlineImgSrc?: string;
    inlineImgAlt?: string;
    inlineImgCaption?: string;
    sections: {
      heading: string;
      paragraphs?: string[];
      blocks?: Block[];
      days?: DayItem[];
      tipLabel?: string;
      tipItems?: { bold: string; text: string }[];
    }[];
    closing: string[];
  };
}

export function getStaticPaths() {
  const entries: Entry[] = [
    {
      slug: 'stoos-ridge-line',
      title: "Stoos Ridge Hike, Switzerland's Most Stunning Ridge Walk",
      titleHtml: "Stoos Ridge Hike,<br/>Switzerland's Most Stunning<br/>Ridge Walk",
      eyebrow: 'Hiking Guide · Schwyz · Switzerland',
      subtitle: '',
      webcamUrl: 'https://www.stoos.ch/en/pages/webcams',
      heroIntro: [
        'The Stoos Ridge hike is one of my favorite hikes in Switzerland.',
        'I first discovered it through a hiking YouTuber who included it in a list of his top hikes in the country. As soon as I saw the footage, I knew I had to visit.',
        'I completed the hike in early July 2023. Down in the valleys, summer had already arrived, but at higher elevations it still felt like spring. Wildflowers covered the slopes along the ridge, creating some of the most beautiful alpine scenery I have seen in Switzerland.',
        'What impressed me most was how much this trail offers for so little effort. Along the route, you can enjoy panoramic views of Lake Lucerne, the surrounding Alps, and the iconic Mythen peaks, while the overall difficulty remains manageable for most reasonably active hikers.',
      ],
      routeOverview: {
        direction: 'Klingenstock → Fronalpstock',
        stats: [
          { label: 'Distance',    value: '~4.5 km' },
          { label: 'Walking',     value: '~2 hours' },
          { label: 'Total time',  value: '4–5 hours' },
          { label: 'Difficulty',  value: 'Moderate' },
        ],
        note: 'Both directions involve similar ascent and descent, but finishing at Fronalpstock makes for a far more satisfying end. The summit has a large viewing platform with panoramic views over Lake Lucerne and the Alps, a mountain restaurant, rest areas, and cable car access back down to Stoos — the perfect place to sit, eat, and soak in the scenery before descending. Klingenstock, by contrast, has fewer facilities and a smaller platform, making it a better starting point than a destination.',
      },
      routeMapSrc: '/images/stoos/stoos-route-map.png',
      routeMapAlt: 'Stoos Ridge Hike route map with elevation profile',
      routeMapNote: 'Recommended direction: start at Klingenstock (right side of map) and hike west towards Fronalpstock (left side of map).',
      orientation: 'portrait',
      imagePosition: 'left',
      src: '/images/haute-route-alps.jpeg',
      alt: 'Alpine wildflowers, Haute Route, Swiss Alps',
      stats: [],
      meta: [],
      body: {
        lead: '',
        paragraphs: [],
        sections: [
          {
            heading: "A Photographer's Recommendation",
            blocks: [
              { type: 'p', text: 'As someone who enjoys photography, I always recommend starting alpine hikes <strong class="hl">as early as possible</strong>.' },
              { type: 'p', text: 'This applies to almost every hike in Switzerland.' },
              { type: 'ul', intro: 'In the early morning:', items: [
                'Air clarity is usually <strong class="hl">at its best</strong>.',
                'Haze is minimal.',
                'Colors appear <strong class="hl">more saturated</strong>.',
                'Visibility is often <strong class="hl">significantly better</strong> than later in the day.',
                'The light is <strong class="hl">softer and more pleasant</strong> for photography.',
              ]},
              { type: 'p', text: 'This is another reason why I prefer hiking from Klingenstock to Fronalpstock.' },
              { type: 'p', text: 'On most summer mornings, <strong class="hl">the sun is behind you</strong> when walking from east to west along the ridge. You avoid looking directly into strong sunlight, and even near midday the lighting conditions remain comfortable for both hiking and photography.' },
            ],
          },
          {
            heading: 'Things You Should Know Before Going',
            blocks: [
              { type: 'subheading', num: '1', text: 'It is not completely effortless' },
              { type: 'p', text: 'While I would not consider this a difficult hike, it is <strong class="hl">not a casual walk</strong> either.' },
              { type: 'p', text: 'People who rarely exercise may find certain sections challenging, especially the <strong class="hl">steeper climbs near the beginning</strong> of the route.' },
              { type: 'p', text: 'If you hike occasionally and have a reasonable fitness level, however, the trail should be <strong class="hl">very manageable</strong>.' },

              { type: 'subheading', num: '2', text: 'There is almost no shade' },
              { type: 'p', text: 'This is an <strong class="hl">exposed ridge hike</strong>.' },
              { type: 'p', text: 'There are very few trees along the route, meaning <strong class="hl">almost no protection from the sun</strong>.' },
              { type: 'p', text: 'On warm summer days, especially around noon and in the afternoon, the heat can feel <strong class="hl">surprisingly intense</strong>.' },
              { type: 'ul', intro: 'I strongly recommend:', items: [
                '<strong class="hl">Bringing sufficient water</strong>',
                'Using sunscreen',
                'Wearing a hat or cap',
                '<strong class="hl">Starting early</strong> whenever possible',
              ]},

              { type: 'subheading', num: '3', text: 'No facilities on the ridge' },
              { type: 'p', text: 'Once you leave the stations, there are:' },
              { type: 'ul', items: [
                '<strong class="hl">No toilets</strong>',
                '<strong class="hl">No food stands</strong>',
                '<strong class="hl">No drinking water points</strong>',
              ]},
              { type: 'p', text: 'Make sure you <strong class="hl">bring everything you need</strong> before starting.' },

              { type: 'subheading', num: '4', text: 'Wear proper footwear' },
              { type: 'p', text: 'You do not need heavy mountaineering boots for this trail.' },
              { type: 'p', text: 'A good pair of <strong class="hl">hiking shoes or sturdy sports shoes</strong> is usually sufficient.' },
              { type: 'ul', intro: 'However, I would avoid:', items: ['Sandals', 'Casual fashion shoes', 'Leather dress shoes'] },
              { type: 'p', text: 'The trail includes <strong class="hl">uneven terrain where proper grip is important</strong>.' },

              { type: 'subheading', num: '5', text: 'Hiking poles are helpful — but not always' },
              { type: 'p', text: 'I highly recommend hiking poles, especially for the steeper sections.' },
              { type: 'p', text: 'They can <strong class="hl">save a significant amount of energy</strong> during climbs and <strong class="hl">reduce stress on your knees</strong> during descents.' },
              { type: 'p', text: 'That said, Stoos Ridge is a very popular route. During busy periods, some sections can become crowded.' },
              { type: 'p', text: "On flatter and narrower stretches, I usually put my poles away to avoid slowing down other hikers or accidentally getting in someone's way." },
            ],
          },
          {
            heading: 'Safety',
            blocks: [
              { type: 'p', text: 'Although I personally consider the overall risk level relatively low, it is <strong class="hl">still a mountain ridge</strong>.' },
              { type: 'p', text: 'The views are spectacular and it is easy to become distracted while taking photos.' },
              { type: 'p', text: '<strong class="hl">Always pay attention to where you are stepping</strong>, particularly when stopping for pictures or looking away from the trail.' },
              { type: 'p', text: '<strong class="hl">No photograph is worth an injury.</strong>' },
            ],
          },
          {
            heading: 'Getting There',
            blocks: [
              { type: 'p', text: 'Another highlight of this trip is the journey itself.' },
              { type: 'p', text: 'Before reaching the ridge, you can ride the famous Stoos funicular, which is often described as <strong class="hl">the steepest funicular railway in the world</strong>.' },
              { type: 'p', text: 'From Stoos village, you can then take the chairlift up to Klingenstock and begin the hike.' },
              { type: 'p', text: 'Transport schedules may change depending on the season, weather conditions, and maintenance work, so I recommend <strong class="hl">checking the official Stoos website before departure</strong>.' },
              { type: 'ul', intro: 'I have included links to:', items: ['The official Stoos website', 'The live webcams'] },
              { type: 'p', text: 'Checking the webcams before leaving home is <strong class="hl">one of the easiest ways to evaluate visibility and weather conditions</strong> in real time.' },
              { type: 'p', text: 'I also recommend using the <strong class="hl">MeteoSwiss app</strong> for weather updates during your trip.' },
            ],
          },
          {
            heading: 'Final Thoughts',
            blocks: [
              { type: 'p', text: 'Stoos Ridge remains one of my <strong class="hl">favourite hikes in Switzerland</strong>.' },
              { type: 'p', text: 'It offers an <strong class="hl">ideal balance between spectacular scenery, reasonable effort, and accessibility</strong>. Whether you are visiting Switzerland for the first time or have lived here for years, it is a route that <strong class="hl">deserves a place on your hiking list</strong>.' },
              { type: 'p', text: 'If you have already completed the hike, or if you are planning to visit soon, feel free to leave a comment and share your experience.' },
            ],
          },
        ],
        closing: [],
      },
      gallery: [
        { src: '/images/stoos/IMG_3352.jpeg',     span: 'full' },
        { src: '/images/stoos/IMG_3354.jpeg' },
        { src: '/images/stoos/IMG_3355.jpeg' },
        { src: '/images/stoos/IMG_3383.jpeg' },
        { src: '/images/stoos/IMG_3386.jpeg',     span: 'full' },
        { src: '/images/stoos/IMG_3399.jpeg' },
        { src: '/images/stoos/IMG_3401.jpeg' },
        { src: '/images/stoos/IMG_3404.jpeg' },
        { src: '/images/stoos/IMG_3413.jpeg',     span: 'full' },
        { src: '/images/stoos/IMG_3422.jpeg' },
        { src: '/images/stoos/IMG_3429.jpeg' },
        { src: '/images/stoos/IMG_3435.jpeg' },
        { src: '/images/stoos/stoos2b.jpeg' },
        { src: '/images/stoos/stoos2.jpeg',       span: 'full' },
        { src: '/images/stoos/stoos3b.jpeg' },
        { src: '/images/stoos/stoos3.jpeg' },
        { src: '/images/stoos/stoos4b.jpeg' },
        { src: '/images/stoos/stoos4.jpeg' },
        { src: '/images/stoos/stoos5.jpeg',       span: 'full' },
        { src: '/images/stoos/stoos6.jpeg' },
        { src: '/images/stoos/stoos7.jpeg' },
        { src: '/images/stoos/stoos8.jpeg' },
        { src: '/images/stoos/stoos9.jpeg' },
      ],
    },
  ];
  return entries.map(e => ({ params: { slug: e.slug }, props: e }));
}

const entry = Astro.props as Entry;
const { title, eyebrow, subtitle, orientation, imagePosition, src, alt, stats, meta, body, webcamUrl, heroIntro, routeOverview } = entry;
---

<BaseLayout title={title} description={subtitle}>
  <ArticleHero
    src={src}
    alt={alt}
    orientation={orientation}
    imagePosition={imagePosition}
    eyebrow={eyebrow}
    title={entry.titleHtml}
    subtitle={subtitle}
    stats={stats}
    webcamUrl={webcamUrl}
    heroIntro={heroIntro}
    routeOverview={routeOverview}
  />

  <div class="article">

    <div class="meta-bar">
      {meta.map((m, i) => (
        <>
          {i > 0 && <div class="meta-divider"></div>}
          <div class="meta-item">
            <span class="meta-label">{m.label}</span>
            <span class="meta-value">{m.value}</span>
          </div>
        </>
      ))}
    </div>

    {entry.routeMapSrc && (
      <div class="route-map-wrap">
        <img src={entry.routeMapSrc} alt={entry.routeMapAlt ?? 'Route map'} />
        {entry.routeMapNote && <p class="route-map-note">{entry.routeMapNote}</p>}
      </div>
    )}

    <div class="body-text">
      <p class="lead">{body.lead}</p>
      {body.paragraphs.map(p => <p>{p}</p>)}

      {body.pullQuote && (
        <div class="pull-quote">
          <p>{body.pullQuote}</p>
        </div>
      )}
    </div>

    {body.inlineImgSrc && (
      <>
        <div class="inline-img-wrap">
          <img src={body.inlineImgSrc} alt={body.inlineImgAlt} />
        </div>
        {body.inlineImgCaption && (
          <p class="inline-img-caption">{body.inlineImgCaption}</p>
        )}
      </>
    )}

    {body.sections.map(section => (
      <div class={`body-text${section.blocks?.some(b => b.type === 'subheading') ? ' compact' : ''}`}>
        <h2 class="section-heading">{section.heading}</h2>

        {section.paragraphs?.map(p => <p>{p}</p>)}

        {section.blocks?.map(b => {
          if (b.type === 'p') return <p set:html={b.text}></p>;
          if (b.type === 'subheading') return (
            <h3 class="sub-heading">
              <span class="sub-num">{b.num}</span>
              <span class="sub-heading-text">{b.text}</span>
            </h3>
          );
          if (b.type === 'ul') return (
            <div class="ul-wrap">
              {b.intro && <p class="ul-intro" set:html={b.intro}></p>}
              <ul class="body-list">
                {b.items.map(item => <li set:html={item}></li>)}
              </ul>
            </div>
          );
        })}

        {section.days && (
          <div class="day-list">
            {section.days.map(d => (
              <div class="day-item">
                <div class="day-num">{d.num}</div>
                <div>
                  <div class="day-title">{d.title}</div>
                  <div class="day-detail">{d.detail}</div>
                </div>
              </div>
            ))}
          </div>
        )}

        {section.tipLabel && section.tipItems && (
          <div class="tip-box">
            <p class="tip-label">{section.tipLabel}</p>
            {section.tipItems.map(t => (
              <p><strong class="tip-bold">{t.bold}</strong> {t.text}</p>
            ))}
          </div>
        )}
      </div>
    ))}

    {entry.gallery && entry.gallery.length > 0 && (
      <div class="gallery-section">
        <h2 class="section-heading">On the Trail</h2>
        <div class="carousel" id="photo-carousel">
          <div class="carousel-track">
            {entry.gallery.map((img, i) => (
              <div class={`carousel-slide${i === 0 ? ' active' : ''}`} data-index={i}>
                <img src={img.src} alt={img.alt ?? 'Stoos Ridge, Switzerland'} loading={i < 3 ? 'eager' : 'lazy'} />
              </div>
            ))}
          </div>
          <button class="carousel-btn carousel-prev" aria-label="Previous photo">&#8249;</button>
          <button class="carousel-btn carousel-next" aria-label="Next photo">&#8250;</button>
          <div class="carousel-counter">
            <span id="carousel-cur">1</span>&thinsp;/&thinsp;{entry.gallery.length}
          </div>
        </div>
      </div>
    )}

    <a class="back-link" href="/photography">← Back to Mountain Calling</a>

  </div>
</BaseLayout>

<style>
  .article {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* Meta bar */
  .meta-bar {
    display: flex; align-items: center;
    gap: 24px; flex-wrap: wrap;
    padding: 36px 0 32px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 52px;
  }
  .meta-item { display: flex; flex-direction: column; gap: 3px; }
  .meta-label {
    font-size: 9px; font-weight: 300;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--rule);
  }
  .meta-value { font-size: 12px; font-weight: 300; color: var(--stone); }
  .meta-divider { width: 1px; height: 28px; background: var(--rule); }
  @media (max-width: 480px) { .meta-divider { display: none; } }

  /* Body text */
  .body-text {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 21px);
    font-weight: 300; line-height: 1.82;
    color: var(--ink);
  }
  .lead {
    font-size: clamp(20px, 2.4vw, 24px);
    line-height: 1.7; margin-bottom: 36px;
  }
  .body-text p + p { margin-top: 26px; }

  /* Section heading */
  .section-heading {
    font-family: var(--serif);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 300; font-style: italic;
    color: var(--ink);
    margin-top: 64px; margin-bottom: 24px;
    padding-top: 48px;
    border-top: 1px solid var(--rule);
  }

  /* Sub-headings (numbered) — light pink highlight */
  .sub-heading {
    display: flex; align-items: center; gap: 12px;
    background: rgba(193,125,157,0.1);
    border-left: 3px solid var(--rose);
    padding: 8px 16px;
    border-radius: 0 4px 4px 0;
    margin-top: 24px; margin-bottom: 10px;
  }
  .sub-num {
    font-family: var(--serif);
    font-size: 22px; font-weight: 300; font-style: italic;
    color: var(--rose); line-height: 1; flex-shrink: 0;
  }
  .sub-heading-text {
    font-family: var(--serif);
    font-size: clamp(16px, 1.7vw, 19px);
    font-weight: 600; font-style: italic;
    color: var(--ink); line-height: 1.2;
  }

  /* Body lists */
  .ul-wrap { margin: 12px 0; }
  .ul-intro {
    font-family: var(--serif);
    font-size: clamp(18px, 2vw, 21px);
    font-weight: 300; line-height: 1.82;
    color: var(--ink); margin-bottom: 6px;
  }
  .body-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 4px;
  }
  .body-list li {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 20px);
    font-weight: 300; line-height: 1.65;
    color: var(--ink);
    padding-left: 22px; position: relative;
  }
  .body-list li::before {
    content: '—';
    position: absolute; left: 0;
    color: var(--rose);
  }

  /* Inline highlight */
  .body-text strong.hl { font-weight: 600; color: var(--rose); font-style: normal; }
  .body-list li strong.hl { font-weight: 600; color: var(--rose); }

  /* Tighter paragraph spacing inside compact sections */
  .body-text.compact p + p { margin-top: 10px; }
  .body-text.compact .sub-heading + p { margin-top: 8px; }

  /* Pull quote */
  .pull-quote {
    margin: 52px 0;
    padding: 0 0 0 28px;
    border-left: 2px solid var(--rose);
  }
  .pull-quote p {
    font-family: var(--serif);
    font-size: clamp(20px, 2.6vw, 26px);
    font-weight: 300; font-style: italic;
    line-height: 1.55; color: var(--stone); margin: 0;
  }

  /* Route map */
  .route-map-wrap {
    margin: 36px calc(-1 * clamp(20px, 4vw, 48px)) 40px;
  }
  .route-map-wrap img {
    width: 100%; height: auto;
    display: block;
    border-radius: 4px;
  }
  .route-map-note {
    font-family: var(--sans); font-size: 12px; font-weight: 300;
    color: var(--stone); font-style: italic;
    margin: 8px 0 0; padding: 0 2px;
    letter-spacing: 0.02em;
  }

  /* Inline image */
  .inline-img-wrap {
    margin: 52px calc(-1 * clamp(20px, 6vw, 40px));
    position: relative;
  }
  .inline-img-wrap img {
    width: 100%; aspect-ratio: 16/9;
    object-fit: cover; object-position: center 30%;
    display: block;
  }
  .inline-img-caption {
    font-size: 11px; font-weight: 300;
    color: var(--stone); letter-spacing: 0.06em;
    padding: 10px clamp(20px, 6vw, 40px) 0;
    font-style: italic;
    font-family: var(--sans);
  }

  /* Day list */
  .day-list { margin-top: 28px; display: flex; flex-direction: column; }
  .day-item {
    display: grid; grid-template-columns: 48px 1fr;
    gap: 20px; padding: 20px 0;
    border-bottom: 1px solid var(--rule);
  }
  .day-item:first-child { border-top: 1px solid var(--rule); }
  .day-num {
    font-family: var(--serif);
    font-size: 32px; font-weight: 300; font-style: italic;
    color: var(--rule); line-height: 1.1;
  }
  .day-title {
    font-family: var(--serif);
    font-size: 18px; font-weight: 400; font-style: italic;
    color: var(--ink); margin-bottom: 5px;
  }
  .day-detail {
    font-family: var(--sans);
    font-size: 12px; font-weight: 300;
    color: var(--stone); line-height: 1.6;
  }

  /* Tip box */
  .tip-box {
    background: rgba(193,125,157,0.06);
    border: 1px solid rgba(193,125,157,0.22);
    border-radius: 10px;
    padding: 24px 28px; margin-top: 48px;
  }
  .tip-label {
    font-family: var(--sans);
    font-size: 9px; font-weight: 400;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--rose); margin-bottom: 14px;
  }
  .tip-box p {
    font-family: var(--sans);
    font-size: 13.5px; font-weight: 300;
    color: var(--stone); line-height: 1.75; margin: 0;
  }
  .tip-box p + p { margin-top: 10px; }
  .tip-bold { font-weight: 400; color: var(--ink); }

  /* Photo carousel */
  .gallery-section { margin-top: 64px; }

  .carousel {
    position: relative;
    margin: 32px calc(-1 * clamp(20px, 4vw, 48px)) 0;
    background: #111;
    user-select: none;
  }
  .carousel-track {
    position: relative;
    aspect-ratio: 4/3;
    background: #111;
    overflow: hidden;
  }

  .carousel-slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 0.35s ease;
    pointer-events: none;
    display: flex; align-items: center; justify-content: center;
  }
  .carousel-slide.active { opacity: 1; pointer-events: auto; }
  .carousel-slide img {
    max-width: 100%; max-height: 100%;
    width: auto; height: auto;
    object-fit: contain; display: block;
  }

  .carousel-btn {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(0,0,0,0.28); backdrop-filter: blur(4px);
    border: none; color: #fff;
    font-size: 36px; line-height: 1;
    width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; border-radius: 50%;
    transition: background 0.2s;
    z-index: 2;
  }
  .carousel-btn:hover { background: rgba(193,125,157,0.7); }
  .carousel-prev { left: 16px; }
  .carousel-next { right: 16px; }

  .carousel-counter {
    position: absolute; bottom: 14px; right: 18px;
    font-family: var(--sans); font-size: 11px; font-weight: 300;
    letter-spacing: 0.08em; color: rgba(255,255,255,0.85);
    background: rgba(0,0,0,0.35); padding: 3px 8px; border-radius: 2px;
    z-index: 2;
  }

  /* Back link */
  .back-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--sans);
    font-size: 11px; font-weight: 300;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--stone); text-decoration: none;
    margin-top: 80px; margin-bottom: 80px;
