      slug: 'oeschinensee',
      title: 'Oeschinensee Panorama Trail, The Jewel of the Bernese Oberland',
      titleHtml: 'Oeschinensee<br/>Panorama Trail',
      eyebrow: 'Hiking Guide · Bern · Switzerland',
