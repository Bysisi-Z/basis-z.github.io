---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  { num: '01', title: 'Journey',          desc: 'Professional path & the person behind it',             href: '/career' },
  { num: '02', title: 'Decoding',         desc: 'Industry research, data analysis & market insights',   href: '/research' },
  { num: '03', title: 'Mountain Calling', desc: 'Landscape photography, hiking guides & alpine walks',   href: '/photography' },
  { num: '04', title: 'Wandering',        desc: 'Personal growth, reflections & inner landscapes',       href: '/writing' },
  { num: '05', title: 'Reading List',     desc: 'Books, papers & ideas worth revisiting',               href: '#', coming: true },
  { num: '06', title: 'More to Come',     desc: 'New chapters in the making',                           href: '#', coming: true },
];
---

<BaseLayout title="Home" description="Sisi — Making sense of numbers and landscapes." hideNav={true}>

  <div class="layout">

    <!-- ① Top bar: tagline + section counter -->
    <div class="bar-top">
      <div class="tagline-block">
        <p class="tagline">Making sense of numbers and landscapes.</p>
        <div class="tagline-rule"></div>
      </div>
      <span class="section-count">06 sections</span>
    </div>

    <!-- ② Left bar -->
    <div class="bar-left"></div>

    <!-- ③ Intersection multiply-blend overlay -->
    <div class="bar-cross"></div>

    <!-- Decorative arc lines — partial concentric arcs from corner (-40,-40) -->
    <svg class="bar-arcs" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M 73  0 A 120 120 0 0 1 0 73"  fill="none" stroke="white" stroke-width="1" opacity="0.12"/>
      <path d="M 136 0 A 180 180 0 0 1 0 136" fill="none" stroke="white" stroke-width="1" opacity="0.10"/>
      <path d="M 197 0 A 240 240 0 0 1 0 197" fill="none" stroke="white" stroke-width="1" opacity="0.09"/>
      <path d="M 257 0 A 300 300 0 0 1 0 257" fill="none" stroke="white" stroke-width="1" opacity="0.08"/>
    </svg>

    <!-- ④ Si centred in the intersection + short divider below -->
    <h1 class="si-heading" aria-label="Si">Si</h1>
    <div class="si-divider"></div>

    <!-- ⑤ Content: 3×2 card grid -->
    <div class="col-right">
      <nav class="modules">
        {modules.map(m => (
          <a class={`tag${m.coming ? ' tag--coming' : ''}`} href={m.href}>
            <div class="tag-header">
              <span class="tag-num">{m.num}</span>
              <div class="tag-num-line"></div>
            </div>
            <span class="tag-name">{m.title}</span>
            <span class="tag-desc">{m.desc}</span>
          </a>
        ))}
      </nav>
    </div>

    <!-- ⑥ Contact strip — full-width, bottom of page -->
    <div class="contact-bar">
      <span class="contact-label">Contact</span>
      <span class="contact-placeholder">— Your details here</span>
    </div>

  </div>

</BaseLayout>

