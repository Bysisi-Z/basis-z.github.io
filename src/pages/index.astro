---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  { num: '01', title: 'Now',                          desc: "What I'm doing and thinking about lately",           href: '/now' },
  { num: '02', title: 'Journey',                      desc: 'Professional path & the person behind it',           href: '/career' },
  { num: '03', title: 'Decoding',                     desc: 'Industry research, data analysis & market insights',  href: '/research' },
  { num: '04', title: 'Nature Never Judges',          desc: 'Landscape photography, hiking guides & alpine walks', href: '/photography' },
  { num: '05', title: 'Wandering',                    desc: 'Personal growth, reflections & inner landscapes',     href: '/writing' },
  { num: '06', title: 'A Collection of Rabbit Holes', desc: 'Books, papers & ideas worth revisiting',             href: '/reading' },
];
---

<BaseLayout title="Home" description="Sisi — Making sense of numbers and landscapes." hideNav={true}>

  <div class="layout">

    <!-- Full-bleed background (shows through glass blur) -->
    <div class="photo-bg" aria-hidden="true">
      <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
    </div>

    <!-- Left: original photo at full natural proportions (no crop) -->
    <div class="photo-strip" aria-hidden="true">
      <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
    </div>

    <!-- Right: frosted glass panel with all content -->
    <div class="glass-strip">

      <div class="si-logo">Si</div>

      <div class="tagline-wrap">
        <h1 class="tagline">Making <em class="sense">sense</em> of<br>numbers and<br>landscapes.</h1>
        <div class="tagline-rule"></div>
      </div>

      <nav class="module-list">
        {modules.map(m => (
          <a class="mod-item" href={m.href}>
            <span class="mod-bullet">◆</span>
            <span class="mod-num">{m.num}</span>
            <span class="mod-body">
              <span class="mod-title">{m.title}</span>
              <span class="mod-desc">{m.desc}</span>
            </span>
          </a>
        ))}
      </nav>

      <div class="contact">
        <a href="https://www.linkedin.com/in/sisi-z-9a4a6075/" target="_blank" rel="noopener" class="contact-link">LinkedIn</a>
        <span class="sep">·</span>
        <a href="https://www.xiaohongshu.com/user/profile/111799574" target="_blank" rel="noopener" class="contact-link">Red Note</a>
        <span class="sep">·</span>
        <a href="mailto:sisi.zhang.ch@gmail.com" class="contact-link">Email</a>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Nunito:wght@300;400&display=swap');

  .layout {
    position: fixed;
    inset: 0;
    overflow: hidden;
    display: flex;
  }

  /* ── Full-bleed background (blurred by glass strip) ── */
  .photo-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .photo-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: 60% 18%;
    display: block;
  }

  /* ── Left photo strip: full portrait, no crop ── */
  .photo-strip {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    width: calc(100vh * 4284 / 5712); /* exact 3:4 ratio */
    height: 100vh;
    overflow: hidden;
  }
  .photo-strip img {
    display: block;
    width: 100%; height: 100%;
    object-fit: fill;
  }

  /* ── Frosted glass content panel ── */
  .glass-strip {
    position: relative;
    z-index: 2;
    flex: 1;
    height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 56px 64px 48px clamp(48px, 6vw, 100px);
    background: rgba(15, 10, 30, 0.25);
    backdrop-filter: blur(32px) brightness(0.55) saturate(1.2);
    -webkit-backdrop-filter: blur(32px) brightness(0.55) saturate(1.2);
  }

  /* Si logo */
  .si-logo {
    font-family: 'Great Vibes', cursive;
    font-size: 92px;
    line-height: 1;
    color: #C4A8E0;
    font-style: italic;
    margin-bottom: 44px;
    flex-shrink: 0;
    text-shadow:
      0 0 20px rgba(196, 168, 224, 0.8),
      0 0 60px rgba(196, 168, 224, 0.3);
  }

  /* Tagline */
  .tagline-wrap { flex-shrink: 0; }

  .tagline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(44px, 4.4vw, 72px);
    font-weight: 300;
    color: #fff;
    line-height: 1.14;
    margin: 0 0 26px;
  }

  .sense {
    font-style: italic;
    color: #C4A8E0;
    font-weight: 300;
    display: inline-block;
    transform: skewX(-8deg);
  }

  .tagline-rule {
    width: 46%;
    height: 1px;
    background: linear-gradient(to right,
      rgba(255,255,255,0.75),
      rgba(196,168,224,0.35),
      transparent
    );
  }

  /* ── Module list ── */
  .module-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding-top: 32px;
    position: relative;
  }

  .module-list::before {
    content: '';
    position: absolute;
    left: 12px; top: 86px; bottom: 62px;
    width: 1px;
    background: rgba(196, 150, 210, 0.2);
    pointer-events: none;
  }

  .mod-item {
    display: grid;
    grid-template-columns: 24px 30px 1fr;
    align-items: center;
    gap: 0 10px;
    padding: 18px 0;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .mod-bullet {
    font-size: 8px;
    color: #C4A8E0;
    text-align: center;
    line-height: 1;
    transition: color 0.2s, text-shadow 0.2s;
    text-shadow:
      0 0 6px rgba(196,168,224,0.9),
      0 0 18px rgba(196,168,224,0.5);
  }

  .mod-num {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.25);
  }

  .mod-body { display: flex; flex-direction: column; gap: 2px; }

  .mod-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(22px, 2.2vw, 32px);
    font-weight: 400;
    font-style: italic;
    color: rgba(255,255,255,0.85);
    line-height: 1.2;
    transition: color 0.2s;
  }

  .mod-desc {
    font-family: 'Nunito', Arial, sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: rgba(255,255,255,0.48);
    line-height: 1.4;
  }

  /* Hover: text brightens */
  .mod-item:hover .mod-title { color: #fff; }
  .mod-item:hover .mod-bullet {
    color: #fff;
    animation: bullet-twinkle 1.8s ease-in-out infinite;
  }

  @keyframes bullet-twinkle {
    0%, 100% {
      transform: scale(1.8);
      text-shadow: 0 0 4px #fff, 0 0 12px #fff,
                   0 0 24px rgba(196,168,224,1), 0 0 50px rgba(196,168,224,.8);
    }
    50% {
      transform: scale(1.1);
      text-shadow: 0 0 2px rgba(255,255,255,.3), 0 0 8px rgba(196,168,224,.4);
    }
  }

  /* Hover meteor sweep */
  .mod-item::after {
    content: '';
    position: absolute;
    bottom: 0; left: 64px;
    height: 1px; width: 0; opacity: 0;
    background: linear-gradient(to right,
      rgba(255,255,255,0.95),
      rgba(235,215,255,0.85) 45%,
      rgba(196,168,224,0.40) 75%,
      transparent
    );
    pointer-events: none;
  }

  .mod-item:hover::after {
    animation: item-meteor 2.8s ease-out infinite;
  }

  @keyframes item-meteor {
    0%   { width: 0;                  opacity: 1; }
    55%  { width: calc(100% - 64px);  opacity: 1; }
    80%  { width: calc(100% - 64px);  opacity: 0; }
    100% { width: 0;                  opacity: 0; }
  }

  /* ── Contact ── */
  .contact {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 22px;
    border-top: 1px solid rgba(196,168,224,0.13);
    flex-shrink: 0;
  }

  .contact-link {
    font-family: 'Nunito', Arial, sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(196,168,224,0.62);
    text-decoration: none;
    transition: color 0.25s;
  }
  .contact-link:hover { color: #fff; }

  .sep { color: rgba(196,168,224,0.2); font-size: 9px; }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .layout { flex-direction: column; overflow-y: auto; }
    .photo-strip {
      width: 100%; height: 50vw;
      flex-shrink: 0;
    }
    .photo-strip img { object-fit: cover; object-position: center 15%; }
    .glass-strip {
      flex: 1;
      padding: 24px 24px 32px;
      backdrop-filter: blur(24px) brightness(0.6);
      -webkit-backdrop-filter: blur(24px) brightness(0.6);
    }
    .si-logo  { font-size: 64px; margin-bottom: 24px; }
    .tagline  { font-size: clamp(28px, 7vw, 44px); }
    .mod-item { padding: 12px 0; }
    .mod-title { font-size: 18px; }
    .mod-desc { display: none; }
    .contact  { margin-top: 8px; }
  }
</style>
