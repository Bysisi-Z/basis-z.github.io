---
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const modules = [
  { num: '01', title: 'Now',                          desc: "What I'm doing and thinking about lately",           href: '/now' },
  { num: '02', title: 'Journey',                      desc: 'Professional path & the person behind it',           href: '/career' },
  { num: '03', title: 'Decoding',                     desc: 'Industry research, data analysis & market insights',  href: '/research' },
  { num: '04', title: 'Nature Never Judges',          desc: 'Landscape photography, hiking guides & alpine walks', href: '/photography' },
  { num: '05', title: 'Wandering',                    desc: 'Personal growth, reflections & inner landscapes',     href: '/writing' },
  { num: '06', title: 'A Collection of Rabbit Holes', desc: 'Books, papers & ideas worth revisiting',             href: '/reading' },
];
---

<BaseLayout title="Home" description="Sisi — Making sense of numbers and landscapes." hideNav={true}>

  <div class="layout">

    <!-- Full-bleed background (shows through glass blur) -->
    <div class="photo-bg" aria-hidden="true">
      <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
    </div>

    <!-- Left: original photo at full natural proportions (no crop) -->
    <div class="photo-strip" aria-hidden="true">
      <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
    </div>

    <!-- Right: frosted glass panel with all content -->
    <div class="glass-strip">

      <div class="si-logo">Si</div>

      <div class="tagline-wrap">
        <h1 class="tagline">Making <em class="sense">sense</em> of<br>numbers and<br>landscapes.</h1>
        <div class="tagline-rule"></div>
      </div>

      <nav class="module-list">
        {modules.map(m => (
          <a class="mod-item" href={m.href}>
            <span class="mod-bullet">◆</span>
            <span class="mod-num">{m.num}</span>
            <span class="mod-body">
              <span class="mod-title">{m.title}</span>
              <span class="mod-desc">{m.desc}</span>
            </span>
          </a>
        ))}
      </nav>

      <div class="contact">
        <a href="https://www.linkedin.com/in/sisi-z-9a4a6075/" target="_blank" rel="noopener" class="contact-link">LinkedIn</a>
        <span class="sep">·</span>
        <a href="https://www.xiaohongshu.com/user/profile/111799574" target="_blank" rel="noopener" class="contact-link">Red Note</a>
        <span class="sep">·</span>
        <a href="mailto:sisi.zhang.ch@gmail.com" class="contact-link">Email</a>
      </div>
      <p class="glass-copyright">© {year} · All photographs on this site are the exclusive property of the author. Unauthorized reproduction, redistribution, or commercial use is strictly prohibited.</p>

    </div>

    <!-- Far right: pure black strip -->
    <div class="black-strip" aria-hidden="true">

      <!-- Carrier: top-left -->
      <div class="carrier">
        <svg class="carrier-signal" viewBox="0 0 20 14" fill="none">
          <rect x="0" y="9" width="3" height="5" rx="0.8" fill="currentColor"/>
          <rect x="4.5" y="6" width="3" height="8" rx="0.8" fill="currentColor"/>
          <rect x="9" y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
          <rect x="13.5" y="0" width="3" height="14" rx="0.8" fill="currentColor" opacity="0.3"/>
        </svg>
        <span class="carrier-name">Swisscom</span>
      </div>

      <!-- Status icons: top-right -->
      <div class="status-bar">
        <!-- WiFi full signal -->
        <svg class="status-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 18.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z" fill="currentColor"/>
          <path d="M12 14c1.6 0 3 .65 4.05 1.7l1.42-1.42A8.1 8.1 0 0 0 12 12a8.1 8.1 0 0 0-5.47 2.28l1.42 1.42A6.08 6.08 0 0 1 12 14z" fill="currentColor"/>
          <path d="M12 9.5c2.76 0 5.26 1.12 7.07 2.93l1.42-1.42A12.14 12.14 0 0 0 12 7.5c-3.35 0-6.39 1.36-8.49 3.51l1.42 1.42A10.12 10.12 0 0 1 12 9.5z" fill="currentColor"/>
          <path d="M12 5c3.93 0 7.48 1.59 10.05 4.16l1.42-1.42A16.18 16.18 0 0 0 12 3C7.37 3 3.17 4.93.53 8.02l1.42 1.42A14.15 14.15 0 0 1 12 5z" fill="currentColor"/>
        </svg>

        <!-- Battery full -->
        <svg class="status-icon battery-icon" viewBox="0 0 28 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="0.5" y="0.5" width="23" height="13" rx="3.5" stroke="currentColor" stroke-opacity="0.6"/>
          <rect x="2" y="2" width="20" height="10" rx="2" fill="currentColor"/>
          <path d="M25 4.5v5a2.5 2.5 0 0 0 0-5z" fill="currentColor" fill-opacity="0.6"/>
        </svg>
      </div>

      <div class="greeting-wrap">
        <span class="greeting-text" id="greeting"></span>
      </div>


      <!-- Cats -->
      <div class="cats-container">
        <div class="cat-item cat-big">
          <img src="/images/cat-first.jpg" alt="嘞嘞" class="cat-photo" />
          <div class="cat-eyes">
            <span class="eye"></span>
            <span class="eye"></span>
          </div>
        </div>
        <div class="cat-item cat-small">
          <img src="/images/cat-second.jpg" alt="小咪渣" class="cat-photo" />
          <div class="cat-eyes">
            <span class="eye"></span>
            <span class="eye"></span>
          </div>
        </div>
      </div>

      <!-- Lamp text -->
      <div class="lamp-text" id="lampText" aria-hidden="true"></div>

      <!-- Floor lamp -->
      <div class="floor-lamp" id="floorLamp">
        <svg viewBox="0 0 80 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">
          <defs>
            <linearGradient id="beamGrad" x1="0.5" y1="0" x2="0.5" y2="1">
              <stop offset="0%" stop-color="rgba(255,220,80,0.08)"/>
              <stop offset="40%" stop-color="rgba(255,210,70,0.05)"/>
              <stop offset="100%" stop-color="rgba(255,200,60,0)"/>
            </linearGradient>
            <linearGradient id="ambientGrad" x1="0.5" y1="0" x2="0.5" y2="1">
              <stop offset="0%" stop-color="rgba(255,215,70,0.14)"/>
              <stop offset="50%" stop-color="rgba(255,210,70,0.06)"/>
              <stop offset="100%" stop-color="rgba(255,200,60,0)"/>
            </linearGradient>
            <filter id="beamBlur" x="-200%" y="-5%" width="500%" height="110%">
              <feGaussianBlur stdDeviation="30 4"/>
            </filter>
            <filter id="ambientBlur" x="-500%" y="-15%" width="1100%" height="130%">
              <feGaussianBlur stdDeviation="80 18"/>
            </filter>
          </defs>
          <!-- Ambient halo — extremely wide, very soft -->
          <path class="beam-path" d="M40 40 L-1200 520 L1280 520 Z" fill="url(#ambientGrad)" filter="url(#ambientBlur)"/>
          <!-- Main beam cone -->
          <path class="beam-path" d="M40 55 L-400 500 L480 500 Z" fill="url(#beamGrad)" filter="url(#beamBlur)"/>
          <!-- Lamp glow behind shade -->
          <ellipse cx="40" cy="44" rx="24" ry="13" fill="url(#lampGlow)" opacity="0.28"/>
          <!-- Shade body — wide trapezoid, 3x wider at bottom than top -->
          <path d="M20 48 L33 22 L47 22 L60 48 Z"
                fill="rgba(212,203,232,0.16)" stroke="rgba(212,203,232,0.44)" stroke-width="1" stroke-linejoin="round"/>
          <!-- Right-side inner shadow for depth -->
          <path d="M47 22 L60 48 L54 48 L44 23 Z" fill="rgba(150,130,185,0.10)"/>
          <!-- Bottom flare lip — clearly wider than shade body -->
          <path d="M16 49 Q18 53 40 54 Q62 53 64 49 L60 48 Q58 52 40 53 Q22 52 20 48 Z"
                fill="rgba(212,203,232,0.18)" stroke="rgba(212,203,232,0.40)" stroke-width="0.8"/>
          <!-- Top finial ring -->
          <ellipse cx="40" cy="22" rx="6" ry="1.8" fill="rgba(10,5,20,0.9)" stroke="rgba(212,203,232,0.32)" stroke-width="0.8"/>
          <!-- Inner warm glow -->
          <ellipse cx="40" cy="37" rx="8" ry="6" fill="rgba(255,235,160,0.12)"/>

          <!-- Pole — top thin, bottom slightly wider -->
          <path d="M39.6 51 L38.5 188 L41.5 188 L40.4 51 Z" fill="rgba(212,203,232,0.38)"/>
          <!-- Base: solid flat cylinder -->
          <!-- Top face -->
          <ellipse cx="40" cy="190" rx="20" ry="4" fill="rgba(212,203,232,0.22)" stroke="rgba(212,203,232,0.38)" stroke-width="0.8"/>
          <!-- Side body -->
          <rect x="20" y="190" width="40" height="4" fill="rgba(212,203,232,0.12)"/>
          <!-- Bottom face (rim) -->
          <ellipse cx="40" cy="194" rx="20" ry="4" fill="rgba(212,203,232,0.18)" stroke="rgba(212,203,232,0.32)" stroke-width="0.8"/>
          <!-- Floor reflection -->
          <ellipse cx="40" cy="199" rx="22" ry="2" fill="rgba(212,203,232,0.06)"/>
          <defs>
            <radialGradient id="lampGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="rgba(235,225,255,1)"/>
              <stop offset="100%" stop-color="rgba(235,225,255,0)"/>
            </radialGradient>
          </defs>
        </svg>
      </div>

      <div class="clock-wrap">
        <div class="date-line" id="dateline"></div>
        <div class="weather-wrap" id="weather">
          <span class="weather-icon" id="weather-icon"></span>
          <span class="weather-temp" id="weather-temp"></span>
          <span class="weather-desc" id="weather-desc"></span>
        </div>
        <div class="clock" id="clock">00:00</div>
      </div>
    </div>

  </div>

<script is:inline>
  const greetings = [
    'Good evening', // English
    '晚上好',        // Chinese
    'Guten Abend',  // German
    'Bonsoir',      // French
    'Buona sera',   // Italian
    'Buenas noches',// Spanish
    'こんばんは',    // Japanese
    '좋은 저녁',     // Korean
    'Goedenavond',  // Dutch
    'Boa noite',    // Portuguese
    'God kväll',    // Swedish
    'Добрый вечер', // Russian
    'Καλησπέρα',    // Greek
    'İyi akşamlar', // Turkish
    'مساء الخير',   // Arabic
    'शुभ संध्या',    // Hindi
  ];

  const el = document.getElementById('greeting');
  let i = 0;

  // Clock + date
  const clockEl   = document.getElementById('clock');
  const datelineEl = document.getElementById('dateline');
  const DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    clockEl.textContent = h + ':' + m;
    datelineEl.textContent = DAYS[now.getDay()] + ' ' + MONTHS[now.getMonth()] + ' ' + now.getDate();
  }
  updateClock();
  setInterval(updateClock, 1000);

  // Weather
  const WMO = {
    0:  ['☀',  'Clear'],
    1:  ['🌤', 'Mostly clear'],
    2:  ['⛅', 'Partly cloudy'],
    3:  ['☁',  'Overcast'],
    45: ['🌫', 'Fog'],
    48: ['🌫', 'Fog'],
    51: ['🌦', 'Drizzle'],
    53: ['🌦', 'Drizzle'],
    55: ['🌦', 'Drizzle'],
    61: ['🌧', 'Rain'],
    63: ['🌧', 'Rain'],
    65: ['🌧', 'Heavy rain'],
    71: ['🌨', 'Snow'],
    73: ['🌨', 'Snow'],
    75: ['❄',  'Heavy snow'],
    80: ['🌦', 'Showers'],
    81: ['🌧', 'Showers'],
    82: ['🌧', 'Heavy showers'],
    95: ['⛈',  'Thunderstorm'],
    96: ['⛈',  'Thunderstorm'],
    99: ['⛈',  'Thunderstorm'],
  };

  async function fetchWeather(lat, lon) {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weathercode&temperature_unit=celsius&timezone=auto`;
    const res  = await fetch(url);
    const data = await res.json();
    const temp = Math.round(data.current.temperature_2m);
    const code = data.current.weathercode;
    const [icon, desc] = WMO[code] ?? ['🌡', 'Unknown'];
    document.getElementById('weather-icon').textContent = icon;
    document.getElementById('weather-temp').textContent = temp + '°C';
    document.getElementById('weather-desc').textContent = desc;
  }

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => fetchWeather(pos.coords.latitude, pos.coords.longitude),
      ()  => fetchWeather(47.05, 8.31) // fallback: Lucerne
    );
  } else {
    fetchWeather(47.05, 8.31);
  }

  // Lamp easter egg
  const lampEl   = document.getElementById('floorLamp');
  const stripEl  = lampEl.closest('.black-strip');
  const lampText = document.getElementById('lampText');

  // Build letter spans
  'Make yourself at home!'.split('').forEach((ch, i) => {
    const s = document.createElement('span');
    s.textContent = ch === ' ' ? ' ' : ch;
    s.dataset.delay = i * 70;
    lampText.appendChild(s);
  });

  lampEl.addEventListener('click', () => {
    const on = stripEl.classList.toggle('lamp-on');
    lampText.querySelectorAll('span').forEach(s => {
      s.classList.remove('letter-in');
      void s.offsetWidth;
    });
    if (on) {
      lampText.querySelectorAll('span').forEach(s => {
        setTimeout(() => s.classList.add('letter-in'), Number(s.dataset.delay));
      });
    }
  });

  const isChinese = s => /[一-鿿]/.test(s);

  function setGreeting(text) {
    el.textContent = text;
    el.classList.toggle('zh', isChinese(text));
  }

  function showNext() {
    el.classList.remove('visible');
    setTimeout(() => {
      setGreeting(greetings[i % greetings.length]);
      i++;
      void el.offsetWidth;
      el.classList.add('visible');
      setTimeout(showNext, 2800 + 1400);
    }, 1600);
  }

  setTimeout(() => {
    setGreeting(greetings[i % greetings.length]);
    i++;
    void el.offsetWidth;
    el.classList.add('visible');
    setTimeout(showNext, 2800 + 1400);
  }, 600);
</script>

</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Ma+Shan+Zheng&family=Barlow+Condensed:wght@700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&family=Nunito:wght@300;400&display=swap');

  .layout {
    position: fixed;
    inset: 0;
    overflow: hidden;
    display: flex;
  }

  /* ── Full-bleed background (blurred by glass strip) ── */
  .photo-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .photo-bg img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: 60% 18%;
    display: block;
  }

  /* ── Left photo strip: 1/3 ── */
  .photo-strip {
    position: relative;
    z-index: 2;
    flex: 1.4 1 0;
    height: 100vh;
    overflow: hidden;
  }
  .photo-strip img {
    display: block;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 18%;
  }

  /* ── Right black strip ── */
  .black-strip {
    position: relative;
    z-index: 2;
    flex: 0.95 1 0;
    height: 100vh;
    background: #000;
    container-type: inline-size;
    overflow: hidden;
  }


  /* ── Lamp text ── */
  .lamp-text {
    position: absolute;
    bottom: clamp(72px, 10vh, 150px);
    left: 0;
    right: 0;
    padding-right: 18cqw;
    text-align: center;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(14px, 5.5cqw, 24px);
    font-style: italic;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(8, 4, 0, 0.85);
    pointer-events: none;
    white-space: nowrap;
    z-index: 4;
  }

  .lamp-text span {
    display: inline-block;
    opacity: 0;
  }

  .lamp-text span.letter-in {
    animation: lamp-letter-in 0.55s ease forwards;
  }

  @keyframes lamp-letter-in {
    from { opacity: 0; transform: translateY(5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Cats ── */
  .cats-container {
    position: absolute;
    bottom: 0;
    left: clamp(4px, 2cqw, 18px);
    display: flex;
    align-items: flex-end;
    gap: clamp(4px, 1.5cqw, 12px);
    z-index: 4;
  }

  .cat-item {
    position: relative;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .cat-big {
    width: clamp(38px, 16cqw, 80px);
    height: clamp(38px, 16cqw, 80px);
  }

  .cat-small {
    width: clamp(26px, 11cqw, 58px);
    height: clamp(26px, 11cqw, 58px);
  }

  .cat-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    opacity: 0;
    transition: opacity 0.9s ease 0.3s;
  }

  .lamp-on .cat-photo {
    opacity: 1;
  }

  .cat-eyes {
    position: absolute;
    inset: 0;
    transition: opacity 0.4s ease;
  }

  .lamp-on .cat-eyes {
    opacity: 0;
  }

  .eye {
    position: absolute;
    top: 36%;
    width: clamp(3px, 0.9cqw, 6px);
    height: clamp(3px, 0.9cqw, 6px);
    border-radius: 50%;
    background: #FFD700;
    box-shadow:
      0 0 4px #FFD700,
      0 0 10px rgba(255, 210, 0, 0.9),
      0 0 22px rgba(255, 190, 0, 0.4);
    transform: translate(-50%, -50%);
  }

  .eye:first-child { left: 34%; }
  .eye:last-child  { left: 66%; }

  /* ── Light beam ── */
  .beam-path {
    opacity: 0;
    transition: opacity 0.7s ease;
  }

  .lamp-on .beam-path {
    opacity: 1;
  }

  /* ── Floor lamp ── */
  /* 15vh keeps lamp at ~37% screen height regardless of viewport width */
  .floor-lamp {
    position: absolute;
    bottom: 0;
    right: clamp(8px, 1.5cqw, 16px);
    width: clamp(100px, 15vh, 220px);
    opacity: 0.9;
    pointer-events: all;
    cursor: pointer;
    z-index: 3;
  }

  .lamp-on .floor-lamp {
    opacity: 1;
    filter: drop-shadow(0 0 12px rgba(255, 220, 80, 0.55)) drop-shadow(0 0 32px rgba(255, 200, 60, 0.25));
  }

  .floor-lamp svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .carrier {
    position: absolute;
    top: 20px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: 5px;
    color: rgba(212, 203, 232, 0.45);
  }

  .carrier-signal {
    width: 17px;
    height: 12px;
    display: block;
  }

  .carrier-name {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .status-bar {
    position: absolute;
    top: 18px;
    right: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(212, 203, 232, 0.45);
  }

  .status-icon {
    width: 18px;
    height: 18px;
    display: block;
  }

  .battery-icon {
    width: 26px;
    height: 13px;
  }

  .greeting-wrap {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 22%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Apple-style clock ── */
  .clock-wrap {
    position: absolute;
    top: 22%;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding-top: 8px;
    z-index: 2;
  }

  .date-line {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(11px, 3.5cqw, 16px);
    font-weight: 700;
    letter-spacing: 0.03em;
    color: rgba(235, 228, 255, 0.90);
    background: rgba(180, 160, 220, 0.22);
    padding: 5px 16px 6px;
    border-radius: 20px;
  }

  .clock {
    font-family: 'Barlow Condensed', 'Inter', system-ui, sans-serif;
    font-size: clamp(56px, 32cqw, 150px);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 0.95;
    font-variant-numeric: tabular-nums;
    background: linear-gradient(
      175deg,
      rgba(235, 228, 255, 0.72) 0%,
      rgba(196, 180, 235, 0.50) 40%,
      rgba(155, 135, 200, 0.28) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    -webkit-box-reflect: below 1px linear-gradient(transparent 30%, rgba(180, 160, 220, 0.32) 100%);
  }

  .weather-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 0;
    margin-bottom: 0;
    color: rgba(212, 203, 232, 0.52);
  }

  .weather-icon {
    font-size: clamp(16px, 7cqw, 28px);
    line-height: 1;
  }

  .weather-temp {
    font-family: 'Barlow Condensed', 'Inter', system-ui, sans-serif;
    font-size: clamp(18px, 9cqw, 34px);
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .weather-desc {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(11px, 4cqw, 17px);
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .greeting-text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(20px, 12cqw, 56px);
    font-weight: 300;
    font-style: italic;
    color: rgba(212, 203, 232, 0.82);
    letter-spacing: 0.02em;
    text-align: center;
    opacity: 0;
    transition: opacity 1.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .greeting-text.visible {
    opacity: 1;
  }

  .greeting-text.zh {
    font-family: 'Ma Shan Zheng', cursive;
  }

  /* ── Frosted glass content panel ── */
  .glass-strip {
    position: relative;
