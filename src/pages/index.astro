<style>
  /* ── 1-screen desktop ── */
  html { height: 100%; overflow: hidden; }
  body { height: 100vh; overflow: hidden; margin: 0; }
  main { height: 100vh; display: block; }

  /* ════════════════════════════════════
     ROOT
  ════════════════════════════════════ */
  .layout {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #FAFAF8;
    overflow: hidden;
    isolation: isolate;
  }

  /* ════════════════════════════════════
     TOP BAR — tagline + section count
  ════════════════════════════════════ */
  .bar-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 120px;
    background: #D3BABD;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 52px 0 152px; /* left: clear 120 px bar + 32 px gap */
  }

  .tagline-block {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .tagline {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.92);
    margin: 0;
  }

  .tagline-rule {
    height: 1px;
    width: 100%;
    background: rgba(255,255,255,0.38);
  }

  .section-count {
    font-family: var(--sans);
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.48);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 24px;
  }

  /* ════════════════════════════════════
     LEFT BAR
  ════════════════════════════════════ */
  .bar-left {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 120px;
    background: #D3BABD;
    z-index: 1;
  }

  /* ════════════════════════════════════
     INTERSECTION multiply-blend
  ════════════════════════════════════ */
  .bar-cross {
    position: absolute;
    top: 0; left: 0;
    width: 120px;
    height: 120px;
    background: #D3BABD;
    mix-blend-mode: multiply;
    z-index: 2;
    pointer-events: none;
  }

  /* ════════════════════════════════════
     DECORATIVE ARCS
     z-index 3: above bars, below col-right
  ════════════════════════════════════ */
  .bar-arcs {
    position: absolute;
    top: 0; left: 0;
    width: 300px; height: 300px;
    overflow: visible;
    z-index: 3;
    pointer-events: none;
  }

  /* ════════════════════════════════════
     "Si" — centred in 120×120 intersection
  ════════════════════════════════════ */
  .si-heading {
    position: absolute;
    top: 60px;
    left: 60px;
    transform: translate(-50%, -50%);
    z-index: 10;
    margin: 0; padding: 0;
    font-family: var(--serif);
    font-size: 108px;
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    color: #fff;
    white-space: nowrap;
    user-select: none;
    pointer-events: none;
  }

  /* Short divider just below the intersection */
  .si-divider {
    position: absolute;
    top: 128px;
    left: 34px;
    width: 52px;
    height: 1px;
    background: rgba(255,255,255,0.38);
    z-index: 10;
  }

  /* ════════════════════════════════════
     CONTENT AREA
  ════════════════════════════════════ */
  .col-right {
    position: absolute;
    top: 120px;
    left: 120px;
    right: 0;
    bottom: 56px;
    overflow: hidden;
    background: #FAFAF8;
    z-index: 4;
    padding: 20px 44px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
  }

  /* ════════════════════════════════════
     2×3 CARD GRID — 70% of available height
  ════════════════════════════════════ */
  .modules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 12px;
    width: 100%;
    height: 72%;
    flex-shrink: 0;
  }

  /* ── Card base: visual (left) + text (right) ── */
  .tag {
    display: grid;
    grid-template-columns: 36% 64%;
    border: 1px solid rgba(211,186,189,0.6);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    min-height: 0;
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .tag:hover {
    border-color: #A87A7A;
    box-shadow: 0 6px 28px rgba(168,122,122,0.18);
  }
  .tag:active { box-shadow: 0 2px 8px rgba(168,122,122,0.14); }
  .tag--coming { opacity: 0.45; pointer-events: none; }

  /* ── Visual area (left column) ── */
  .tag-visual {
    background: linear-gradient(150deg, #E8D5D5 0%, #D3BABD 100%);
    display: flex; align-items: center; justify-content: center;
    border-right: 1px solid rgba(211,186,189,0.5);
    overflow: hidden;
    position: relative;
  }
  .tag-visual-num {
    font-family: var(--serif);
    font-size: clamp(36px, 4.5vw, 68px);
    font-weight: 300; font-style: italic;
    color: rgba(168,122,122,0.28);
    user-select: none; pointer-events: none;
    transition: color 0.25s;
  }
  .tag:hover .tag-visual-num { color: rgba(168,122,122,0.45); }

  /* ── Text area (right column) ── */
  .tag-text {
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: clamp(14px, 1.6vw, 22px);
    background: #FAFAF8;
  }
  .tag-num {
    font-family: var(--sans);
    font-size: 10px; font-weight: 300;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(168,122,122,0.55);
    margin-bottom: 8px;
  }
  .tag-name {
    font-family: var(--serif);
    font-size: clamp(20px, 2.2vw, 30px);
    font-weight: 300; font-style: italic;
    color: #3A1E1E; line-height: 1.1;
    margin: 0 0 6px;
    transition: color 0.22s;
  }
  .tag:hover .tag-name { color: #2a1010; }
  .tag-desc {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 300; color: #9A7A7A;
    line-height: 1.6; margin: 0 0 10px;
    transition: color 0.22s;
  }
  .tag:hover .tag-desc { color: #6A4A4A; }
  .tag-foot {
    border-top: 1px solid rgba(211,186,189,0.5);
    padding-top: 8px;
  }
  .tag-arrow {
    font-size: 14px;
    color: rgba(168,122,122,0.45);
    display: inline-block;
    transition: transform 0.22s, color 0.22s;
  }
  .tag:hover .tag-arrow { transform: translateX(5px); color: #A87A7A; }

  /* ════════════════════════════════════
     CONTACT STRIP — full-width bottom
  ════════════════════════════════════ */
  .contact-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: rgba(250,250,248,0.97);
    border-top: 1px solid rgba(211,186,189,0.5);
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 44px 0 148px;   /* left: clear the 120 px bar */
    z-index: 5;
  }

  .contact-label {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9A7A7A;
  }

  .contact-links {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--stone);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-link:hover { color: var(--ink); }
  .contact-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    border-radius: 2px;
  }
  .contact-sep {
    color: var(--rule);
    font-size: 10px;
  }

  /* ════════════════════════════════════
     MOBILE ≤ 768 px
  ════════════════════════════════════ */
  @media (max-width: 768px) {
    html { height: auto; overflow: auto; }
    body { height: auto; min-height: 100vh; overflow-y: auto; }
    main { height: auto; min-height: 100vh; }

    .layout { height: auto; min-height: 100vh; overflow: visible; }

    .bar-top  { height: 80px; padding: 0 24px 0 100px; }
    .bar-left { width: 72px; }
    .bar-cross { width: 72px; height: 80px; }
    .bar-deco  { width: 52px; height: 52px; }

    .si-heading { font-size: 72px; top: 40px; left: 36px; }
    .si-divider { top: 86px; left: 20px; width: 36px; }

    .tagline    { font-size: 0.875rem; }
    .section-count { display: none; }

    .col-right {
      top: 80px; left: 72px;
      bottom: 52px;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 12px 14px 16px;
    }

    .bar-arcs { transform: scale(0.6); transform-origin: top left; }
    .contact-bar { padding: 0 24px 0 88px; }

    /* 1 column × 6 rows on mobile */
    .modules {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      height: auto;
      gap: 9px;
    }
    .tag {
      grid-template-columns: 28% 72%;
      height: 110px;
    }
    .tag-visual-num { font-size: 36px; }
    .tag-text { padding: 14px 14px 12px; }
  }

  /* ── Small phones ≤ 430 px ── */
  @media (max-width: 430px) {
    .bar-top  { height: 64px; padding: 0 14px 0 84px; }
    .bar-left { width: 56px; }
    .bar-cross { width: 56px; height: 64px; }

    .si-heading { font-size: 58px; top: 32px; left: 28px; }
    .si-divider { top: 70px; left: 15px; width: 30px; }

    .tagline { font-size: 0.78rem; }

    .col-right {
      top: 64px; left: 56px; bottom: 48px;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
