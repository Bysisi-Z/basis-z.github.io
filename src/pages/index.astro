<style>
  /* ── 1-screen desktop ── */
  html { height: 100%; overflow: hidden; }
  body { height: 100vh; overflow: hidden; margin: 0; }
  main { height: 100vh; display: block; }

  /* ════════════════════════════════════
     ROOT
  ════════════════════════════════════ */
  .layout {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #FAFAF8;
    overflow: hidden;
    isolation: isolate;
  }

  /* ════════════════════════════════════
     TOP BAR — tagline + section count
  ════════════════════════════════════ */
  .bar-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 120px;
    background: #D3BABD;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 52px 0 152px; /* left: clear 120 px bar + 32 px gap */
  }

  .tagline-block {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .tagline {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.92);
    margin: 0;
  }

  .tagline-rule {
    height: 1px;
    width: 100%;
    background: rgba(255,255,255,0.38);
  }

  .section-count {
    font-family: var(--sans);
    font-size: 9px;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.48);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 24px;
  }

  /* ════════════════════════════════════
     LEFT BAR
  ════════════════════════════════════ */
  .bar-left {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 120px;
    background: #D3BABD;
    z-index: 1;
  }

  /* ════════════════════════════════════
     INTERSECTION multiply-blend
  ════════════════════════════════════ */
  .bar-cross {
    position: absolute;
    top: 0; left: 0;
    width: 120px;
    height: 120px;
    background: #D3BABD;
    mix-blend-mode: multiply;
    z-index: 2;
    pointer-events: none;
  }

  /* ════════════════════════════════════
     DECORATIVE ARCS
     z-index 3: above bars, below col-right
  ════════════════════════════════════ */
  .bar-arcs {
    position: absolute;
    top: 0; left: 0;
    width: 300px; height: 300px;
    overflow: visible;
    z-index: 3;
    pointer-events: none;
  }

  /* ════════════════════════════════════
     "Si" — centred in 120×120 intersection
  ════════════════════════════════════ */
  .si-heading {
    position: absolute;
    top: 60px;
    left: 60px;
    transform: translate(-50%, -50%);
    z-index: 10;
    margin: 0; padding: 0;
    font-family: var(--serif);
    font-size: 108px;
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    color: #fff;
    white-space: nowrap;
    user-select: none;
    pointer-events: none;
  }

  /* Short divider just below the intersection */
  .si-divider {
    position: absolute;
    top: 128px;
    left: 34px;
    width: 52px;
    height: 1px;
    background: rgba(255,255,255,0.38);
    z-index: 10;
  }

  /* ════════════════════════════════════
     CONTENT AREA
  ════════════════════════════════════ */
  .col-right {
    position: absolute;
    top: 120px;
    left: 120px;
    right: 0;
    bottom: 56px;
    overflow: hidden;
    background: #FAFAF8;
    z-index: 4;            /* above arcs (z:3) so cards stay clear */
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    padding: 28px 44px;
  }

  /* ════════════════════════════════════
     3×2 CARD GRID — fills available width
  ════════════════════════════════════ */
  .modules {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    width: 100%;
  }

  /* ── Card base ── */
  .tag {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: #E8D5D5;
    padding: 22px 22px 20px;
    text-decoration: none;
    border-radius: 2px;
    overflow: hidden;
    transition:
      background  0.24s ease,
      transform   0.24s ease,
      box-shadow  0.24s ease;
  }

  /* Left accent bar — slides in on hover */
  .tag::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: #A87A7A;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
    border-radius: 0 1px 1px 0;
  }

  /* Radial gradient bloom — fades in on hover */
  .tag::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 8% 50%, rgba(211,186,189,0.45) 0%, transparent 68%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }

  .tag:hover {
    background: #E0C8C8;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(168,122,122,0.22);
  }
  .tag:hover::before { transform: scaleX(1); }
  .tag:hover::after  { opacity: 1; }

  .tag:hover .tag-name { color: #3A1E1E; }
  .tag:hover .tag-desc { color: #6A4A4A; }

  /* Click / press-down */
  .tag:active {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(168,122,122,0.18);
    background: #D8BBBB;
    transition-duration: 0.07s;
  }

  .tag--coming {
    opacity: 0.48;
    pointer-events: none;
  }

  /* ── Card internals ── */
  .tag-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    position: relative;
    z-index: 1;
  }

  .tag-num {
    font-family: var(--sans);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.18em;
    color: rgba(107, 74, 74, 0.55);
    flex-shrink: 0;
  }

  .tag-num-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(192,160,160,0.55), transparent);
  }

  .tag-name {
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: #6B4A4A;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    transition: color 0.22s ease;
  }

  .tag-desc {
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 300;
    color: #9A7A7A;
    line-height: 1.5;
    position: relative;
    z-index: 1;
    transition: color 0.22s ease;
  }

  /* ════════════════════════════════════
     CONTACT STRIP — full-width bottom
  ════════════════════════════════════ */
  .contact-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: rgba(250,250,248,0.97);
    border-top: 1px solid rgba(211,186,189,0.5);
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 44px 0 148px;   /* left: clear the 120 px bar */
    z-index: 5;
  }

  .contact-label {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9A7A7A;
  }

  .contact-placeholder {
    font-family: var(--serif);
    font-size: 0.875rem;
    font-weight: 300;
    font-style: italic;
    color: #C9B4B4;
  }

  /* ════════════════════════════════════
     MOBILE ≤ 768 px
  ════════════════════════════════════ */
  @media (max-width: 768px) {
    html { height: auto; overflow: auto; }
    body { height: auto; min-height: 100vh; overflow-y: auto; }
    main { height: auto; min-height: 100vh; }

    .layout { height: auto; min-height: 100vh; overflow: visible; }

    .bar-top  { height: 80px; padding: 0 24px 0 100px; }
    .bar-left { width: 72px; }
    .bar-cross { width: 72px; height: 80px; }
    .bar-deco  { width: 52px; height: 52px; }

    .si-heading { font-size: 72px; top: 40px; left: 36px; }
    .si-divider { top: 86px; left: 20px; width: 36px; }

    .tagline    { font-size: 0.875rem; }
    .section-count { display: none; }

    .col-right {
      top: 80px; left: 72px;
      bottom: 52px;
      overflow-y: auto;          /* allow vertical scroll if cards don't fit */
      justify-content: flex-start;
      padding: 16px 18px 16px;
    }

    .bar-arcs { transform: scale(0.6); transform-origin: top left; }
    .contact-bar { padding: 0 24px 0 88px; }
    .modules { grid-template-columns: repeat(2, 1fr); gap: 9px; }
    .tag { padding: 14px 14px 12px; }
    .tag-name { font-size: 0.8125rem; }
    .tag-desc { font-size: 0.7rem; }
  }

  /* ── Small phones ≤ 430 px ── */
  @media (max-width: 430px) {
    .bar-top  { height: 64px; padding: 0 14px 0 84px; }
    .bar-left { width: 56px; }
    .bar-cross { width: 56px; height: 64px; }

    .si-heading { font-size: 58px; top: 32px; left: 28px; }
    .si-divider { top: 70px; left: 15px; width: 30px; }

    .tagline { font-size: 0.78rem; }

    .col-right {
      top: 64px; left: 56px; bottom: 48px;
      overflow-y: auto;
      justify-content: flex-start;
      padding: 14px 14px 14px;
    }
    .contact-bar { height: 48px; padding: 0 14px 0 68px; }
    .bar-arcs { transform: scale(0.47); transform-origin: top left; }
    .modules { grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .tag { padding: 12px 12px 10px; gap: 4px; }
    .tag-header { margin-bottom: 4px; }
    .tag-name { font-size: 0.78rem; }
    .tag-desc { font-size: 0.68rem; }
  }
</style>
