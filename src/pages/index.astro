---
import BaseLayout from '../layouts/BaseLayout.astro';

const year = new Date().getFullYear();
const modules = [
  { num: '01', title: 'Now',                          desc: "What I'm doing and thinking about lately",           href: '/now' },
  { num: '02', title: 'Journey',                      desc: 'Professional path & the person behind it',           href: '/career' },
  { num: '03', title: 'Decoding',                     desc: 'Industry research, data analysis & market insights',  href: '/research' },
  { num: '04', title: 'Nature Never Judges',          desc: 'Landscape photography, hiking guides & alpine walks', href: '/photography' },
  { num: '05', title: 'Wandering',                    desc: 'Personal growth, reflections & inner landscapes',     href: '/writing' },
  { num: '06', title: 'A Collection of Rabbit Holes', desc: 'Books, papers & ideas worth revisiting',             href: '/reading' },
];
---

<BaseLayout title="Home" description="Sisi — Making sense of numbers and landscapes." hideNav={true} hideFooter={true}>

  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Ma+Shan+Zheng&family=Barlow+Condensed:wght@200;700&family=Nunito:wght@300;400&display=swap" rel="stylesheet">
  </Fragment>


  <!-- ══════════════════════════════════════════════════════════
       NIGHT HOME  (夜间 18:00–6:00)
       左：摩天轮照片，精确竖幅比例，无裁切
       中：深紫毛玻璃，内容面板
       右：黑色手机锁屏条，时钟 / 天气 / 猫猫 / 落地灯
       ══════════════════════════════════════════════════════════ -->
  <div id="homeNight" class="n-layout" style="display:none">

    <!-- Full-bleed background (ferris wheel, blurs through glass) -->
    <div class="n-bg" aria-hidden="true">
      <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
    </div>

    <!-- Left: exact portrait ratio, object-fit: fill — no crop -->
    <div class="n-photo" aria-hidden="true">
      <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
    </div>

    <!-- Middle: frosted glass content panel -->
    <div class="n-glass">
      <div class="n-logo">Si</div>

      <div class="n-tagwrap">
        <h1 class="n-tag">Making <em class="n-sense">sense</em> of<br>numbers and<br>landscapes.</h1>
        <div class="n-rule"></div>
      </div>

      <nav class="n-mods">
        {modules.map(m => (
          <a class="n-mod" href={m.href}>
            <span class="n-bullet">◆</span>
            <span class="n-num">{m.num}</span>
            <span class="n-body">
              <span class="n-title">{m.title}</span>
              <span class="n-desc">{m.desc}</span>
            </span>
          </a>
        ))}
      </nav>

      <div class="n-contact">
        <a href="https://www.linkedin.com/in/sisi-z-9a4a6075/" target="_blank" rel="noopener" class="n-link">LinkedIn</a>
        <span class="n-sep">·</span>
        <a href="https://www.xiaohongshu.com/user/profile/111799574" target="_blank" rel="noopener" class="n-link">Red Note</a>
        <span class="n-sep">·</span>
        <a href="mailto:sisi.zhang.ch@gmail.com" class="n-link">Email</a>
        <span class="n-sep">·</span>
        <button class="n-link card-trigger" id="nCardBtn"><svg class="card-icon" viewBox="0 0 14 14" fill="none"><path d="M9 1h4v4M13 1L7.5 6.5M6 3H2a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg> Get QR Code & Share</button>
      </div>
      <p class="n-copy">© {year} · All photographs on this site are the exclusive property of the author. Unauthorized reproduction, redistribution, or commercial use is strictly prohibited.</p>
    </div>

    <!-- Right: black phone-strip -->
    <div class="n-strip" id="nStrip" aria-hidden="true">

      <div class="n-carrier">
        <svg class="n-carrier-signal" viewBox="0 0 20 14" fill="none">
          <rect x="0"    y="9" width="3" height="5"  rx="0.8" fill="currentColor"/>
          <rect x="4.5"  y="6" width="3" height="8"  rx="0.8" fill="currentColor"/>
          <rect x="9"    y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
          <rect x="13.5" y="0" width="3" height="14" rx="0.8" fill="currentColor" opacity="0.3"/>
        </svg>
        <span class="n-carrier-name">Swisscom</span>
      </div>

      <div class="n-statusbar">
        <svg class="n-status-icon" viewBox="0 0 24 24" fill="none">
          <path d="M12 18.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z" fill="currentColor"/>
          <path d="M12 14c1.6 0 3 .65 4.05 1.7l1.42-1.42A8.1 8.1 0 0 0 12 12a8.1 8.1 0 0 0-5.47 2.28l1.42 1.42A6.08 6.08 0 0 1 12 14z" fill="currentColor"/>
          <path d="M12 9.5c2.76 0 5.26 1.12 7.07 2.93l1.42-1.42A12.14 12.14 0 0 0 12 7.5c-3.35 0-6.39 1.36-8.49 3.51l1.42 1.42A10.12 10.12 0 0 1 12 9.5z" fill="currentColor"/>
          <path d="M12 5c3.93 0 7.48 1.59 10.05 4.16l1.42-1.42A16.18 16.18 0 0 0 12 3C7.37 3 3.17 4.93.53 8.02l1.42 1.42A14.15 14.15 0 0 1 12 5z" fill="currentColor"/>
        </svg>
        <svg class="n-status-icon n-battery" viewBox="0 0 28 14" fill="none">
          <rect x="0.5" y="0.5" width="23" height="13" rx="3.5" stroke="currentColor" stroke-opacity="0.6"/>
          <rect x="2"   y="2"   width="20" height="10" rx="2"   fill="currentColor"/>
          <path d="M25 4.5v5a2.5 2.5 0 0 0 0-5z" fill="currentColor" fill-opacity="0.6"/>
        </svg>
      </div>

      <div class="n-greet-wrap">
        <span class="n-greet" id="nGreeting"></span>
      </div>

      <div class="n-clockwrap">
        <div class="n-dateline" id="nDateline"></div>
        <div class="n-weather" id="nWeather">
          <span class="n-w-icon" id="nWeatherIcon"></span>
          <span class="n-w-temp" id="nWeatherTemp"></span>
          <span class="n-w-desc" id="nWeatherDesc"></span>
          <span class="n-w-loc"  id="nWeatherLoc"></span>
        </div>
        <div class="n-clock" id="nClock">00:00</div>
      </div>

      <!-- Cats easter egg -->
      <div class="n-cats-container" id="nCatsContainer">
        <div class="n-cats-wrap">
          <img src="/images/cats-illustration.png" alt="" class="n-cat n-cat-a">
          <img src="/images/cats-illustration.png" alt="" class="n-cat n-cat-b">
        </div>
        <img src="/images/cat-scratch.png" alt="" class="n-scratch n-scratch-a" id="nScratchA" aria-hidden="true">
        <img src="/images/cat-scratch.png" alt="" class="n-scratch n-scratch-b" id="nScratchB" aria-hidden="true">
      </div>

      <!-- Floor lamp easter egg -->
      <div class="n-lamp" id="nLamp">
        <svg viewBox="0 0 80 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">
          <defs>
            <linearGradient id="nBeamGrad" x1="0.5" y1="0" x2="0.5" y2="1">
              <stop offset="0%"   stop-color="rgba(255,220,80,0.08)"/>
              <stop offset="40%"  stop-color="rgba(255,210,70,0.05)"/>
              <stop offset="100%" stop-color="rgba(255,200,60,0)"/>
            </linearGradient>
            <linearGradient id="nAmbientGrad" x1="0.5" y1="0" x2="0.5" y2="1">
              <stop offset="0%"   stop-color="rgba(255,215,70,0.14)"/>
              <stop offset="50%"  stop-color="rgba(255,210,70,0.06)"/>
              <stop offset="100%" stop-color="rgba(255,200,60,0)"/>
            </linearGradient>
            <radialGradient id="nLampGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%"   stop-color="rgba(235,225,255,1)"/>
              <stop offset="100%" stop-color="rgba(235,225,255,0)"/>
            </radialGradient>
            <filter id="nBeamBlur"    x="-200%" y="-5%"  width="500%"  height="110%"><feGaussianBlur stdDeviation="30 4"/></filter>
            <filter id="nAmbientBlur" x="-500%" y="-15%" width="1100%" height="130%"><feGaussianBlur stdDeviation="80 18"/></filter>
          </defs>
          <path class="n-beam" d="M40 40 L-1200 520 L1280 520 Z" fill="url(#nAmbientGrad)" filter="url(#nAmbientBlur)"/>
          <path class="n-beam" d="M40 55 L-400 500 L480 500 Z"    fill="url(#nBeamGrad)"   filter="url(#nBeamBlur)"/>
          <ellipse cx="40" cy="44" rx="24" ry="13" fill="url(#nLampGlow)" opacity="0.28"/>
          <path d="M20 48 L33 22 L47 22 L60 48 Z" fill="rgba(212,203,232,0.16)" stroke="rgba(212,203,232,0.44)" stroke-width="1" stroke-linejoin="round"/>
          <path d="M47 22 L60 48 L54 48 L44 23 Z" fill="rgba(150,130,185,0.10)"/>
          <path d="M16 49 Q18 53 40 54 Q62 53 64 49 L60 48 Q58 52 40 53 Q22 52 20 48 Z" fill="rgba(212,203,232,0.18)" stroke="rgba(212,203,232,0.40)" stroke-width="0.8"/>
          <ellipse cx="40" cy="22" rx="6" ry="1.8" fill="rgba(10,5,20,0.9)" stroke="rgba(212,203,232,0.32)" stroke-width="0.8"/>
          <ellipse cx="40" cy="37" rx="8" ry="6" fill="rgba(255,235,160,0.12)"/>
          <path d="M39.6 51 L38.5 188 L41.5 188 L40.4 51 Z" fill="rgba(212,203,232,0.38)"/>
          <ellipse cx="40" cy="190" rx="20" ry="4" fill="rgba(212,203,232,0.22)" stroke="rgba(212,203,232,0.38)" stroke-width="0.8"/>
          <rect x="20" y="190" width="40" height="4" fill="rgba(212,203,232,0.12)"/>
          <ellipse cx="40" cy="194" rx="20" ry="4" fill="rgba(212,203,232,0.18)" stroke="rgba(212,203,232,0.32)" stroke-width="0.8"/>
          <ellipse cx="40" cy="199" rx="22" ry="2" fill="rgba(212,203,232,0.06)"/>
        </svg>
      </div>

    </div><!-- /n-strip -->
  </div><!-- /homeNight -->


  <!-- ══════════════════════════════════════════════════════════
       DAY HOME  (白天 6:00–18:00)
       左：瑞士高山湖照片，flex 比例，cover 裁切
       中：湖蓝灰毛玻璃，内容面板
       右：雾蓝灰条，搜索 / 通知卡 / 时钟
       ══════════════════════════════════════════════════════════ -->
  <div id="homeDay" class="d-layout" style="display:none">

    <!-- Full-bleed background (alpine morning, blurs through glass) -->
    <div class="d-bg" aria-hidden="true">
      <img src="/images/homepage-morning.jpg" alt="" loading="eager">
    </div>

    <!-- Left: alpine photo, flex ratio, cover -->
    <div class="d-photo" aria-hidden="true">
      <img src="/images/homepage-morning.jpg" alt="" loading="eager">
    </div>

    <!-- Middle: frosted glass content panel -->
    <div class="d-glass">
      <div class="d-logo">Si</div>

      <div class="d-tagwrap">
        <h1 class="d-tag">Making <em class="d-sense">sense</em> of<br>numbers and<br>landscapes.</h1>
        <div class="d-rule"></div>
      </div>

      <nav class="d-mods">
        {modules.map(m => (
          <a class="d-mod" href={m.href}>
            <svg class="d-bullet-leaf" viewBox="0 0 12 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 1 C10 1 12 5 10 9 C9 12 7.5 14 6 15 C4.5 14 3 12 2 9 C0 5 2 1 6 1Z" fill="currentColor"/>
              <line x1="6" y1="4" x2="6" y2="15" stroke="rgba(255,255,255,0.35)" stroke-width="0.8"/>
            </svg>
            <span class="d-num">{m.num}</span>
            <span class="d-body">
              <span class="d-title">{m.title}</span>
              <span class="d-desc">{m.desc}</span>
            </span>
          </a>
        ))}
      </nav>

      <div class="d-contact">
        <a href="https://www.linkedin.com/in/sisi-z-9a4a6075/" target="_blank" rel="noopener" class="d-link">LinkedIn</a>
        <span class="d-sep">·</span>
        <a href="https://www.xiaohongshu.com/user/profile/111799574" target="_blank" rel="noopener" class="d-link">Red Note</a>
        <span class="d-sep">·</span>
        <a href="mailto:sisi.zhang.ch@gmail.com" class="d-link">Email</a>
        <span class="d-sep">·</span>
        <button class="d-link card-trigger" id="dCardBtn"><svg class="card-icon" viewBox="0 0 14 14" fill="none"><path d="M9 1h4v4M13 1L7.5 6.5M6 3H2a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg> Get QR Code & Share</button>
      </div>
      <p class="d-copy">© {year} · All photographs on this site are the exclusive property of the author. Unauthorized reproduction, redistribution, or commercial use is strictly prohibited.</p>
    </div>

    <!-- Right: mist blue-grey phone strip -->
    <div class="d-strip" id="dStrip">

      <div class="d-carrier">
        <svg class="d-carrier-signal" viewBox="0 0 20 14" fill="none">
          <rect x="0"    y="9" width="3" height="5"  rx="0.8" fill="currentColor"/>
          <rect x="4.5"  y="6" width="3" height="8"  rx="0.8" fill="currentColor"/>
          <rect x="9"    y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
          <rect x="13.5" y="0" width="3" height="14" rx="0.8" fill="currentColor" opacity="0.3"/>
        </svg>
        <span class="d-carrier-name">Swisscom</span>
      </div>

      <div class="d-statusbar">
        <svg class="d-status-icon" viewBox="0 0 24 24" fill="none">
          <path d="M12 18.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z" fill="currentColor"/>
          <path d="M12 14c1.6 0 3 .65 4.05 1.7l1.42-1.42A8.1 8.1 0 0 0 12 12a8.1 8.1 0 0 0-5.47 2.28l1.42 1.42A6.08 6.08 0 0 1 12 14z" fill="currentColor"/>
          <path d="M12 9.5c2.76 0 5.26 1.12 7.07 2.93l1.42-1.42A12.14 12.14 0 0 0 12 7.5c-3.35 0-6.39 1.36-8.49 3.51l1.42 1.42A10.12 10.12 0 0 1 12 9.5z" fill="currentColor"/>
          <path d="M12 5c3.93 0 7.48 1.59 10.05 4.16l1.42-1.42A16.18 16.18 0 0 0 12 3C7.37 3 3.17 4.93.53 8.02l1.42 1.42A14.15 14.15 0 0 1 12 5z" fill="currentColor"/>
        </svg>
        <svg class="d-status-icon d-battery" viewBox="0 0 28 14" fill="none">
          <rect x="0.5" y="0.5" width="23" height="13" rx="3.5" stroke="currentColor" stroke-opacity="0.6"/>
          <rect x="2"   y="2"   width="20" height="10" rx="2"   fill="currentColor"/>
          <path d="M25 4.5v5a2.5 2.5 0 0 0 0-5z" fill="currentColor" fill-opacity="0.6"/>
        </svg>
      </div>

      <div class="d-greet-wrap">
        <span class="d-greet" id="dGreeting"></span>
      </div>

      <div class="d-clockwrap">
        <div class="d-dateline" id="dDateline"></div>
        <div class="d-weather" id="dWeather">
          <span class="d-w-icon" id="dWeatherIcon"></span>
          <span class="d-w-temp" id="dWeatherTemp"></span>
          <span class="d-w-desc" id="dWeatherDesc"></span>
          <span class="d-w-loc"  id="dWeatherLoc"></span>
        </div>
        <div class="d-clock" id="dClock">00:00</div>
      </div>

      <!-- Search bar -->
      <div class="d-search-wrap">
        <div class="d-search-bar">
          <svg class="d-search-icon" viewBox="0 0 18 18" fill="none">
            <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 12l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input id="dSearchInput" class="d-search-input" type="search" placeholder="Search..." autocomplete="off" spellcheck="false">
        </div>
        <div class="d-search-results" id="dSearchResults"></div>
      </div>

      <!-- Notification cards -->
      <div class="d-notif-stack">
        <a class="d-notif" href="/research/data">
          <div class="d-notif-meta">
            <div class="d-notif-left">
              <svg class="d-notif-icon" viewBox="0 0 16 14" fill="none">
                <rect x="0.5" y="0.5" width="15" height="13" rx="2" stroke="currentColor" stroke-opacity="0.7"/>
                <path d="M1 2l7 5.5L15 2" stroke="currentColor" stroke-opacity="0.7" stroke-width="1" stroke-linecap="round"/>
              </svg>
              <span class="d-notif-app">Latest Update</span>
            </div>
            <span class="d-notif-time">Jun 16, 2026</span>
          </div>
          <div class="d-notif-title">NSFG Contraceptive Survey</div>
          <div class="d-notif-body">2022–23 vs 2017–19 cycle analysis · method trends by age</div>
        </a>
        <a class="d-notif" href="/photography/stoos-ridge-line">
          <div class="d-notif-meta">
            <div class="d-notif-left">
              <svg class="d-notif-icon" viewBox="0 0 16 14" fill="none">
                <rect x="0.5" y="0.5" width="15" height="13" rx="2" stroke="currentColor" stroke-opacity="0.7"/>
                <path d="M1 2l7 5.5L15 2" stroke="currentColor" stroke-opacity="0.7" stroke-width="1" stroke-linecap="round"/>
              </svg>
              <span class="d-notif-app">Latest Update</span>
            </div>
            <span class="d-notif-time">Jun 5, 2026</span>
          </div>
          <div class="d-notif-title">Stoos Ridge Line Hike</div>
          <div class="d-notif-body">Hiking guide · Central Switzerland, ridge traverse</div>
        </a>
      </div>

    </div><!-- /d-strip -->
  </div><!-- /homeDay -->


  <!-- ══════════════════════════════════════════════════════════
       MOBILE HOME  (≤600px 专属)
       锁屏: 摩天轮全屏 + 状态栏 + 大时钟 + 向上滑提示
       解锁: 原图模糊 + 夜间玻璃面板内容 (全宽自适应)
       ══════════════════════════════════════════════════════════ -->
  <div id="homeMobile">

    <!-- ── 锁屏 (100dvh) ── -->
    <div class="m-lock">
      <div class="m-lock-bg" aria-hidden="true">
        <img src="/images/homepage-ferris-original.jpeg" alt="" loading="eager">
      </div>

      <!-- 状态栏 -->
      <div class="m-bar" aria-hidden="true">
        <div class="m-bar-l">
          <svg class="m-sig" viewBox="0 0 20 14" fill="none">
            <rect x="0"    y="9" width="3" height="5"  rx="0.8" fill="currentColor"/>
            <rect x="4.5"  y="6" width="3" height="8"  rx="0.8" fill="currentColor"/>
            <rect x="9"    y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
            <rect x="13.5" y="0" width="3" height="14" rx="0.8" fill="currentColor"/>
          </svg>
          <span class="m-carrier">Swisscom</span>
          <svg class="m-bell" viewBox="0 0 16 18" fill="none">
            <path d="M8 1a5.5 5.5 0 0 0-5.5 5.5V11l-1.5 2h14l-1.5-2V6.5A5.5 5.5 0 0 0 8 1z" stroke="currentColor" stroke-width="1.3"/>
            <path d="M6 13a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.3"/>
            <line x1="2" y1="2" x2="14" y2="16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="m-bar-r">
          <svg class="m-sig" viewBox="0 0 20 14" fill="none">
            <rect x="0"    y="9" width="3" height="5"  rx="0.8" fill="currentColor"/>
            <rect x="4.5"  y="6" width="3" height="8"  rx="0.8" fill="currentColor"/>
            <rect x="9"    y="3" width="3" height="11" rx="0.8" fill="currentColor"/>
            <rect x="13.5" y="0" width="3" height="14" rx="0.8" fill="currentColor"/>
          </svg>
          <svg class="m-wifi" viewBox="0 0 24 18" fill="none">
            <path d="M12 14.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z" fill="currentColor"/>
            <path d="M12 10c1.6 0 3 .65 4.05 1.7l1.42-1.42A8.1 8.1 0 0 0 12 8a8.1 8.1 0 0 0-5.47 2.28l1.42 1.42A6.08 6.08 0 0 1 12 10z" fill="currentColor"/>
            <path d="M12 5.5c2.76 0 5.26 1.12 7.07 2.93l1.42-1.42A12.14 12.14 0 0 0 12 3.5c-3.35 0-6.39 1.36-8.49 3.51l1.42 1.42A10.12 10.12 0 0 1 12 5.5z" fill="currentColor"/>
          </svg>
          <svg class="m-batt" viewBox="0 0 28 14" fill="none">
            <rect x="0.5" y="0.5" width="23" height="13" rx="3.5" stroke="currentColor" stroke-opacity="0.6"/>
            <rect x="2" y="2" width="19" height="10" rx="2" fill="currentColor"/>
            <path d="M25 4.5v5a2.5 2.5 0 0 0 0-5z" fill="currentColor" fill-opacity="0.6"/>
          </svg>
          <span class="m-batt-pct">100%</span>
        </div>
      </div>

      <!-- 时钟 + 日期 + 天气 -->
      <div class="m-timebox">
        <div class="m-date" id="mDate">Wed Jun 18</div>
        <div class="m-time" id="mTime">00:00</div>
        <div class="m-weather-row" id="mWeatherRow">
          <span class="m-wicon" id="mWIcon"></span>
          <span class="m-wtemp" id="mWTemp"></span>
          <span class="m-wdesc" id="mWDesc"></span>
        </div>
        <div class="m-wloc" id="mWLoc"></div>

        <!-- Message notification card -->
        <div class="m-msg-card">
          <div class="m-msg-header">
            <div class="m-msg-left">
              <svg class="m-msg-icon" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 2C5.58 2 2 5.13 2 9c0 2.09 1.03 3.97 2.67 5.27L4 17l3.07-1.53C7.67 15.81 8.81 16 10 16c4.42 0 8-3.13 8-7s-3.58-7-8-7z" fill="currentColor"/>
              </svg>
