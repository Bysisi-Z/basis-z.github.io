    50% {
      transform: scale(1.05);
      filter: drop-shadow(0 0 3px rgba(168,212,184,0.5)) drop-shadow(0 0 8px rgba(168,212,184,0.2));
    }
  }

  /* Highlight: left→right gradient, tail almost transparent, collapses on mouse leave */
  .d-mod::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right,
      rgba(168, 212, 184, 0.14) 0%,
      rgba(168, 212, 184, 0.09) 40%,
      rgba(168, 212, 184, 0.03) 75%,
      rgba(168, 212, 184, 0.00) 100%
    );
    clip-path: inset(0 100% 0 0);
    pointer-events: none;
    transition: clip-path 0.5s ease;
  }
  .d-mod:hover::before {
    animation: d-highlight-expand 1.5s ease-in-out 1 forwards;
    transition: none;
  }

  @keyframes d-highlight-expand {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0% 0 0); }
  }

  /* Morning light beam — sweeps once at 2× speed */
  .d-mod::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 64px;
    width: 72px;
    opacity: 0;
    background: linear-gradient(to right,
      transparent,
      rgba(168, 212, 184, 0.20) 30%,
      rgba(255, 255, 245, 0.26) 50%,
      rgba(168, 212, 184, 0.20) 70%,
      transparent
    );
    transform: translateX(-72px);
    pointer-events: none;
  }
  .d-mod:hover::after {
    animation: d-sunbeam 1.6s ease-in-out 1 forwards;
  }

  @keyframes d-sunbeam {
    0%   { transform: translateX(-72px); opacity: 0; }
    12%  { opacity: 1; }
    82%  { opacity: 1; }
    100% { transform: translateX(640px); opacity: 0; }
  }

  /* Contact */
  .d-contact {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: clamp(5px, 1.2cqw, 10px);
    padding-top: clamp(10px, 2cqh, 24px);
    border-top: 1px solid rgba(255,255,255,0.18);
    flex-shrink: 0;
    overflow: hidden;
  }

  .d-link {
    font-family: 'Nunito', Arial, sans-serif;
    font-size: clamp(9px, 2cqw, 12px);
    font-weight: 400;
    letter-spacing: clamp(0.05em, 0.12em, 0.12em);
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.25s;
  }
  .d-link:hover { color: #fff; }

  .d-contact a.d-link,
  .d-contact button.card-trigger {
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 20px;
    padding: 4px clamp(6px, 1.3cqw, 11px) 5px;
    background: rgba(255,255,255,0.07);
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .d-contact a.d-link:hover,
  .d-contact button.card-trigger:hover {
    background: rgba(255,255,255,0.16);
    border-color: rgba(255,255,255,0.42);
    color: #fff;
  }

  .d-sep { color: rgba(255,255,255,0.2); font-size: 9px; }

  .d-copy {
    font-family: 'Nunito', Arial, sans-serif;
    font-size: clamp(9px, 1.2cqw, 11px);
    font-weight: 300;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.4);
    line-height: 1.7;
    padding-top: clamp(6px, 1cqh, 12px);
    flex-shrink: 0;
    margin: 0;
  }

  /* Right mist blue-grey strip */
  .d-strip {
    position: relative;
    z-index: 2;
    flex: 0.7 1 0;
    background: #D4DCE2;
    container-type: inline-size;
    overflow-x: clip;
  }

  .d-carrier {
    position: absolute;
    top: 20px; left: 16px;
    display: flex;
    align-items: center;
    gap: 5px;
    color: #6E7B81;
  }
  .d-carrier-signal { width: 17px; height: 12px; display: block; }
  .d-carrier-name {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .d-statusbar {
    position: absolute;
    top: 18px; right: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #6E7B81;
  }
  .d-status-icon { width: 18px; height: 18px; display: block; }
  .d-battery     { width: 26px; height: 13px; }

  .d-greet-wrap {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 22%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .d-greet {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(20px, 12cqw, 56px);
    font-weight: 400;
    font-style: italic;
    color: #546860;
    letter-spacing: 0.02em;
    text-align: center;
    opacity: 0;
    transition: opacity 0.75s ease-in-out;
  }
  .d-greet.visible { opacity: 1; }
  .d-greet.zh      { font-family: 'Ma Shan Zheng', cursive; }

  .d-clockwrap {
    position: absolute;
    top: 22%; left: 0; right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding-top: 8px;
    z-index: 2;
  }

  .d-dateline {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(11px, 3.5cqw, 16px);
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #6E7B81;
    background: rgba(165,174,184,0.14);
    padding: 5px 16px 6px;
    border-radius: 20px;
  }

  .d-clock {
    font-family: 'Barlow Condensed', 'Inter', system-ui, sans-serif;
    font-size: clamp(56px, 32cqw, 150px);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 0.95;
    font-variant-numeric: tabular-nums;
    background: linear-gradient(175deg, rgba(165,174,184,0.88) 0%, rgba(110,123,129,0.62) 45%, rgba(48,64,60,0.40) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    -webkit-box-reflect: below 1px linear-gradient(transparent 30%, rgba(110,123,129,0.15) 100%);
  }

  .d-weather {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #6E7B81;
  }
  .d-w-icon { font-size: clamp(16px, 7cqw, 28px); line-height: 1; }
  .d-w-temp {
    font-family: 'Barlow Condensed', 'Inter', system-ui, sans-serif;
    font-size: clamp(18px, 9cqw, 34px);
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .d-w-desc {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(11px, 4cqw, 17px);
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .d-w-loc {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(10px, 3.5cqw, 14px);
    font-weight: 300;
    letter-spacing: 0.08em;
    opacity: 0.65;
    text-transform: uppercase;
  }
  .d-w-loc:not(:empty)::before { content: '·'; margin-right: 5px; opacity: 0.5; }

  /* Search bar */
  .d-search-wrap {
    position: absolute;
    top: 52%;
    left: clamp(10px, 4cqw, 18px);
    right: clamp(10px, 4cqw, 18px);
    z-index: 5;
  }

  .d-search-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.55);
    border: 1px solid rgba(110,140,120,0.20);
    border-radius: 12px;
    padding: 8px 12px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .d-search-icon { width: 16px; height: 16px; color: #6E7B81; flex-shrink: 0; }

  .d-search-input {
    flex: 1;
    border: none;
    background: transparent;
    outline: none;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(12px, 3.5cqw, 14px);
    font-weight: 300;
    color: #15201B;
    min-width: 0;
  }
  .d-search-input::placeholder { color: #A5AEB8; }
  .d-search-input::-webkit-search-cancel-button { display: none; }

  .d-search-results {
    position: fixed;
    background: rgba(255,255,255,0.92);
    border: 1px solid rgba(110,140,120,0.20);
    border-radius: 12px;
    overflow: hidden;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    overflow-y: auto;
    display: none;
    z-index: 9999;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }
  .d-search-results.open { display: block; }

  .d-sr-item {
    display: block;
    padding: 9px 13px;
    text-decoration: none;
    border-bottom: 1px solid rgba(110,140,120,0.10);
    transition: background 0.15s;
  }
  .d-sr-item:last-child { border-bottom: none; }
  .d-sr-item:hover { background: rgba(160,195,170,0.22); }

  .d-sr-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(13px, 4cqw, 16px);
    font-weight: 600;
    font-style: italic;
    color: #15201B;
    line-height: 1.3;
  }
  .d-sr-excerpt {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(10px, 2.8cqw, 11px);
    font-weight: 300;
    color: #6E7B81;
    line-height: 1.4;
    margin-top: 2px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .d-sr-empty {
    padding: 12px 13px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: #A5AEB8;
    font-style: italic;
  }

  /* Notification cards */
  .d-notif-stack {
    position: absolute;
    top: 63%;
    left: clamp(10px, 4cqw, 18px);
    right: clamp(10px, 4cqw, 18px);
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 1.5cqh, 10px);
    z-index: 3;
  }

  .d-notif {
    display: block;
    background: rgba(160,195,170,0.22);
    border: 1px solid rgba(110,140,120,0.18);
    border-radius: 14px;
    padding: clamp(10px, 2.5cqw, 14px) clamp(12px, 3cqw, 16px);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .d-notif:hover { background: rgba(160,195,170,0.34); border-color: rgba(110,140,120,0.32); }

  .d-notif-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: clamp(4px, 1cqh, 7px);
  }
  .d-notif-left { display: flex; align-items: center; gap: 5px; }
  .d-notif-icon { width: clamp(11px, 3.2cqw, 14px); height: auto; color: #6E7B81; flex-shrink: 0; }
  .d-notif-app {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(9px, 2.8cqw, 11px);
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #6E7B81;
  }
  .d-notif-time {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(9px, 2.8cqw, 11px);
    color: #6E7B81;
  }
  .d-notif-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(15px, 5cqw, 22px);
    font-weight: 600;
    font-style: italic;
    color: #15201B;
    line-height: 1.2;
    margin-bottom: clamp(3px, 0.8cqh, 6px);
  }
  .d-notif-body {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(11px, 3.2cqw, 13px);
    font-weight: 300;
    color: #6E7B81;
    line-height: 1.45;
  }

  /* Day mobile ≤600px */
  @media (max-width: 600px) {
    .d-layout { flex-direction: column; overflow-y: auto; }
    .d-strip { display: none; }
    .d-photo { flex: none; width: 100%; height: 50vw; }
    .d-photo img { object-fit: cover; object-position: center 35%; position: absolute; inset: 0; }
    .d-glass { flex: 1; padding: 24px 24px 32px; backdrop-filter: blur(24px) brightness(0.6); -webkit-backdrop-filter: blur(24px) brightness(0.6); }
    .d-logo  { font-size: 64px; margin-bottom: 24px; }
    .d-tag   { font-size: clamp(28px, 7vw, 44px); }
    .d-mod   { padding: 12px 0; }
    .d-title { font-size: 18px; }
    .d-desc  { display: none; }
    .d-contact { margin-top: 8px; }
  }

  /* Day tablet 601–900px: two-col, no strip */
  @media (min-width: 601px) and (max-width: 900px) {
    .d-strip { display: none; }
    .d-photo { flex: 1.2 1 0; }
    .d-glass { flex: 1.8 1 0; }
  }

  /* Short viewport adjustments */
  @media (max-height: 750px) {
    .d-search-wrap { top: 47%; }
    .d-notif-stack { top: 58%; }
    .d-notif-title { font-size: clamp(13px, 4.5cqw, 18px); }
  }
  @media (max-height: 620px) {
    .d-search-wrap { top: 44%; }
    .d-notif-stack { top: 56%; }
    .d-notif:last-child { display: none; }
  }


  /* ════════════════════════════════════════════════════════
     MOBILE HOME (≤600px)
     ════════════════════════════════════════════════════════ */
  #homeMobile { display: none; }

  @media (max-width: 600px) {
    #homeMobile { display: block; }
    .n-layout, .d-layout { display: none !important; }

    /* ── Lock screen: fixed overlay, slides up on dismiss ── */
    .m-lock {
      position: fixed;
      inset: 0; z-index: 100;
      height: 100dvh; overflow: hidden;
      transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .m-lock.dismissed {
      transform: translateY(-100%);
      pointer-events: none;
    }
    .m-lock-bg { position: absolute; inset: 0; z-index: 0; }
    .m-lock-bg img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 65%;
      display: block;
    }

    /* Status bar */
    .m-bar {
      position: absolute; z-index: 2;
      top: 16px; left: 20px; right: 20px;
      display: flex; justify-content: space-between; align-items: center;
      color: rgba(255,255,255,0.92);
    }
    .m-bar-l { display: flex; align-items: center; gap: 5px; }
    .m-bar-r { display: flex; align-items: center; gap: 6px; }
    .m-sig  { width: 17px; height: 12px; display: block; flex-shrink: 0; }
    .m-bell { width: 14px; height: 16px; display: block; flex-shrink: 0; }
    .m-wifi { width: 17px; height: 14px; display: block; flex-shrink: 0; }
    .m-batt { width: 24px; height: 11px; display: block; flex-shrink: 0; }
    .m-carrier {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 13px; font-weight: 600;
    }
    .m-batt-pct {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 11px; font-weight: 600;
    }

    /* Clock + date */
    .m-timebox {
      position: absolute; z-index: 2;
      left: 0; right: 0;
      top: 60px;
      text-align: center; padding: 0 16px;
    }
    .m-date {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 17px; font-weight: 600;
      color: rgba(255,255,255,0.9);
      letter-spacing: 0.01em; margin-bottom: 2px;
    }
    .m-time {
      font-family: 'Barlow Condensed', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 36vw; font-weight: 700;
      letter-spacing: -0.025em; line-height: 1;
      background: linear-gradient(to bottom, rgba(230,235,252,0.95) 0%, rgba(215,200,238,0.88) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .m-weather-row {
      display: flex; align-items: center; justify-content: center; gap: 6px;
      margin-top: 10px;
      color: rgba(255,255,255,0.88);
    }
    .m-wicon { font-size: 18px; line-height: 1; }
    .m-wtemp {
      font-family: 'Barlow Condensed', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 20px; font-weight: 700; letter-spacing: 0.01em;
    }
    .m-wdesc {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 14px; font-weight: 400; letter-spacing: 0.02em;
    }
    .m-wloc {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 12px; font-weight: 400; letter-spacing: 0.06em;
      color: rgba(255,255,255,0.6);
      text-transform: uppercase;
      margin-top: 4px;
      min-height: 16px;
    }
    .m-wloc:not(:empty)::before { content: '◎  '; font-size: 10px; opacity: 0.7; }
    .m-msg-card {
      margin: 18px 16px 0;
      background: rgba(196, 168, 224, 0.18);
      border: 1px solid rgba(196, 168, 224, 0.32);
      border-radius: 16px;
      padding: 11px 14px 13px;
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      text-align: left;
    }
    .m-msg-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 6px;
    }
    .m-msg-left { display: flex; align-items: center; gap: 6px; }
    .m-msg-icon { width: 20px; height: 20px; color: rgba(255,255,255,0.88); flex-shrink: 0; }
    .m-msg-from {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 13px; font-weight: 600; letter-spacing: 0.01em;
      color: rgba(255,255,255,0.88);
    }
    .m-msg-time {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 12px; color: rgba(255,255,255,0.48);
    }
    .m-msg-body {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 14px; font-weight: 400; line-height: 1.5;
      color: rgba(255,255,255,0.85);
    }

    /* Swipe hint */
    .m-swipe {
      position: absolute; z-index: 2;
      bottom: 38px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 7px;
      color: rgba(255,255,255,0.88);
      white-space: nowrap;
    }
    .m-swipe-arr {
      width: 28px; height: 16px; display: block;
      animation: mBounceUp 2.2s ease-in-out infinite;
    }
    .m-swipe-txt {
      font-family: -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 13px; font-weight: 500; letter-spacing: 0.08em;
    }
    @keyframes mBounceUp {
      0%, 100% { transform: translateY(0);   opacity: 0.75; }
      50%       { transform: translateY(-7px); opacity: 1;    }
    }

    /* ── Content: sits behind lock screen, always rendered ── */
    .m-open {
      position: relative;
      min-height: 100dvh;
      overflow: hidden;
    }
    .m-open-bg {
      position: absolute; inset: -30px; z-index: 0;
    }
    .m-open-bg img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center 65%;
      filter: blur(22px); display: block;
    }
    .m-open-overlay {
      position: absolute; inset: 0; z-index: 1;
      background: rgba(15, 8, 38, 0.48);
    }

    /* n-glass override: full-width, fixed height, internally scrollable */
    .m-glass {
      position: relative !important; z-index: 2 !important;
      flex: none !important; display: flex !important; flex-direction: column !important;
      width: 100% !important; height: 100% !important;
      box-sizing: border-box !important;
      padding: 48px 28px 52px !important;
      background: transparent !important;
      backdrop-filter: none !important; -webkit-backdrop-filter: none !important;
      container-type: inline-size !important;
    }
    .m-glass .n-logo   { font-size: clamp(56px, 16vw, 80px) !important; margin-bottom: 20px !important; }
    .m-glass .n-tag    { font-size: clamp(28px, 8vw, 40px) !important; }
    .m-glass .n-title  { font-size: clamp(17px, 4.8vw, 24px) !important; }
    .m-glass .n-desc   { font-size: 12px !important; }
    .m-glass .n-mod    { padding: 11px 0 !important; }
    .m-glass .n-mods::before { display: none !important; }
  }

  /* ── Card trigger button ── */
  .card-trigger {
    background: none; border: none; padding: 0;
    cursor: pointer; line-height: inherit;
    display: inline-flex; align-items: center; gap: 5px;
  }
  .card-icon { width: 13px; height: 13px; display: block; flex-shrink: 0; }

  /* ── QR Card Modal ── */
  #cardModal {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(250, 250, 248, 0.2);
    backdrop-filter: blur(28px) saturate(1.4);
    -webkit-backdrop-filter: blur(28px) saturate(1.4);
    align-items: center; justify-content: center;
    flex-direction: column; gap: 22px;
    padding: 24px;
  }
  #cardModal.open { display: flex; }

  #cardCanvas {
    display: block;
    border-radius: 10px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.14), 0 0 0 1px rgba(0,0,0,0.06);
    max-width: 100%;
    height: auto;
  }

  #cardClose {
    position: absolute; top: 22px; right: 26px;
    background: none; border: none; padding: 6px;
    cursor: pointer; color: rgba(255,255,255,0.4);
    transition: color 0.2s; line-height: 0;
  }
  #cardClose:hover { color: #fff; }
