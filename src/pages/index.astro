---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  { num: '01', title: 'Now',              desc: 'What I\'m doing and thinking about lately',           href: '/now' },
  { num: '02', title: 'Journey',          desc: 'Professional path & the person behind it',            href: '/career' },
  { num: '03', title: 'Decoding',         desc: 'Industry research, data analysis & market insights',  href: '/research' },
  { num: '04', title: 'Mountain Calling', desc: 'Landscape photography, hiking guides & alpine walks', href: '/photography' },
  { num: '05', title: 'Wandering',        desc: 'Personal growth, reflections & inner landscapes',     href: '/writing' },
  { num: '06', title: 'Reading List',     desc: 'Books, papers & ideas worth revisiting',              href: '/reading' },
];
---

<BaseLayout title="Home" description="Sisi — Making sense of numbers and landscapes." hideNav={true}>

  <div class="layout">

    <!-- ── Left identity panel ── -->
    <aside class="identity">
      <div class="identity-top">
        <div class="si-wrap">
          <span class="si-ghost" aria-hidden="true">Si</span>
          <h1 class="si">Si</h1>
        </div>
        <div class="si-rule">
          <span class="si-rule-a"></span>
          <span class="si-rule-b"></span>
        </div>
        <p class="tagline">Making sense of<br>numbers and landscapes.</p>
      </div>
      <div class="contact">
        <a class="contact-link" href="https://www.linkedin.com/in/sisi-z-9a4a6075/" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
            <rect width="24" height="24" rx="3" fill="rgba(255,255,255,0.25)"/>
            <path fill="#fff" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a class="contact-link" href="https://www.xiaohongshu.com/user/profile/111799574" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,0.7)" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.5 6.5h-2v1h2v1h-2v1h1.5c.828 0 1.5.672 1.5 1.5v1c0 .828-.672 1.5-1.5 1.5H13v1h-1v-1H9.5V15H13v-1h-1.5C10.672 14 10 13.328 10 12.5v-1C10 10.672 10.672 10 11.5 10H13V9h1v1h1.5v1zm-5 3.5c-.276 0-.5.224-.5.5v1c0 .276.224.5.5.5H12v-2h-1.5zm3 0v2H13v-2h-.5z"/>
          </svg>
          Red Note
        </a>
        <a class="contact-link" href="mailto:sisi.zhang.ch@gmail.com">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M2 7l10 7 10-7"/>
          </svg>
          Email
        </a>
      </div>
    </aside>

    <!-- ── Right modules panel ── -->
    <div class="modules-panel">
      <nav class="modules">
        {modules.map(m => (
          <a class="mod" href={m.href}>
            <span class="mod-num">{m.num}</span>
            <span class="mod-rule"></span>
            <span class="mod-body">
              <span class="mod-title">{m.title}</span>
              <span class="mod-desc">{m.desc}</span>
            </span>
            <span class="mod-arrow">→</span>
          </a>
        ))}
      </nav>
    </div>

  </div>

</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap');
</style>

<style>
  .layout {
    position: fixed;
    inset: 0;
    display: grid;
    grid-template-columns: 300px 1fr;
    overflow: hidden;
  }

  /* ── Identity panel ── */
  .identity {
    background: var(--rose);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 52px 40px 44px;
    position: relative;
    overflow: hidden;
  }

  /* Subtle decorative circle behind Si */
  .identity::before {
    content: '';
    position: absolute;
    bottom: -80px;
    right: -80px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    pointer-events: none;
  }
  .identity::after {
    content: '';
    position: absolute;
    bottom: -140px;
    right: -140px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.06);
    pointer-events: none;
  }

  .identity-top { position: relative; z-index: 1; }

  .si-wrap {
    position: relative;
    margin-bottom: 28px;
    line-height: 1;
  }

  .si-ghost {
    position: absolute;
    top: 55px;
    left: -20px;
    font-family: 'Great Vibes', cursive;
    font-size: clamp(130px, 18vw, 210px);
    font-weight: 300;
    font-style: italic;
    line-height: 0.85;
    color: rgba(255,255,255,0.15);
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .si {
    font-family: 'Great Vibes', cursive;
    font-size: clamp(90px, 12vw, 150px);
    font-weight: 400;
    font-style: italic;
    line-height: 0.85;
    color: #fff;
    margin: 0;
    letter-spacing: -0.03em;
    position: relative;
    z-index: 2;
    transform: translate(18px, 16px);
    text-shadow:
      2px 3px 0 rgba(120, 50, 75, 0.9),
      4px 6px 0 rgba(120, 50, 75, 0.75),
      6px 9px 0 rgba(120, 50, 75, 0.6),
      8px 12px 0 rgba(120, 50, 75, 0.45),
      10px 15px 0 rgba(120, 50, 75, 0.3),
      12px 18px 0 rgba(120, 50, 75, 0.15),
      14px 21px 16px rgba(0,0,0,0.2);
  }

  .si-rule {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 120px;
    margin-bottom: 18px;
  }
  .si-rule-a {
    display: block;
    width: 140px;
    height: 1px;
    background: rgba(255,255,255,0.75);
    margin-left: 0;
  }
  .si-rule-b {
    display: block;
    width: 140px;
    height: 1px;
    background: rgba(255,255,255,0.75);
    margin-left: 20px;
  }

  .tagline {
    font-family: var(--serif);
    font-size: clamp(18px, 1.6vw, 24px);
    font-weight: 300;
    font-style: italic;
    color: #fff;
    line-height: 1.6;
    margin: 0;
  }

  /* Contact */
  .contact {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    z-index: 1;
  }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-link:hover { color: #fff; }

  /* ── Modules panel ── */
  .modules-panel {
    background: var(--bg);
    display: flex;
    align-items: center;
    padding: 0 clamp(32px, 5vw, 72px);
    overflow: hidden;
  }

  .modules {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .mod {
    display: grid;
    grid-template-columns: 36px 1px 1fr auto;
    align-items: center;
    gap: 0 20px;
    padding: 18px 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
    border-radius: 8px;
    padding-left: 12px;
    padding-right: 12px;
    margin: 0 -12px;
  }
  .mod:first-child { border-top: 1px solid var(--rule); }
  .mod:hover { background: rgba(193,125,157,0.05); }

  .mod-num {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.18em;
    color: var(--rose);
    flex-shrink: 0;
  }

  .mod-rule {
    width: 1px;
    height: 28px;
    background: var(--rule);
    display: block;
    flex-shrink: 0;
  }

  .mod-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .mod-title {
    font-family: var(--serif);
    font-size: clamp(18px, 1.8vw, 24px);
    font-weight: 300;
    font-style: italic;
    color: var(--ink);
    line-height: 1.2;
    transition: color 0.2s;
  }
  .mod:hover .mod-title { color: var(--rose); }

  .mod-desc {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 300;
    color: var(--stone);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mod-arrow {
    font-size: 14px;
    color: var(--rule);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }
  .mod:hover .mod-arrow { transform: translateX(4px); color: var(--rose); }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .layout {
      position: static;
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      min-height: 100vh;
      overflow: visible;
    }

    .identity {
      padding: 40px 28px 36px;
      flex-direction: row;
      align-items: flex-end;
      gap: 24px;
    }
    .identity::before, .identity::after { display: none; }
    .identity-top { flex: 1; }

    .si, .si-full {
      font-size: clamp(64px, 16vw, 100px);
      display: inline;
    }
    .si-full { margin-bottom: 16px; }

    .contact {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 14px;
      align-items: flex-end;
    }

    .modules-panel {
      padding: 20px 20px 40px;
      align-items: flex-start;
    }

    .mod { padding: 16px 10px; margin: 0 -10px; gap: 0 14px; }
    .mod-title { font-size: clamp(17px, 4.5vw, 22px); }
    .mod-desc { font-size: 11px; }
  }

  @media (max-width: 480px) {
    .identity { flex-direction: column; align-items: flex-start; gap: 20px; }
    .contact { flex-direction: column; gap: 10px; }
    .mod-rule { height: 20px; }
  }
</style>
