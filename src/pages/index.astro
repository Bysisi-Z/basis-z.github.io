  <!-- ══════════════════════════════════════════════════════════
       SHARED JS  (clock · weather · greeting · lamp · search)
       ══════════════════════════════════════════════════════════ -->
  <script is:inline>
    // ── Day/night detection (runs after DOM is ready) ──
    var _preview = new URLSearchParams(location.search).get('preview');
    var _hour    = _preview === 'night' ? 20 : _preview === 'day' ? 10 : new Date().getHours();
    var _isDay   = _hour >= 6 && _hour < 18;
    if (window.innerWidth > 600) {
      document.getElementById(_isDay ? 'homeDay' : 'homeNight').style.display = 'flex';
    }

    const _pfx = _isDay ? 'd' : 'n';

    function gel(id) { return document.getElementById(_pfx + id); }

    // ── Greetings (morning 6–12 / afternoon 12–18 / evening 18–6) ──
    const _morningGreets = [
      'Good morning', '早上好', 'Guten Morgen', 'Bonjour', 'Buongiorno',
      'Buenos días', 'おはようございます', '좋은 아침', 'Goedemorgen', 'Bom dia',
      'God morgon', 'Доброе утро', 'Καλημέρα', 'Günaydın', 'صباح الخير', 'शुभ प्रभात',
    ];
    const _afternoonGreets = [
      'Good afternoon', '下午好', 'Guten Tag', 'Bon après-midi', 'Buon pomeriggio',
      'Buenas tardes', 'こんにちは', '좋은 오후', 'Goedemiddag', 'Boa tarde',
      'God eftermiddag', 'Добрый день', 'Καλό απόγευμα', 'İyi günler', 'مساء النور', 'नमस्ते',
    ];
    const _nightGreets = [
      'Good evening', '晚上好', 'Guten Abend', 'Bonsoir', 'Buona sera',
      'Buenas noches', 'こんばんは', '좋은 저녁', 'Goedenavond', 'Boa noite',
      'God kväll', 'Добрый вечер', 'Καλησπέρα', 'İyi akşamlar', 'مساء الخير', 'शुभ संध्या',
    ];
    const _greets = _hour >= 6 && _hour < 12 ? _morningGreets
                  : _hour >= 12 && _hour < 18 ? _afternoonGreets
                  : _nightGreets;
    const _greetEl = gel('Greeting');
    let _gi = 0;

    function _isChinese(s) { return /[一-鿿]/.test(s); }
    function _setGreet(t) {
      _greetEl.textContent = t;
      _greetEl.classList.toggle('zh', _isChinese(t));
    }
    function _nextGreet() {
      _greetEl.classList.remove('visible');
      _greetEl.addEventListener('transitionend', function _h() {
        _greetEl.removeEventListener('transitionend', _h);
        _setGreet(_greets[_gi % _greets.length]);
        _gi++;
        void _greetEl.offsetWidth;
        _greetEl.classList.add('visible');
        setTimeout(_nextGreet, 3600);
      }, { once: true });
    }
    setTimeout(function () {
      _setGreet(_greets[_gi % _greets.length]);
      _gi++;
      void _greetEl.offsetWidth;
      _greetEl.classList.add('visible');
      setTimeout(_nextGreet, 4200);
    }, 600);

    // ── Clock + date ──
    const DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    function updateClock() {
      var now = new Date();
      var h = String(now.getHours()).padStart(2,'0');
      var m = String(now.getMinutes()).padStart(2,'0');
      gel('Clock').textContent = h + ':' + m;
      gel('Dateline').textContent = DAYS[now.getDay()] + ' ' + MONTHS[now.getMonth()] + ' ' + now.getDate();
    }
    updateClock();
    setInterval(updateClock, 1000);

    // ── Mobile clock ──
    var _mT = document.getElementById('mTime'), _mD = document.getElementById('mDate');
    if (_mT) {
      function _mClock() {
        var n = new Date();
        _mT.textContent = String(n.getHours()).padStart(2,'0') + ':' + String(n.getMinutes()).padStart(2,'0');
        _mD.textContent = DAYS[n.getDay()] + ' ' + MONTHS[n.getMonth()] + ' ' + n.getDate();
      }
      _mClock(); setInterval(_mClock, 1000);
    }

    // ── Mobile lock screen: swipe up to dismiss (one-way, no return) ──
    (function() {
      var lock = document.querySelector('.m-lock');
      if (!lock) return;
      var _sy = 0;
      lock.addEventListener('touchstart', function(e) { _sy = e.touches[0].clientY; }, { passive: true });
      lock.addEventListener('touchend', function(e) {
        if (_sy - e.changedTouches[0].clientY > 40) lock.classList.add('dismissed');
      }, { passive: true });
      lock.addEventListener('wheel', function(e) { if (e.deltaY > 20) lock.classList.add('dismissed'); }, { passive: true });
      var hint = lock.querySelector('.m-swipe');
      if (hint) hint.addEventListener('click', function() { lock.classList.add('dismissed'); });
    })();

    // ── Dynamic weather messages ──
    var _PRECIP = new Set([51,53,55,61,63,65,71,73,75,77,80,81,82,85,86,95,96,99]);
    var _WM = {
      cold_dry: [
        '{city} is feeling a little chilly today. Stay warm.',
        'Looks like a cool one in {city} today. A warm cup of tea might be just the thing.',
        'Hope you\'re keeping cozy in {city} today.',
        'A crisp day in {city}. Don\'t forget an extra layer.',
        'Cooler weather has settled over {city} today. Take good care of yourself.',
        'Perfect weather in {city} to slow down for a moment.',
        'A day like this in {city} feels made for hot chocolate.',
        'Wishing you a warm and comfortable day in {city}.',
      ],
      cold_wet: [
        'Rain and cold have found {city} today. Don\'t forget your umbrella.',
        'A chilly, rainy day in {city}. Stay warm and dry.',
        'The weather in {city} is feeling a little moody. An umbrella might come in handy.',
        'Cold outside, rain overhead in {city}. Hope you\'re staying cozy.',
        'Perfect weather in {city} for a warm drink and a good umbrella.',
        'Even rainy days in {city} have their charm. Stay dry out there.',
        'Hope the weather in {city} is kinder than it looks. Take your umbrella.',
        'One of those days in {city} to enjoy the sound of the rain from somewhere warm.',
      ],
      nice_dry: [
        '{city} is looking lovely today.',
        'Looks like a beautiful day in {city}. Enjoy it if you can.',
        'The weather in {city} couldn\'t be much nicer today.',
        'Perfect weather in {city} for a little walk.',
        'Hope you get a chance to enjoy the fresh air in {city} today.',
        'Days like this in {city} don\'t ask for much—just a little time outside.',
        'The weather in {city} is just about perfect today.',
        'Wishing you a peaceful day in {city}, wherever you\'re headed.',
        'Something about the weather in {city} today quietly makes everything a little better.',
        'Enjoy every bit of today\'s sunshine in {city}.',
      ],
      nice_wet: [
        'A little rain has arrived in {city}. Don\'t forget your umbrella.',
        'Rainy in {city} today, but still a lovely day. Stay dry.',
        'Looks like you\'ll want an umbrella in {city} today.',
        'Hope the rain in {city} doesn\'t slow you down too much.',
        'A rainy day in {city} can be beautiful too. Enjoy it.',
        'Clouds over {city} today, but hopefully sunshine somewhere nearby.',
        'Worth keeping an umbrella close in {city} today, just in case.',
        'The weather in {city} has its own plans today. Hope yours go smoothly.',
        'Something about rainy days in {city} makes for the best conversations.',
        'Wishing you a cozy day in {city}, rain or shine.',
      ],
      hot_dry: [
        'It\'s getting warm in {city} today. Stay hydrated.',
        'Hope you\'re staying cool in {city} today.',
        'Perfect weather in {city} for a cold drink.',
        'A warm day like this in {city} feels made for an iced coffee.',
        'Perfect weather in {city} for an iced tea.',
        'Perfect weather in {city} for something cold and refreshing.',
        'The sun is making itself well known in {city} today.',
        'It\'s a hot one in {city} today — take it easy out there.',
        'A little shade goes a long way in {city} on a day like this.',
        'Wishing you a cool and refreshing day in {city}.',
      ],
      hot_wet: [
        'Warm weather and rain in {city} today—quite the combination. Don\'t forget your umbrella.',
        'It\'s warm in {city}, but you\'ll still want an umbrella today.',
        'Hope you\'re finding ways to stay cool and dry in {city} today.',
        'The weather in {city} can\'t quite make up its mind today.',
        'Perfect day in {city} for a cold drink and an umbrella.',
        'Summer showers have arrived in {city}. Hope you\'re prepared.',
        'Even warm days in {city} can surprise you. Take an umbrella just in case.',
        'Hope you\'re finding a cool place to take a break in {city} today.',
        'Rain or sunshine in {city}, I hope today treats you well.',
        'Wishing you a refreshing day in {city}, whatever the weather decides.',
      ],
    };
    function _pickWMsg(temp, code, city) {
      var wet = _PRECIP.has(code);
      var key = temp < 20 ? (wet ? 'cold_wet' : 'cold_dry')
              : temp <= 26 ? (wet ? 'nice_wet' : 'nice_dry')
              : (wet ? 'hot_wet' : 'hot_dry');
      var pool = _WM[key];
      return pool[Math.floor(Math.random() * pool.length)].replace(/\{city\}/g, city || 'Luzern');
    }

    // ── Weather ──
    var WMO = {
      0:['☀','Clear'], 1:['🌤','Mostly clear'], 2:['⛅','Partly cloudy'], 3:['☁','Overcast'],
      45:['🌫','Fog'], 48:['🌫','Fog'],
      51:['🌦','Drizzle'], 53:['🌦','Drizzle'], 55:['🌦','Drizzle'],
      61:['🌧','Rain'], 63:['🌧','Rain'], 65:['🌧','Heavy rain'],
      71:['🌨','Snow'], 73:['🌨','Snow'], 75:['❄','Heavy snow'],
      80:['🌦','Showers'], 81:['🌧','Showers'], 82:['🌧','Heavy showers'],
      95:['⛈','Thunderstorm'], 96:['⛈','Thunderstorm'], 99:['⛈','Thunderstorm'],
    };
    function fetchWeather(lat, lon, city) {
      fetch('https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&current=temperature_2m,weathercode&temperature_unit=celsius&timezone=auto')
        .then(function(r){ return r.json(); })
        .then(function(data){
          var temp = Math.round(data.current.temperature_2m);
          var code = data.current.weathercode;
          var ic = WMO[code] || ['🌡','Unknown'];
          gel('WeatherIcon').textContent = ic[0];
          gel('WeatherTemp').textContent = temp + '°C';
          gel('WeatherDesc').textContent = ic[1];
          gel('WeatherLoc').textContent  = city || 'Luzern';
          // Mobile lock screen
          var _mwi = document.getElementById('mWIcon');
          if (_mwi) {
            _mwi.textContent = ic[0];
            document.getElementById('mWTemp').textContent = temp + '°C';
            document.getElementById('mWDesc').textContent = ic[1];
            document.getElementById('mWLoc').textContent  = city || 'Luzern';
            var _mb = document.getElementById('mMsgBody');
            if (_mb) {
              var _wx = _pickWMsg(temp, code, city || 'Luzern');
              _mb.textContent = 'Hi! How\'s the day? ' + _wx + ' It\'s really wonderful to see you. I hope you enjoy everything here, and let\'s stay in touch!';
            }
          }
        }).catch(function(){});
    }
    function getCity(lat, lon) {
      return fetch('https://nominatim.openstreetmap.org/reverse?lat='+lat+'&lon='+lon+'&format=json&accept-language=en')
        .then(function(r){ return r.json(); })
        .then(function(d){ return d.address && (d.address.city || d.address.town || d.address.village || d.address.county) || ''; })
        .catch(function(){ return ''; });
    }
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(pos) {
          var lat = pos.coords.latitude, lon = pos.coords.longitude;
          getCity(lat, lon).then(function(city){ fetchWeather(lat, lon, city); });
        },
        function(){ fetchWeather(47.05, 8.31, 'Luzern'); }
      );
    } else {
      fetchWeather(47.05, 8.31, 'Luzern');
    }

    // ── Floor lamp (night only) ──
    if (!_isDay) {
      var _lampEl  = document.getElementById('nLamp');
      var _stripEl = document.getElementById('nStrip');
      _lampEl.addEventListener('click', function () {
        _stripEl.classList.toggle('n-lamp-on');
      });

      // ── Cat scratch easter egg ──
      var _catsEl   = document.getElementById('nCatsContainer');
      var _scratchA = document.getElementById('nScratchA');
      var _scratchB = document.getElementById('nScratchB');
      function _triggerScratch(el) {
        if (_stripEl.classList.contains('n-lamp-on')) return;
        el.classList.remove('n-scratch-active');
        void el.offsetWidth;
        el.classList.add('n-scratch-active');
        el.addEventListener('animationend', function _h() {
          el.classList.remove('n-scratch-active');
          el.removeEventListener('animationend', _h);
        });
      }
      _catsEl.addEventListener('click', function (e) {
        var rect = _catsEl.getBoundingClientRect();
        if (e.clientX < rect.left + rect.width / 2) {
          _triggerScratch(_scratchA);
        } else {
          _triggerScratch(_scratchB);
        }
      });
    }

    // ── QR Card Generator ──
    (function() {
      var _modal    = document.getElementById('cardModal');
      var _canvas   = document.getElementById('cardCanvas');
      var _dlBtn    = document.getElementById('cardDownload');
      var _closeBtn = document.getElementById('cardClose');
      if (!_modal) return;

      var _ctx, _W = 700, _H = 1050;
      var _qrSize = 300, _qrX = 200, _qrY = 395;

      function _openModal()  { _modal.classList.add('open'); _draw(); }
      function _closeModal() { _modal.classList.remove('open'); }

      _closeBtn.addEventListener('click', _closeModal);
      _modal.addEventListener('click', function(e){ if (e.target === _modal) _closeModal(); });
      document.addEventListener('keydown', function(e){ if (e.key === 'Escape') _closeModal(); });

      var _nb = document.getElementById('nCardBtn');
      var _db = document.getElementById('dCardBtn');
      if (_nb) _nb.addEventListener('click', _openModal);
      if (_db) _db.addEventListener('click', _openModal);

      _dlBtn.addEventListener('click', function() {
        var a = document.createElement('a');
        a.download = 'si-lens-card.png';
        a.href = _canvas.toDataURL('image/png');
        a.click();
      });

      function _rr(ctx, x, y, w, h, r) {
        ctx.beginPath();
        ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.arcTo(x+w,y,x+w,y+r,r);
        ctx.lineTo(x+w,y+h-r); ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
        ctx.lineTo(x+r,y+h); ctx.arcTo(x,y+h,x,y+h-r,r);
        ctx.lineTo(x,y+r); ctx.arcTo(x,y,x+r,y,r);
        ctx.closePath();
      }

      function _theme() {
        return _isDay ? {
          accent   : '#c17d9d',
          accentA  : 'rgba(193,125,157,0.4)',
          overlay  : 'rgba(238,243,240,0.86)',
          textMain : '#1A1A1A',
          textSub  : '#847B7B',
          divider  : '#E2DEDB',
          photo    : '/images/homepage-morning.jpg'
        } : {
          accent   : '#c17d9d',
          accentA  : 'rgba(193,125,157,0.4)',
          overlay  : 'rgba(228,220,240,0.86)',
          textMain : '#1A1A1A',
          textSub  : '#847B7B',
          divider  : '#E2DEDB',
          photo    : '/images/homepage-ferris-original.jpeg'
        };
      }

      function _loadQRLib() {
        return new Promise(function(resolve, reject) {
          if (window.QRCode) { resolve(); return; }
          var s = document.createElement('script');
          s.src = 'https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
          s.onload = resolve; s.onerror = reject;
          document.head.appendChild(s);
        });
      }

      function _drawContent(t) {
        var ctx = _ctx, cx = _W / 2;
        ctx.textAlign = 'center';

        // Si logo
        ctx.font = 'italic 400 110px "Great Vibes", cursive';
        ctx.fillStyle = t.accent;
        ctx.fillText('Si', cx, 172);

        // Accent line
        ctx.fillStyle = t.accentA;
        ctx.fillRect(cx - 44, 190, 88, 1.5);

        // Tagline — enlarged
        ctx.font = 'italic 300 32px "Cormorant Garamond", Georgia, serif';
        ctx.fillStyle = t.textMain;
        ctx.fillText('Making sense of numbers', cx, 260);
        ctx.fillText('and landscapes.', cx, 302);

        // Dividers
        ctx.fillStyle = t.divider;
        ctx.fillRect(60, 346, _W - 120, 1);
        ctx.fillRect(60, 756, _W - 120, 1);

        // Scan hint
        ctx.font = '300 15px "Inter", system-ui, sans-serif';
        ctx.fillStyle = t.textSub;
        ctx.fillText('scan to visit', cx, _qrY + _qrSize + 34);

        // URL — enlarged
        ctx.font = '300 32px "Inter", system-ui, sans-serif';
        ctx.fillStyle = t.accent;
        ctx.fillText('si-lens.me', cx, 862);

        // Copyright
        ctx.font = '300 13px "Inter", system-ui, sans-serif';
        ctx.fillStyle = t.textSub;
        ctx.fillText('© ' + new Date().getFullYear(), cx, 1016);
      }

      function _drawQR(t) {
        _loadQRLib().then(function() {
          var holder = document.createElement('div');
          holder.style.cssText = 'position:fixed;left:-9999px;top:0;width:' + _qrSize + 'px;';
          document.body.appendChild(holder);
          new QRCode(holder, {
            text: 'https://si-lens.me',
            width: _qrSize, height: _qrSize,
            colorDark: '#1A1A1A', colorLight: '#FAFAF8',
            correctLevel: QRCode.CorrectLevel.H
          });
          setTimeout(function() {
            var qrEl = holder.querySelector('canvas') || holder.querySelector('img');
            if (qrEl) {
              var ctx = _ctx;
              // White backing card behind QR
              ctx.fillStyle = '#FAFAF8';
              _rr(ctx, _qrX - 14, _qrY - 14, _qrSize + 28, _qrSize + 28, 16);
              ctx.fill();
              // QR code
              ctx.save();
              _rr(ctx, _qrX, _qrY, _qrSize, _qrSize, 8);
              ctx.clip();
              ctx.drawImage(qrEl, _qrX, _qrY, _qrSize, _qrSize);
              ctx.restore();
            }
            document.body.removeChild(holder);
            document.fonts.ready.then(function() { _drawContent(t); });
          }, 300);
        }).catch(function() {
          document.fonts.ready.then(function() { _drawContent(t); });
        });
      }

      function _draw() {
        var t = _theme();
        _canvas.width = _W; _canvas.height = _H;
        var dh = Math.min(520, window.innerHeight - 200);
        _canvas.style.height = dh + 'px';
        _canvas.style.width  = Math.round(dh * _W / _H) + 'px';
        _ctx = _canvas.getContext('2d');

        // Blurred photo background
        var img = new Image();
        img.onload = function() {
          var blur = 32;
          _ctx.filter = 'blur(' + blur + 'px)';
          var scale = Math.max((_W + blur*2) / img.width, (_H + blur*2) / img.height);
          var dw = _W + blur*2, dh2 = _H + blur*2;
          var sw = dw / scale, sh = dh2 / scale;
          var sx = (img.width - sw) / 2, sy = (img.height - sh) / 2;
          _ctx.drawImage(img, sx, sy, sw, sh, -blur, -blur, dw, dh2);
          _ctx.filter = 'none';
          _ctx.fillStyle = t.overlay;
          _ctx.fillRect(0, 0, _W, _H);
          _drawQR(t);
        };
        img.onerror = function() {
          _ctx.fillStyle = _isDay ? '#FAFAF8' : '#0F0A1E';
          _ctx.fillRect(0, 0, _W, _H);
          _drawQR(t);
        };
        img.src = t.photo;
      }
    })();

    // ── Search (day only) ──
    if (_isDay) {
      var _pf;
      var _si = document.getElementById('dSearchInput');
      var _sr = document.getElementById('dSearchResults');

      async function _initPF() {
        if (_pf) return;
        try { _pf = await import('/pagefind/pagefind.js'); await _pf.init(); }
        catch(e) { _pf = null; }
      }
      function _posResults() {
        var bar  = _si.closest('.d-search-bar');
        var rect = bar.getBoundingClientRect();
        var avH  = window.innerHeight - rect.bottom - 12;
        _sr.style.top      = (rect.bottom + 6) + 'px';
        _sr.style.left     = rect.left + 'px';
        _sr.style.width    = rect.width + 'px';
        _sr.style.maxHeight = Math.min(240, Math.max(80, avH)) + 'px';
      }
      async function _doSearch(q) {
        if (!q.trim()) { _sr.classList.remove('open'); return; }
        await _initPF();
        if (!_pf) {
          _sr.innerHTML = '<div class="d-sr-empty">Search unavailable.</div>';
          _posResults(); _sr.classList.add('open'); return;
        }
        try {
          var res = await _pf.search(q);
          var top = await Promise.all(res.results.slice(0,6).map(function(r){ return r.data(); }));
          _sr.innerHTML = '';
          if (!top.length) {
            _sr.innerHTML = '<div class="d-sr-empty">No results for "' + q + '".</div>';
          } else {
            top.forEach(function(r) {
              var a = document.createElement('a');
              a.className = 'd-sr-item';
              a.href = r.url;
              var title   = r.meta && r.meta.title || r.url;
              var excerpt = r.excerpt ? r.excerpt.replace(/<\/?mark>/g,'') : '';
              a.innerHTML = '<div class="d-sr-title">'+title+'</div>'
                + (excerpt ? '<div class="d-sr-excerpt">'+excerpt+'</div>' : '');
              _sr.appendChild(a);
            });
          }
          _posResults(); _sr.classList.add('open');
        } catch(e) {
          _sr.innerHTML = '<div class="d-sr-empty">Search error. Please retry.</div>';
          _posResults(); _sr.classList.add('open');
        }
      }
      var _dbt;
      _si.addEventListener('input', function(e) {
        clearTimeout(_dbt); _dbt = setTimeout(function(){ _doSearch(e.target.value); }, 220);
      });
      _si.addEventListener('focus', function(){ _initPF(); });
      window.addEventListener('resize', function(){
        if (_sr.classList.contains('open')) _posResults();
      });
      document.addEventListener('click', function(e){
        if (!e.target.closest('.d-search-wrap') && !e.target.closest('.d-search-results'))
          _sr.classList.remove('open');
      });
    }
  </script>

