---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  { num: '01', title: 'Journey',         href: '/career',       desc: 'Professional path & the person behind it' },
  { num: '02', title: 'Decoding',        href: '/research',     desc: 'Industry research, data analysis & market insights' },
  { num: '03', title: 'Mountain Calling',href: '/photography',  desc: 'Landscape photography, hiking guides & alpine adventures' },
  { num: '04', title: 'Wandering',       href: '/writing',      desc: 'Personal growth, reflections & inner landscapes' },
  { num: '05', title: 'More to Come',    href: '#',             desc: 'New chapters in the making', coming: true },
];
---

<BaseLayout title="Home" description="Sisi — Making sense of numbers and landscapes." hideNav={true}>

  <!-- ① HERO -->
  <div class="hero">
    <div class="hero-image">
      <div class="img-sky"></div>
      <div class="img-far"></div>
      <div class="img-near"></div>
      <div class="img-mist"></div>
      <div class="img-top-fade"></div>
      <div class="img-bottom-fade"></div>
    </div>

    <h1 class="site-name" id="site-name">
      <span class="s-first" id="s-first">S</span>isi
    </h1>

    <p class="tagline-overlay">Making sense of numbers and landscapes.</p>

    <div class="camera-rig" id="camera-rig">
      <div class="rope"></div>
      <svg class="camera-svg" viewBox="0 0 88 64" xmlns="http://www.w3.org/2000/svg">
        <rect x="8"  y="22" width="72" height="40" rx="5" fill="#D3BABD"/>
        <rect x="8"  y="16" width="18" height="46" rx="5" fill="#C4ABAE"/>
        <path d="M 34 22 L 34 9 L 44 4 L 54 9 L 54 22 Z" fill="#C9B2B5"/>
        <circle cx="22" cy="14" r="5"   fill="#B8A0A4"/>
        <circle cx="22" cy="14" r="3"   fill="#C9B2B5"/>
        <circle cx="68" cy="20" r="7"   fill="#B8A0A4"/>
        <circle cx="68" cy="20" r="4.5" fill="#C4ABAE"/>
        <line x1="68" y1="13" x2="68" y2="16" stroke="#D3BABD" stroke-width="1.2"/>
        <circle cx="50" cy="42" r="18" fill="#847B7B"/>
        <circle cx="50" cy="42" r="16" fill="#786E6E"/>
        <circle cx="50" cy="42" r="13" fill="#5C5454"/>
        <circle cx="50" cy="42" r="9"  fill="#3e3636"/>
        <circle cx="50" cy="42" r="5"  fill="#2a2424"/>
        <circle cx="44" cy="37" r="3.5" fill="rgba(255,255,255,0.22)"/>
        <circle cx="55" cy="46" r="1.5" fill="rgba(255,255,255,0.10)"/>
        <rect x="12" y="30" width="10" height="7" rx="2" fill="rgba(255,255,255,0.30)"/>
        <rect x="37" y="3"  width="14" height="4" rx="1" fill="#B8A0A4" opacity="0.7"/>
        <rect x="5"  y="26" width="5"  height="9" rx="2" fill="#B0979A"/>
        <rect x="78" y="26" width="5"  height="9" rx="2" fill="#B0979A"/>
        <line x1="8"  y1="42" x2="26" y2="42" stroke="#C4ABAE" stroke-width="0.6" opacity="0.5"/>
        <line x1="8"  y1="48" x2="26" y2="48" stroke="#C4ABAE" stroke-width="0.6" opacity="0.5"/>
        <line x1="8"  y1="54" x2="26" y2="54" stroke="#C4ABAE" stroke-width="0.6" opacity="0.5"/>
      </svg>
    </div>
  </div>

  <!-- ② MODULE CARDS -->
  <section class="cards-section">
    <div class="cards-grid">
      {modules.map(m => (
        <a class={`card${m.coming ? ' card--coming' : ''}`} href={m.href}>
          <div>
            <span class="card-num">{m.num}</span>
            <h2 class="card-title">{m.title}</h2>
            <p class="card-desc">{m.desc}</p>
          </div>
          <span class="card-arrow">↗</span>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Desktop: 1-screen no-scroll layout ── */
  html { height: 100%; overflow: hidden; }
  body { height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
  main { flex: 1; min-height: 0; display: flex; flex-direction: column; }

  /* ── HERO ── */
  .hero {
    position: relative;
    height: 38vh;
    flex-shrink: 0;
  }

  .hero-image {
    position: absolute;
    top: 36%; left: 0; right: 0; bottom: 0;
    z-index: 1; overflow: hidden;
  }
  .img-sky {
    position: absolute; inset: 0;
    background: linear-gradient(180deg,
      #cec8c4 0%, #c2bab6 20%, #bab0ac 40%,
      #c0b8b4 60%, #ccc4c0 80%, #d8d0cc 100%);
  }
  .img-far {
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 75%;
    background: linear-gradient(180deg, #a8a09c 0%, #948c88 55%, #807870 100%);
    clip-path: polygon(
      0% 100%, 0% 52%, 3% 38%, 6% 50%,
      9% 30%, 13% 46%, 17% 22%, 21% 40%,
      25% 16%, 29% 36%, 33% 14%, 37% 34%,
      41% 20%, 45% 38%, 49% 16%, 53% 36%,
      57% 22%, 61% 40%, 65% 26%, 69% 44%,
      73% 30%, 77% 48%, 81% 34%, 85% 52%,
      89% 38%, 93% 56%, 97% 42%, 100% 50%, 100% 100%);
  }
  .img-near {
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 52%;
    background: linear-gradient(180deg, #706864 0%, #605a56 60%, #504c48 100%);
    clip-path: polygon(
      0% 100%, 0% 62%, 4% 46%, 8% 60%,
      12% 38%, 16% 56%, 20% 30%, 24% 52%,
      28% 24%, 32% 48%, 36% 32%, 40% 54%,
      44% 28%, 48% 52%, 52% 34%, 56% 54%,
      60% 38%, 64% 58%, 68% 42%, 72% 60%,
      76% 44%, 80% 62%, 84% 48%, 88% 64%,
      92% 50%, 96% 66%, 100% 56%, 100% 100%);
  }
  .img-mist {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 130% 35% at 50% 50%,
      rgba(250,248,245,0.20) 0%, transparent 70%);
  }
  .img-top-fade {
    position: absolute;
    top: 0; left: 0; right: 0; height: 55%;
    background: linear-gradient(to bottom, var(--bg), transparent);
  }
  .img-bottom-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0; height: 45%;
    background: linear-gradient(to bottom, transparent, var(--bg));
  }

  .site-name {
    position: absolute;
    top: 4%;
    left: clamp(24px, 5vw, 72px);
    z-index: 2;
    font-family: var(--serif);
    font-size: clamp(72px, 17vh, 158px);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    white-space: nowrap;
    user-select: none;
    opacity: 0;
    animation: rise 0.9s ease 0.1s forwards;
  }
  .s-first { color: var(--rose); }

  .tagline-overlay {
    position: absolute;
    bottom: 20%;
    right: clamp(24px, 5vw, 72px);
    z-index: 2;
    font-family: var(--sans);
    font-size: clamp(10px, 1.15vw, 13px);
    font-weight: 300;
    letter-spacing: 0.13em;
    color: rgba(250,244,241,0.82);
    text-shadow: 0 1px 12px rgba(0,0,0,0.22);
    white-space: nowrap;
    opacity: 0;
    animation: rise 0.9s ease 0.5s forwards;
  }

  .camera-rig {
    position: absolute;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }
  .rope {
    width: 1.5px;
    height: clamp(28px, 4vh, 48px);
    background: linear-gradient(to bottom, var(--stone), var(--rose));
    border-radius: 1px;
  }
  .camera-svg {
    width:  clamp(52px, 7vw, 80px);
    height: clamp(38px, 5vw, 58px);
    filter: drop-shadow(0 3px 10px rgba(0,0,0,0.20))
            drop-shadow(0 1px 3px rgba(0,0,0,0.14));
  }

  /* ── CARDS ── */
  .cards-section {
    flex: 1;
    min-height: 0;
    padding: 12px clamp(24px, 5vw, 72px) 0;
    opacity: 0;
    animation: rise 0.9s ease 0.4s forwards;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: 1fr 1fr;
    gap: 10px;
    height: 100%;
  }

  .card:nth-child(1) { grid-column: span 2; }
  .card:nth-child(2) { grid-column: span 2; }
  .card:nth-child(3) { grid-column: span 2; }
  .card:nth-child(4) { grid-column: span 3; }
  .card:nth-child(5) { grid-column: span 3; }

  .card {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: clamp(16px, 2vh, 26px) clamp(18px, 2vw, 28px);
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    transition: border-color 0.28s ease, box-shadow 0.28s ease;
  }
  .card::after {
    content: '';
    position: absolute; inset: 0;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(211,186,189,0.09) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .card:hover { border-color: var(--rose); box-shadow: 0 4px 24px rgba(211,186,189,0.18); }
  .card:hover::after { opacity: 1; }

  .card--coming { border-style: dashed; }
  .card--coming:hover { border-style: dashed; }
  .card--coming .card-num,
  .card--coming .card-title,
  .card--coming .card-desc { opacity: 0.42; }

  .card-num {
    font-family: var(--sans);
    font-size: clamp(9px, 0.85vw, 11px);
    font-weight: 300;
    letter-spacing: 0.18em;
    color: var(--rose);
    display: block;
    margin-bottom: clamp(8px, 1.1vh, 14px);
  }
  .card-title {
    font-family: var(--serif);
    font-size: clamp(26px, 3.6vh, 46px);
    font-weight: 500;
    font-style: italic;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: clamp(6px, 0.8vh, 10px);
    transition: color 0.22s;
  }
  .card:hover .card-title { color: var(--stone); }
  .card-desc {
    font-family: var(--sans);
    font-size: clamp(9px, 0.9vw, 11px);
    font-weight: 300;
    color: var(--stone);
    line-height: 1.6;
  }
  .card-arrow {
    display: block;
    align-self: flex-end;
    font-size: clamp(13px, 1.6vh, 20px);
    color: var(--rule);
    margin-top: auto;
    padding-top: 8px;
    transition: color 0.22s, transform 0.22s;
  }
  .card:hover .card-arrow { color: var(--rose); transform: translate(4px, -3px); }

  /* ── Animation ── */
  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── MOBILE ≤ 768px ── */
  @media (max-width: 768px) {
    html { overflow: auto; height: auto; }
    body { height: auto; min-height: 100vh; overflow-x: hidden; }

    .hero { height: 38vh; }

    .site-name {
      font-size: clamp(58px, 19vw, 96px);
      left: 20px;
      top: 6%;
    }
    .tagline-overlay {
      left: 50%;
      right: auto;
      transform: translateX(-50%);
      bottom: 13%;
      font-size: 9.5px;
      letter-spacing: 0.1em;
    }
    .rope       { height: 22px; }
    .camera-svg { width: 46px; height: 34px; }

    .cards-section { flex: none; padding: 14px 16px 0; }

    .cards-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      gap: 10px;
      height: auto;
    }
    .card:nth-child(n) { grid-column: span 1; }

    .card {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      padding: 18px 20px;
      min-height: 80px;
    }
    .card > div { flex: 1; min-width: 0; }
    .card-num   { font-size: 9px; margin-bottom: 4px; }
    .card-title {
      font-size: clamp(22px, 5.6vw, 30px);
      margin-bottom: 3px;
    }
    .card-title :global(br) { display: none; }
    .card-desc {
      font-size: 10px;
      line-height: 1.5;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .card-arrow {
      flex-shrink: 0;
      margin-top: 0;
      padding-top: 0;
      align-self: center;
      font-size: 15px;
    }
  }

  /* ── Small phones ≤ 390px ── */
  @media (max-width: 390px) {
    .hero           { height: 34vh; }
    .site-name      { font-size: clamp(50px, 17vw, 72px); }
    .tagline-overlay { display: none; }
    .card-title     { font-size: 20px; }
    .card-desc      { display: none; }
    .card           { min-height: 68px; padding: 14px 16px; }
  }
</style>

<script>
  function positionCamera() {
    const s    = document.getElementById('s-first');
    const rig  = document.getElementById('camera-rig');
    const hero = document.querySelector('.hero');
    if (!s || !rig || !hero) return;

    const sRect    = s.getBoundingClientRect();
    const heroRect = hero.getBoundingClientRect();

    rig.style.left = (sRect.left - heroRect.left + sRect.width * 0.38) + 'px';
    rig.style.top  = (sRect.bottom - heroRect.top - 2) + 'px';
  }

  document.fonts.ready.then(() => {
    requestAnimationFrame(() => requestAnimationFrame(positionCamera));
  });
  window.addEventListener('resize', positionCamera);
</script>
