---
import BaseLayout from '../layouts/BaseLayout.astro';

const experiences = [
  {
    company: 'Organon',
    role: 'Associate Director, Global Analytics & Insights',
    period: '06/2022 — Present',
    bullets: [
      'Synthesized market, competitive, and performance intelligence into executive-level insights, informing strategic discussions and decision-making at CEO and Board level.',
      'Built and institutionalized the global floor price assessment capability, establishing it as a core pillar of global pricing management.',
      'Led two waves of GM-sponsored BD screening (20,000+ marketed, 2,000+ late-stage assets), identifying 33 shortlisted and 11 priority opportunities. Scaled the methodology into a structured decision framework to enable faster and more informed early-stage investment decisions.',
      'Selected for a year-long strategic assignment supporting late-stage BD transactions through valuation modeling, scenario analysis, and commercial assessments, informing deal structure and negotiation strategy.',
      'Built and scaled a global tender analytics capability from scratch, covering 50+ countries and enabling systematic assessment of pricing, access, and competitive risks, particularly in biosimilar-driven markets.',
      'Acted as a key liaison between commercial stakeholders and Global Analytics & Insights team, aligning business questions with analytics, payer, and market research capabilities to support pricing and market access decision-making.',
    ],
  },
  {
    company: 'MSD',
    role: 'Assoc. Analysis Manager → Analysis Manager → Sr. Strategic Planning Manager',
    period: '01/2018 — 06/2022',
    bullets: [
      'Built a COVID-19 business tracking and forecasting framework in a highly uncertain environment, providing a critical decision-making foundation for performance monitoring that remained in use through the Organon spin-off.',
      'Invited as a regular contributor to GM-1 leadership weekly reviews, shaping executive decision-making and global performance discussions.',
      'Designed and launched MSD China\'s first enterprise-wide business tracking platform, creating a single source of truth for KPI alignment; led adoption campaigns driving rollout to 3,000+ users across the organization.',
      'Acted as analytics partner to the vaccines business (largest BU), developing competitive intelligence frameworks to support strategy planning in a highly data-constrained environment.',
    ],
  },
  {
    company: 'Sanofi',
    role: 'Business Analyst → National Analysis Supervisor',
    period: '03/2014 — 12/2017',
    bullets: [
      'Acted as a strategic advisor to the Commercial Head, aligning cross-functional inputs to ensure decision readiness on critical topics.',
      'Entrusted with delegated authority across business operations, making and executing decisions related to field force deployment, resource allocation, and commercial planning.',
      'Led a matrix team of 12 (4 Business Analysts, 8 Business Operations Specialists) supporting a 1,000+ person commercial organization, building analytics-driven decision models across territory design, FTE allocation, budget allocation and sales forecasting.',
      'Led commercial and marketing resource planning and governance for the franchise through a team of BOS, supporting investment decisions and ensuring budget discipline and compliance.',
      'Led commercial transformation initiatives (e.g., reorganization, new product launch), navigating competing stakeholder priorities and driving alignment in complex and fast-changing environment.',
      'Coached analytics, operations, and commercial teams to adopt structured, data-driven decision-making practices.',
    ],
  },
  {
    company: 'Cisco',
    role: 'Business Analyst',
    period: '09/2012 — 03/2014',
    bullets: [],
  },
  {
    company: 'LG Electronics',
    role: 'Supply & Analysis Specialist',
    period: '07/2011 — 09/2012',
    bullets: [],
  },
];

const capabilities = [
  'Commercial Insights & Analytics',
  'Strategic Planning',
  'Forecasting & Scenario Planning',
  'Competitive Intelligence',
  'Business Development Evaluation',
  'Pricing & Market Access Analytics',
  'Commercial Performance Management',
  'Executive Decision Support',
  'Power BI',
  'Excel Modeling',
  'Market Research',
  'Cross-functional Leadership',
];
---

<BaseLayout title="CV" description="Commercial Insights and Strategy professional with 12+ years in pharmaceutical analytics and executive decision support.">

  <div class="wrap">

    <header class="page-header">
      <div class="header-inner">
        <div class="profile-photo-wrap">
          <img src="/images/profile.jpg" alt="Giselle" class="profile-photo" />
        </div>
        <div class="header-text">
          <p class="summary">
            Commercial Insights and Strategy professional with 12+ years of experience across commercial operations, strategic analytics, and global portfolio decision support within the pharmaceutical industry. Proven track record of translating complex business questions into actionable insights and scalable decision frameworks, supporting executive decision-making across country, regional, and global organizations.
          </p>
        </div>
      </div>
    </header>

    <section class="cv-section">
      <h2 class="section-label">Work Experience</h2>
      <div class="exp-list">
        {experiences.map(exp => (
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-company">{exp.company}</span>
              <span class="exp-period">{exp.period}</span>
            </div>
            <p class="exp-role">{exp.role}</p>
            {exp.bullets.length > 0 && (
              <ul class="exp-bullets">
                {exp.bullets.map(b => <li>{b}</li>)}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>

    <section class="cv-section">
      <h2 class="section-label">Education</h2>
      <div class="edu-item">
        <span class="exp-company">Southwestern University of Finance and Economics</span>
        <p class="exp-role">Bachelor of Business Administration</p>
      </div>
    </section>

    <section class="cv-section cv-section--last">
      <h2 class="section-label">Core Capabilities</h2>
      <div class="caps-grid">
        {capabilities.map(c => <span class="cap-tag">{c}</span>)}
      </div>
    </section>

  </div>

</BaseLayout>

<style>
  .wrap {
    max-width: 1078px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 80px);
  }

  /* ── Header ── */
  .page-header {
    padding-top: 64px;
    padding-bottom: 28px;
    border-bottom: none;
  }
  .header-inner {
    display: flex;
    align-items: flex-end;
    gap: 40px;
  }
  .profile-photo-wrap {
    flex-shrink: 0;
    width: 220px;
    height: 287px;
    border-radius: 10px;
    overflow: hidden;
  }
  .profile-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .header-text {
    flex: 1;
    padding-top: 4px;
  }
  .location {
    font-family: var(--sans);
    font-size: 11px; font-weight: 300;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--stone);
    margin-bottom: 14px;
  }
  .summary {
    font-family: var(--serif);
    font-size: clamp(18px, 1.7vw, 22px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.75;
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .header-inner { flex-direction: column; gap: 20px; }
    .profile-photo-wrap { width: 90px; height: 90px; }
  }

  /* ── Sections ── */
  .cv-section {
    padding: 32px 0 8px;
  }
  .cv-section--last {
    border-bottom: none;
    padding-bottom: 100px;
  }
  .section-label {
    font-family: var(--serif);
    font-size: clamp(17px, 1.6vw, 20px);
    font-weight: 700; font-style: italic;
    letter-spacing: 0.02em;
    color: #fff;
    background: var(--rose);
    display: block;
    padding: 8px 20px;
    border-radius: 6px;
    margin-bottom: 32px;
  }

  /* ── Experience ── */
  .exp-list { display: flex; flex-direction: column; gap: 16px; }
  .exp-item {
    background: rgba(193,125,157,0.05);
    border-radius: 12px;
    padding: 24px 28px;
    border-left: 3px solid rgba(193,125,157,0.3);
  }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 6px;
  }
  .exp-company {
    font-family: var(--sans);
    font-size: clamp(14px, 1.3vw, 16px); font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--rose);
  }
  .exp-period {
    font-family: var(--sans);
    font-size: 12px; font-weight: 700;
    color: var(--stone);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .exp-role {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 21px);
    font-weight: 400; font-style: italic;
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: 16px;
  }

  /* ── Bullets ── */
  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-left: 16px;
    border-left: 1.5px solid rgba(193,125,157,0.25);
  }
  .exp-bullets li {
    font-family: var(--sans);
    font-size: clamp(13.5px, 1.1vw, 15px); font-weight: 300;
    line-height: 1.8;
    color: var(--ink);
    position: relative;
    padding-left: 18px;
  }
  .exp-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--rose);
    font-size: 11px;
    top: 4px;
  }

  /* ── Education ── */
  .edu-item .exp-role { margin-bottom: 0; }

  /* ── Capabilities ── */
  .caps-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .cap-tag {
    font-family: var(--sans);
    font-size: 15px; font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--ink);
    border: 1px solid rgba(193,125,157,0.45);
    border-radius: 20px;
    padding: 5px 14px;
    line-height: 1;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .exp-header { flex-direction: column; gap: 2px; }
    .exp-period { font-size: 10px; }
  }
</style>
