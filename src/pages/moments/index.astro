  /* ── Responsive ── */
  @media (max-width: 900px) {
    .scatter-grid { flex-wrap: wrap; gap: 28px; }
    .scatter-col { flex: 1 1 calc(50% - 14px); }
    .scatter-col:nth-child(2) { margin-top: 0; }
    .scatter-col:nth-child(3) { margin-top: 0; flex-basis: 100%; }
  }

  @media (max-width: 560px) {
    .scatter-grid { flex-direction: column; gap: 20px; padding-top: 36px; }
    .scatter-col { flex: none; width: 100%; }
    .scatter-col:nth-child(2),
    .scatter-col:nth-child(3) { margin-top: 0; }
    .scatter-col .card { transform: rotate(0deg); }
    .scatter-col:nth-child(odd)  .card { transform: rotate(-0.5deg); }
    .scatter-col:nth-child(even) .card { transform: rotate(0.5deg); }
  }
</style>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.scatter-col .card'));
  let focused: HTMLElement | null = null;

  function focusCard(card: HTMLElement) {
    if (focused === card) { resetAll(); return; }
    focused = card;
    cards.forEach(c => {
      c.classList.remove('card-focused', 'card-dimmed');
      c.classList.add(c === card ? 'card-focused' : 'card-dimmed');
    });
  }

  function resetAll() {
    focused = null;
    cards.forEach(c => c.classList.remove('card-focused', 'card-dimmed'));
  }

  cards.forEach(card => card.addEventListener('click', e => {
    e.stopPropagation();
    focusCard(card);
  }));

  document.addEventListener('click', () => { if (focused) resetAll(); });
</script>

