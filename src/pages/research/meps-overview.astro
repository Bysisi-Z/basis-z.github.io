<script>
{
  const switcher = document.getElementById('lang-switcher');
  if (switcher) {
    const btns = switcher.querySelectorAll('.ls-btn');
    const saved = localStorage.getItem('sisi-article-lang') || 'en';
    if (saved !== 'en') {
      document.documentElement.dataset.lang = saved;
      btns.forEach(b => b.classList.toggle('ls-active', (b as HTMLElement).dataset.lang === saved));
    }
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const lang = (btn as HTMLElement).dataset.lang!;
        document.documentElement.dataset.lang = lang;
        localStorage.setItem('sisi-article-lang', lang);
        btns.forEach(b => b.classList.toggle('ls-active', b === btn));
      });
    });
  }
}
</script>
