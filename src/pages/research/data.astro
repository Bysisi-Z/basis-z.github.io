<script>
{
  const gate = document.getElementById('mobile-gate');
  const btn  = document.getElementById('mobile-gate-btn');
  if (gate && btn) {
    if (sessionStorage.getItem('nsfg-mobile-gate-dismissed')) {
      gate.classList.add('dismissed');
    }
    btn.addEventListener('click', () => {
      sessionStorage.setItem('nsfg-mobile-gate-dismissed', '1');
      gate.classList.add('dismissed');
    });
  }
}
</script>

<script>
(async () => {

// ── Tab display names (descriptive, no letters) ───────────────────────────────
const TAB_SHORT = {
  screener:       'Screener',
  section_a:      'Demographics',
  section_b:      'Pregnancy & Birth',
  section_c:      'Relationships',
  section_d:      'Sterilization & Fecundity',
  section_e:      'Contraception',
  section_f:      'Family Planning',
  section_g:      'Birth Intentions',
  section_h:      'Reproductive Health',
  section_j:      'CASI / CAWI',
  recodes:        'Recodes',
  sample_design:  'Sample Design',
};

const BAR_COLOR   = '#c17d9d';
const INAPP_COLOR = '#E2DEDB';

const ALL_AGE_GROUPS = ['15–19','20–24','25–29','30–34','35–39','40–44','45–50'];

// ── State ─────────────────────────────────────────────────────────────────────
let META          = null;
let sectionCache  = {};
let currentSec    = null;
let currentVar    = null;
let filteredVars  = [];
let ageCounts     = null;    // loaded lazily
let ageGroupSplit = false;   // toggle state
let activeTypeFilter = 'raw';
let groups     = null;
let varToGroup = null;

// ── DOM refs ──────────────────────────────────────────────────────────────────
const secTabsEl   = document.getElementById('section-tabs');
const varListEl   = document.getElementById('var-list');
const varCountEl  = document.getElementById('var-count');
const loadingEl   = document.getElementById('loading-badge');
const searchEl    = document.getElementById('var-search');
const detailEmpty = document.getElementById('detail-empty');
const detailContent = document.getElementById('detail-content');

// ── Fetch helpers ─────────────────────────────────────────────────────────────
async function fetchJSON(url) {
  const r = await fetch(url);
  if (!r.ok) throw new Error(`HTTP ${r.status}: ${url}`);
  return r.json();
}

// ── Load meta on boot ─────────────────────────────────────────────────────────
try {
  META = await fetchJSON('/data/nsfg_meta.json');
} catch(e) {
  secTabsEl.textContent = 'Error loading data.';
  return;
}

buildSectionTabs();
initTabsArrow();
initAgeToggle();
initTypeFilter();
// Load age counts in background — ready by the time user opens the toggle
fetchJSON('/data/nsfg_age_counts.json').then(d => { ageCounts = d; }).catch(() => {});
fetchJSON('/data/nsfg_groups.json').then(d => { groups = d.groups; varToGroup = d.var_to_group; }).catch(() => {});
await selectSection(META.sections[0].key);

// ── Section tabs ──────────────────────────────────────────────────────────────
function buildSectionTabs() {
  META.sections.forEach(sec => {
    const btn = document.createElement('button');
    btn.className    = 'sec-tab';
    btn.dataset.key  = sec.key;
    btn.textContent  = TAB_SHORT[sec.key] || sec.key;
    btn.title        = sec.label + ` (${sec.n_vars} vars)`;
    btn.setAttribute('role', 'tab');
    btn.addEventListener('click', () => selectSection(sec.key));
    secTabsEl.appendChild(btn);
  });
}

function setActiveTab(key) {
  secTabsEl.querySelectorAll('.sec-tab').forEach(b => {
    b.classList.toggle('active', b.dataset.key === key);
  });
}

// ── Tabs scroll arrows (left + right) ────────────────────────────────────────
function initTabsArrow() {
  const btnL = document.getElementById('tabs-arrow-left');
  const btnR = document.getElementById('tabs-arrow-right');
  if (!btnL || !btnR) return;

  function sync() {
    const overflows = secTabsEl.scrollWidth > secTabsEl.clientWidth + 2;
    const atStart   = secTabsEl.scrollLeft <= 2;
    const atEnd     = secTabsEl.scrollLeft + secTabsEl.clientWidth >= secTabsEl.scrollWidth - 4;
    btnL.hidden = !overflows || atStart;
    btnR.hidden = !overflows || atEnd;
  }

  btnL.addEventListener('click', () => secTabsEl.scrollBy({ left: -220, behavior: 'smooth' }));
  btnR.addEventListener('click', () => secTabsEl.scrollBy({ left:  220, behavior: 'smooth' }));
  secTabsEl.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', sync);

  // Layout may not be settled at first rAF — check after paint AND after a short delay
  requestAnimationFrame(() => requestAnimationFrame(sync));
  setTimeout(sync, 200);
  window.addEventListener('load', sync);
}

// ── Type filter chips ─────────────────────────────────────────────────────────
function initTypeFilter() {
  document.querySelectorAll('.type-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      activeTypeFilter = btn.dataset.type;
      document.querySelectorAll('.type-chip').forEach(b =>
        b.classList.toggle('active', b === btn)
      );
      renderVarList(sectionCache[currentSec] || []);
    });
  });
}

function matchesTypeFilter(v) {
  if (activeTypeFilter === 'all') return true;
  if (activeTypeFilter === 'raw') return v.variable_type === 'raw';
  if (activeTypeFilter === 'recode') return v.variable_type === 'recode';
  if (activeTypeFilter === 'computed') return (v.variable_type || '').startsWith('computed');
  return true;
}

// ── Age split toggle ──────────────────────────────────────────────────────────
function initAgeToggle() {
  const cb = document.getElementById('age-split-cb');
  if (!cb) return;
  cb.addEventListener('change', () => {
    ageGroupSplit = cb.checked;
    if (currentVar) renderDetail(currentVar);
  });
}

// ── Build split-by-age-group HTML for valid codes ─────────────────────────────
function makeAgeSplitRows(v) {
  const varCounts = ageCounts?.[v.name];
  const validCodes = (v.distribution || []).filter(d => !d.inapplicable);

  return validCodes.map(d => {
    const groupRows = ALL_AGE_GROUPS.map(grp => {
      const grpCounts = varCounts?.[grp] || {};
      const cnt   = grpCounts[d.value] || 0;
      const n_uni = Object.entries(grpCounts)
        .filter(([k]) => k !== '.')
        .reduce((s, [, c]) => s + c, 0);
      const pct = n_uni > 0 ? Math.round(cnt / n_uni * 1000) / 10 : 0;
      return `<div class="dist-age-row">
        <span class="dist-age-tag">${grp}</span>
        <div class="dist-bar-track">
          <div class="dist-bar-fill" style="width:0%;background:${BAR_COLOR}" data-w="${pct}%"></div>
        </div>
        <span class="dist-age-pct">${pct}%</span>
      </div>`;
    }).join('');

    return `<div class="dist-row-split">
      <div class="dist-split-header">
        ${escHtml(d.label)}<span class="dist-val-code">${escHtml(d.value)}</span>
      </div>
      <div class="dist-age-bars">${groupRows}</div>
    </div>`;
  }).join('');
}

// ── Section selection ─────────────────────────────────────────────────────────
async function selectSection(key) {
  if (currentSec === key && sectionCache[key]) {
    renderVarList(sectionCache[key]);
    return;
  }
  currentSec = key;
  setActiveTab(key);
  currentVar = null;
  showEmpty();
  searchEl.value = '';

  // Load section data
  if (!sectionCache[key]) {
    loadingEl.hidden = false;
    try {
      sectionCache[key] = await fetchJSON(`/data/nsfg_section_${key}.json`);
    } catch(e) {
      varCountEl.textContent = 'Load error';
      loadingEl.hidden = true;
      return;
    }
    loadingEl.hidden = true;
  }

  renderVarList(sectionCache[key]);
}

// ── Variable list ─────────────────────────────────────────────────────────────
function renderVarList(vars) {
  const query = searchEl.value.toLowerCase().trim();

  // ── Global search: query across all sections from META ──────────────────────
  if (query && META) {
    const results = [];
    META.sections.forEach(sec => {
      sec.variables.forEach(v => {
        if (
          (v.name.toLowerCase().includes(query) || v.label.toLowerCase().includes(query)) &&
          matchesTypeFilter(v)
        ) {
          results.push({ ...v, _secKey: sec.key, _secLabel: sec.label });
        }
      });
    });
    filteredVars = results;
    varCountEl.textContent = `${results.length} result${results.length !== 1 ? 's' : ''} — all sections`;

    const frag = document.createDocumentFragment();
    results.forEach(v => {
      const item = document.createElement('div');
      item.className   = 'var-item' + (currentVar?.name === v.name ? ' selected' : '');
      item.dataset.name    = v.name;
      item.dataset.secKey  = v._secKey;
      item.setAttribute('role', 'option');
      item.innerHTML =
        `<span class="var-item-label">${escHtml(v.label)}</span>` +
        `<span class="var-item-bottom">` +
          `<span class="var-item-name">${v.name}</span>` +
          `<span class="var-item-type ${typeClass(v.variable_type)}">${v.variable_type || '—'}</span>` +
        `</span>` +
        `<span class="var-item-section">${escHtml(shortSecName(v._secLabel))}</span>`;
      item.addEventListener('click', () => selectVarGlobal(v._secKey, v.name));
      frag.appendChild(item);
    });
    varListEl.innerHTML = '';
    varListEl.appendChild(frag);
    return;
  }

  // ── Section search: filter within current section ───────────────────────────
  filteredVars = (vars || []).filter(v =>
    matchesTypeFilter(v) &&
    (!query || v.name.toLowerCase().includes(query) || v.label.toLowerCase().includes(query))
  );
  varCountEl.textContent = `${filteredVars.length} variable${filteredVars.length !== 1 ? 's' : ''}`;

  const frag = document.createDocumentFragment();
  filteredVars.forEach(v => {
    const item = document.createElement('div');
    item.className  = 'var-item' + (currentVar?.name === v.name ? ' selected' : '');
    item.dataset.name = v.name;
    item.setAttribute('role', 'option');
    item.innerHTML =
      `<span class="var-item-label">${escHtml(v.label)}</span>` +
      `<span class="var-item-bottom">` +
        `<span class="var-item-name">${v.name}</span>` +
        `<span class="var-item-type ${typeClass(v.variable_type)}">${v.variable_type || '—'}</span>` +
      `</span>`;
    item.addEventListener('click', () => selectVar(v.name));
    frag.appendChild(item);
  });
  varListEl.innerHTML = '';
  varListEl.appendChild(frag);
}

// ── Click a global search result: load section if needed, then show detail ────
async function selectVarGlobal(secKey, varName) {
  if (!sectionCache[secKey]) {
    loadingEl.hidden = false;
    try {
      sectionCache[secKey] = await fetchJSON(`/data/nsfg_section_${secKey}.json`);
    } catch(e) {
      loadingEl.hidden = true;
      return;
    }
    loadingEl.hidden = true;
  }

  // Update active tab to reflect the variable's section
  currentSec = secKey;
  setActiveTab(secKey);

  const varData = sectionCache[secKey].find(v => v.name === varName);
  if (!varData) return;

  currentVar = varData;
  varListEl.querySelectorAll('.var-item').forEach(el => {
    el.classList.toggle('selected', el.dataset.name === varName);
  });
  renderDetail(varData);
}

// ── Helper: derive a short readable section name from the full label ───────────
function shortSecName(label) {
  return label.replace(/^SECTION\s+[A-Z]:\s*/i, '').split(';')[0].trim();
}

// ── Search ────────────────────────────────────────────────────────────────────
searchEl.addEventListener('input', () => {
  // Always re-render: global mode if query, section mode if empty
  renderVarList(sectionCache[currentSec] || []);
});

// ── Variable selection ────────────────────────────────────────────────────────
function selectVar(name) {
  const secData = sectionCache[currentSec];
  if (!secData) return;
  const varData = secData.find(v => v.name === name);
  if (!varData) return;

  currentVar = varData;

  // Highlight selected
  varListEl.querySelectorAll('.var-item').forEach(el => {
    el.classList.toggle('selected', el.dataset.name === name);
  });

  renderDetail(varData);
}

// ── Group view ────────────────────────────────────────────────────────────────
async function renderGroupView(groupId, fromVar) {
  const group = groups?.[groupId];
  if (!group) return;

  // Load section if not cached
  if (!sectionCache[group.section]) {
    loadingEl.hidden = false;
    try {
      sectionCache[group.section] = await fetchJSON(`/data/nsfg_section_${group.section}.json`);
    } catch(e) { loadingEl.hidden = true; return; }
    loadingEl.hidden = true;
  }

  const secData = sectionCache[group.section];
  const varDatas = group.vars.map(name => secData.find(v => v.name === name)).filter(Boolean);

  // Derive title using majority-prefix algorithm
  const title = majorityLabelPrefix(varDatas.map(v => v.label));

  // Aggregate distribution by response code across all vars (exclude inapplicable)
  const tally = new Map();
  for (const vd of varDatas) {
    for (const d of (vd.distribution || [])) {
      if (d.inapplicable) continue;
      if (!tally.has(d.value)) tally.set(d.value, { label: d.label, value: d.value, n: 0 });
      tally.get(d.value).n += d.n;
    }
  }
  const aggregated = [...tally.values()].sort((a, b) => b.n - a.n);
  const maxN = Math.max(...aggregated.map(r => r.n), 1);
  const totalMentions = aggregated.reduce((s, r) => s + r.n, 0);

  const rowsHtml = aggregated.map(r => {
    const w = (r.n / maxN * 100).toFixed(1);
    return `<div class="gv-row" style="grid-template-columns:1fr 180px 80px">
      <div class="gv-label">${escHtml(r.label)}<span class="dist-val-code">${escHtml(r.value)}</span></div>
      <div class="dist-bar-track">
        <div class="dist-bar-fill" style="width:0%;background:${BAR_COLOR}" data-w="${w}%"></div>
      </div>
      <div class="gv-n">${r.n.toLocaleString()}</div>
    </div>`;
  }).join('');

  detailEmpty.hidden   = true;
  detailContent.hidden = false;

  detailContent.innerHTML =
    `<div class="gv-header">
       <button class="gv-back-btn">← Back to ${escHtml(fromVar.name)}</button>
       <div class="gv-title-row">
         <span class="gv-qcode">${escHtml(group.qcode)}</span>
         <h2 class="gv-title">${escHtml(title)}</h2>
       </div>
       <div class="gv-count">${group.n_vars} variables · ${totalMentions.toLocaleString()} total mentions</div>
     </div>
     <div class="gv-body">${rowsHtml}</div>`;

  // Back: restore single selection and original detail
  detailContent.querySelector('.gv-back-btn').addEventListener('click', () => {
    varListEl.querySelectorAll('.var-item').forEach(el => {
      el.classList.toggle('selected', el.dataset.name === fromVar.name);
    });
    renderDetail(fromVar);
  });

  // Switch left panel to group's section and highlight all group vars
  await switchVarListToSection(group.section);
  const groupVarSet = new Set(group.vars);
  varListEl.querySelectorAll('.var-item').forEach(el => {
    el.classList.toggle('selected', groupVarSet.has(el.dataset.name));
  });

  requestAnimationFrame(() => requestAnimationFrame(() => {
    detailContent.querySelectorAll('.dist-bar-fill').forEach(el => {
      el.style.width = el.dataset.w;
    });
  }));
}

// Switch the left var-list panel to a section without touching the detail panel
async function switchVarListToSection(key) {
  if (!sectionCache[key]) {
    loadingEl.hidden = false;
    try {
      sectionCache[key] = await fetchJSON(`/data/nsfg_section_${key}.json`);
    } catch(e) { loadingEl.hidden = true; return; }
    loadingEl.hidden = true;
  }
  currentSec = key;
  setActiveTab(key);
  searchEl.value = '';
  renderVarList(sectionCache[key]);
}

// Longest prefix shared by >= 60% of labels (handles outlier variables in a group)
function majorityLabelPrefix(labels) {
  if (!labels.length) return '';
  if (labels.length === 1) return labels[0].replace(/[\s\-(–,;:]+$/, '').trim();

  const threshold = Math.ceil(labels.length * 0.6);
  let best = '';

  for (const base of labels) {
    // Binary search: longest prefix of `base` shared by >= threshold labels
    let lo = 0, hi = base.length;
    while (lo < hi) {
      const mid = (lo + hi + 1) >> 1;
      const cand = base.slice(0, mid);
      if (labels.filter(l => l.startsWith(cand)).length >= threshold) lo = mid;
      else hi = mid - 1;
    }
    const trimmed = base.slice(0, lo).replace(/[\s\-(–,;:]+$/, '').trim();
    if (trimmed.length > best.length) best = trimmed;
  }

  return best || labels[0].replace(/[\s\-(–,;:]+$/, '').trim();
}

// ── Detail panel ──────────────────────────────────────────────────────────────
function showEmpty() {
  detailEmpty.hidden  = false;
  detailContent.hidden = true;
}

function renderDetail(v) {
  detailEmpty.hidden   = true;
  detailContent.hidden = false;

  const dist    = v.distribution || [];
  const valid   = dist.filter(d => !d.inapplicable);
  const inapps  = dist.filter(d => d.inapplicable);
  const maxN    = Math.max(...valid.map(d => d.n), 1);
  const n_universe = v.n_universe;
  const n_total    = v.n_total;

  // Type badge class
  const tc = typeClass(v.variable_type);

  // Group hint
  const groupId = varToGroup?.[v.name];
  const group   = groupId ? groups?.[groupId] : null;
  const groupHintHtml = group
    ? `<div class="group-hint">
         <div class="group-hint-info">
           <span>Question group</span>
           <strong>${escHtml(group.qcode)}</strong>
           <span>— ${escHtml(group.title)}</span>
         </div>
         <button class="group-view-btn" data-group-id="${escHtml(groupId)}">View all ${group.n_vars} →</button>
       </div>`
    : '';

  // Deep-dive hints — one per EA method variable
  const DEEPDIVE_MAP = {
    PILL:     { text: '1,008 women stopped the pill due to dissatisfaction — 72.1% of those with any method dissatisfaction data.', href: '/pill-analysis.html' },
    CONDOM:   { text: '316 women stopped condoms due to dissatisfaction — 21.1% of those with any method dissatisfaction data.', href: '/condom-analysis.html' },
    VASECTMY: { text: 'Only 1 respondent listed a partner\'s vasectomy in EA-17 — vasectomy is permanent and cannot be stopped.', href: '/vasectomy-analysis.html' },
    DEPOPROV: { text: '337 women stopped Depo due to dissatisfaction — 71.4% of those with any method dissatisfaction data.', href: '/depo-analysis.html' },
    WIDRAWAL: { text: '159 women stopped withdrawal due to dissatisfaction — 13.0% of those with any method dissatisfaction data.', href: '/withdrawal-analysis.html' },
    PATCH:    { text: '111 women stopped the patch due to dissatisfaction — 52.9% of those with any method dissatisfaction data.', href: '/patch-analysis.html' },
    RING:     { text: '180 women stopped the vaginal ring due to dissatisfaction — 54.9% of those with any method dissatisfaction data.', href: '/ring-analysis.html' },
    MORNPILL: { text: 'EC does not appear in EA-17 (it\'s episodic, not a regular method). See how 708 EC users stopped other methods.', href: '/ec-analysis.html' },
    IMPLANT:  { text: '136 women stopped the implant due to dissatisfaction — 57.6% of those with any method dissatisfaction data.', href: '/implant-analysis.html' },
    IUD:      { text: '263 women stopped the IUD due to dissatisfaction — 45.2% of those with any method dissatisfaction data.', href: '/iud-analysis.html' },
  };
  const diveInfo = DEEPDIVE_MAP[v.name];
  const deepDiveHtml = diveInfo
    ? `<div class="deepdive-hint">
         <div class="deepdive-hint-info">
           <div class="deepdive-icon">
             <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
               <rect x="1" y="8" width="3" height="5" rx="1" fill="#c17d9d"/>
               <rect x="5.5" y="5" width="3" height="8" rx="1" fill="#c17d9d"/>
               <rect x="10" y="2" width="3" height="11" rx="1" fill="#c17d9d"/>
             </svg>
           </div>
           <div class="deepdive-text">${escHtml(diveInfo.text)}</div>
         </div>
         <a class="deepdive-btn" href="${escHtml(diveInfo.href)}" target="_blank">Full breakdown →</a>
       </div>`
    : '';

  // Notes section
  const notesHtml = v.notes
    ? `<div class="notes-box">
         <span class="notes-label">Note</span>
         <p>${escHtml(v.notes)}</p>
       </div>`
    : '';

  // Distribution rows
  function makeRow(d) {
    const w   = d.inapplicable ? (d.n / n_total * 100).toFixed(1) : (d.n / maxN * 100).toFixed(1);
    const color = d.inapplicable ? INAPP_COLOR : BAR_COLOR;
    return `<div class="dist-row${d.inapplicable ? ' inapplicable' : ''}">
      <div class="dist-label">
        ${escHtml(d.label)}<span class="dist-val-code">${escHtml(d.value)}</span>
      </div>
      <div class="dist-bar-track">
        <div class="dist-bar-fill" style="width:0%;background:${color}" data-w="${w}%"></div>
      </div>
      <div class="dist-pct">${d.pct}%</div>
      <div class="dist-n">${d.n.toLocaleString()}</div>
    </div>`;
  }

  detailContent.innerHTML =
    `<div class="detail-header">
       <p class="detail-label-text">${escHtml(v.label)}</p>
       <div class="detail-name-row">
         <span class="detail-varname">${escHtml(v.name)}</span>
         <span class="type-badge ${tc}">${escHtml(v.variable_type || '—')}</span>
         ${v.drr ? '<span class="drr-badge">DRR</span>' : ''}
       </div>
       ${v.universe ? `<p class="detail-universe"><strong>Universe:</strong> ${escHtml(v.universe)}</p>` : ''}
       <div class="detail-stats-row">
         <div class="detail-stat">
           <span class="detail-stat-val">${n_total.toLocaleString()}</span>
           <span class="detail-stat-lbl">Total respondents</span>
         </div>
         <div class="detail-stat">
           <span class="detail-stat-val">${n_universe.toLocaleString()}</span>
           <span class="detail-stat-lbl">In universe</span>
         </div>
         <div class="detail-stat">
           <span class="detail-stat-val">${valid.length}</span>
           <span class="detail-stat-lbl">Response codes</span>
         </div>
       </div>
     </div>
     ${groupHintHtml}
     ${deepDiveHtml}
     ${notesHtml}
     <div class="dist-wrap">
       ${ageGroupSplit
         ? `<p class="dist-section-label">Response distribution — split by age group</p>
            ${makeAgeSplitRows(v)}
            ${inapps.length ? `<p class="dist-section-label">Outside universe</p>${inapps.map(makeRow).join('')}` : ''}`
         : `${valid.length ? `<p class="dist-section-label">Response distribution</p>${valid.map(makeRow).join('')}` : ''}
            ${inapps.length ? `<p class="dist-section-label">Outside universe</p>${inapps.map(makeRow).join('')}` : ''}`
       }
     </div>`;

  // Animate bars after paint
  requestAnimationFrame(() => requestAnimationFrame(() => {
    detailContent.querySelectorAll('.dist-bar-fill').forEach(el => {
      el.style.width = el.dataset.w;
    });
  }));

  // Group view button
  const groupBtn = detailContent.querySelector('.group-view-btn');
  if (groupBtn) {
    groupBtn.addEventListener('click', () => renderGroupView(groupBtn.dataset.groupId, v));
  }
}

// ── Utils ─────────────────────────────────────────────────────────────────────
function typeClass(t) {
  if (!t) return 'other';
  if (t === 'raw') return 'raw';
  if (t === 'recode') return 'recode';
  if (t.startsWith('computed')) return 'computed';
  return 'other';
}

function escHtml(s) {
  if (!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

})();
</script>
