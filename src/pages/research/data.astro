    METHX190: { text: 'Contraceptive method use across the 4 years before interview — see how pill, IUD, condom, withdrawal and other methods were used over time.', href: '/nsfg-method-trends.html' },
    METHX191: { text: 'Contraceptive method use across the 4 years before interview — see how pill, IUD, condom, withdrawal and other methods were used over time.', href: '/nsfg-method-trends.html' },
    METHX192: { text: 'Contraceptive method use across the 4 years before interview — see how pill, IUD, condom, withdrawal and other methods were used over time.', href: '/nsfg-method-trends.html' },
  };
  const DEEPDIVE_MAP_1719 = {
    PILL:     { text: '34.6% of pill users stopped due to dissatisfaction — 1,448 out of 4,181. (2017–2019)', href: '/pill-analysis.html' },
    CONDOM:   { text: '7.1% of condom users stopped due to dissatisfaction — 356 out of 5,009. (2017–2019)', href: '/condom-analysis.html' },
    VASECTMY: { text: '0.6% — 4 out of 650 women listed vasectomy as stopped due to dissatisfaction. (2017–2019)', href: '/vasectomy-analysis.html' },
    DEPOPROV: { text: '44.1% of Depo users stopped due to dissatisfaction — 662 out of 1,500. Highest rate among all hormonal methods. (2017–2019)', href: '/depo-analysis.html' },
    WIDRAWAL: { text: '6.0% of withdrawal users stopped due to dissatisfaction — 205 out of 3,440. (2017–2019)', href: '/withdrawal-analysis.html' },
    PATCH:    { text: '38.4% of patch users stopped due to dissatisfaction — 180 out of 469. (2017–2019)', href: '/patch-analysis.html' },
    RING:     { text: '44.2% of vaginal ring users stopped due to dissatisfaction — 234 out of 530. (2017–2019)', href: '/ring-analysis.html' },
    MORNPILL: { text: 'EC is a one-time backup and does not appear in the EA-17 dissatisfaction question. See patterns for EC users. (2017–2019)', href: '/ec-analysis.html' },
    IMPLANT:  { text: '156 implant users stopped due to dissatisfaction in 2017–2019. No standalone "ever used" question — rate not computed.', href: '/implant-analysis.html' },
    IUD:      { text: '35.8% of IUD users stopped due to dissatisfaction — 392 out of 1,096. (2017–2019)', href: '/iud-analysis.html' },
    METHDISS:   { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP01: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP02: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP03: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP04: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP05: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP06: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP07: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP08: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
    METHSTOP09: { text: 'Compare dissatisfied rates across all 9 contraceptive methods side by side — 2017–2019 cycle data.', href: '/method-comparison.html' },
  };
  const diveInfo  = (currentCycle === '2017-2019' ? DEEPDIVE_MAP_1719 : DEEPDIVE_MAP)[v.name.toUpperCase()];
  const isMethx   = /^METHX\d+$/i.test(v.name);
  const diveIcon  = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="1" y="8" width="3" height="5" rx="1" fill="#c17d9d"/><rect x="5.5" y="5" width="3" height="8" rx="1" fill="#c17d9d"/><rect x="10" y="2" width="3" height="11" rx="1" fill="#c17d9d"/></svg>`;
  const makeCard  = (text, href, label) => `<div class="deepdive-hint">
         <div class="deepdive-hint-info">
           <div class="deepdive-icon">${diveIcon}</div>
           <div class="deepdive-text">${text}</div>
         </div>
         <a class="deepdive-btn" href="${escHtml(href)}" target="_blank">${label} →</a>
       </div>`;
  const deepDiveHtml = diveInfo
    ? makeCard(escHtml(diveInfo.text), diveInfo.href, 'Full breakdown') +
      (isMethx ? makeCard(
        'Pill, IUD, implant &amp; ring by age group — who uses each method and how that profile shifted over 4 years.',
        '/nsfg-method-age.html',
        'Age breakdown'
      ) : '')
    : '';

  // Notes section
  const notesHtml = v.notes
    ? `<div class="notes-box">
         <span class="notes-label">Note</span>
         <p>${escHtml(v.notes)}</p>
       </div>`
    : '';

  // Distribution rows
  function makeRow(d) {
    const w   = d.inapplicable ? (d.n / n_total * 100).toFixed(1) : (d.n / maxN * 100).toFixed(1);
    const color = d.inapplicable ? INAPP_COLOR : BAR_COLOR;
    return `<div class="dist-row${d.inapplicable ? ' inapplicable' : ''}">
      <div class="dist-label">
        ${escHtml(d.label)}<span class="dist-val-code">${escHtml(d.value)}</span>
      </div>
      <div class="dist-bar-track">
        <div class="dist-bar-fill" style="width:0%;background:${color}" data-w="${w}%"></div>
      </div>
      <div class="dist-pct">${d.pct}%</div>
      <div class="dist-n">${d.n.toLocaleString()}</div>
    </div>`;
  }

  detailContent.innerHTML =
    `<div class="detail-header">
       <p class="detail-label-text">${escHtml(v.label)}</p>
       <div class="detail-name-row">
         <span class="detail-varname">${escHtml(v.name)}</span>
         <span class="type-badge ${tc}">${escHtml(v.variable_type || '—')}</span>
         ${v.drr ? '<span class="drr-badge">DRR</span>' : ''}
       </div>
       ${v.universe ? `<p class="detail-universe"><strong>Universe:</strong> ${escHtml(v.universe)}</p>` : ''}
       <div class="detail-stats-row">
         <div class="detail-stat">
           <span class="detail-stat-val">${n_total.toLocaleString()}</span>
           <span class="detail-stat-lbl">Total respondents</span>
         </div>
         <div class="detail-stat">
           <span class="detail-stat-val">${n_universe.toLocaleString()}</span>
           <span class="detail-stat-lbl">In universe</span>
         </div>
         <div class="detail-stat">
           <span class="detail-stat-val">${valid.length}</span>
           <span class="detail-stat-lbl">Response codes</span>
         </div>
       </div>
     </div>
     ${groupHintHtml}
     ${deepDiveHtml}
     ${notesHtml}
     <div class="dist-wrap">
       ${ageGroupSplit
         ? `<p class="dist-section-label">Response distribution — split by age group</p>
            ${makeAgeSplitRows(v)}
            ${inapps.length ? `<p class="dist-section-label">Outside universe</p>${inapps.map(makeRow).join('')}` : ''}`
         : `${valid.length ? `<p class="dist-section-label">Response distribution</p>${valid.map(makeRow).join('')}` : ''}
            ${inapps.length ? `<p class="dist-section-label">Outside universe</p>${inapps.map(makeRow).join('')}` : ''}`
       }
     </div>`;

  // Animate bars after paint
  requestAnimationFrame(() => requestAnimationFrame(() => {
    detailContent.querySelectorAll('.dist-bar-fill').forEach(el => {
      el.style.width = el.dataset.w;
    });
  }));

  // Group view button
  const groupBtn = detailContent.querySelector('.group-view-btn');
  if (groupBtn) {
    groupBtn.addEventListener('click', () => renderGroupView(groupBtn.dataset.groupId, v));
  }
}

// ── Utils ─────────────────────────────────────────────────────────────────────
function typeClass(t) {
  if (!t) return 'other';
  if (t === 'raw') return 'raw';
  if (t === 'recode') return 'recode';
  if (t.startsWith('computed')) return 'computed';
  return 'other';
}

function escHtml(s) {
  if (!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

})();
</script>
