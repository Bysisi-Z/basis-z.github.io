---
import BaseLayout from '../../layouts/BaseLayout.astro';

const industry = [
  {
    num: '01',
    title: "Sun Pharma's Acquisition of OGN",
    sub: "Financial Comparison & Deal Analysis",
    tags: ['M&A', 'Pharma'],
    meta: '12 min · Interactive Charts',
    href: '/research/sun-pharma-ogn-acquisition',
    coming: false,
  },
  {
    num: '02',
    title: "OGN Annual Financial Analysis Report",
    sub: "Revenue, debt structure, profitability & stock performance",
    tags: ['Pharma', 'Financial Analysis'],
    meta: '8 min',
    href: '/research/ogn-annual-analysis',
    coming: false,
  },
];

const dataProjects = [
  {
    num: '01',
    title: "US NSFG Survey",
    sub: "Female Respondent — 2022–2023",
    tags: ['Survey', 'Reproductive Health'],
    href: '/research/data',
    live: true,
    coming: false,
  },
  {
    num: '02',
    title: "Pharma Market Landscape",
    sub: "Competitive share & pipeline analysis by therapeutic area",
    tags: ['Market Data'],
    href: '#',
    live: false,
    coming: true,
  },
  {
    num: '03',
    title: "Clinical Trial Explorer",
    sub: "Browse and filter trials by phase, sponsor & indication",
    tags: ['Clinical Data'],
    href: '#',
    live: false,
    coming: true,
  },
];
---

<BaseLayout title="Decoding" description="Industry research and interactive data explorations">
  <div class="content-wrap">

    <div class="page-header">
      <h1 class="page-title">De<em>coding</em></h1>
    </div>

    <div class="decoding-grid">

      <!-- Left: Industry Research -->
      <div class="d-col">
        <div class="col-head">
          <span class="col-eyebrow">01</span>
          <h2 class="col-title">Industry<br/><em>Research</em></h2>
          <p class="col-sub">Financial analysis and market deep dives built from public filings.</p>
        </div>
        <div class="col-items">
          {industry.map(item => (
            <a class={`d-item${item.coming ? ' d-item--coming' : ''}`} href={item.href}>
              <div class="item-body">
                <span class="item-num">{item.num}</span>
                <h3 class="item-title">{item.title}</h3>
                <p class="item-sub">{item.sub}</p>
                <div class="item-foot">
                  <div class="item-tags">
                    {item.tags.map(t => <span class="i-tag">{t}</span>)}
                  </div>
                  <span class="item-meta">{item.meta}</span>
                </div>
              </div>
              <span class="item-arrow">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Divider -->
      <div class="col-divider" aria-hidden="true"></div>

      <!-- Right: Play with the Data -->
      <div class="d-col">
        <div class="col-head">
          <span class="col-eyebrow">02</span>
          <h2 class="col-title">Play with<br/><em>the Data</em></h2>
          <p class="col-sub">Interactive tools and exploratory data projects.</p>
        </div>
        <div class="col-items">
          {dataProjects.map(item => (
            <a class={`d-item${item.coming ? ' d-item--coming' : ''}`} href={item.href}>
              <div class="item-body">
                <span class="item-num">{item.num}</span>
                <h3 class="item-title">{item.title}</h3>
                <p class="item-sub">{item.sub}</p>
                <div class="item-foot">
                  <div class="item-tags">
                    {item.tags.map(t => <span class="i-tag">{t}</span>)}
                  </div>
                  {item.live   && <span class="live-badge">Live</span>}
                  {item.coming && <span class="soon-badge">Coming soon</span>}
                </div>
              </div>
              {!item.coming && <span class="item-arrow">→</span>}
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Two-column directory grid ── */
  .decoding-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0 56px;
    padding-top: 52px;
    padding-bottom: 100px;
    align-items: start;
  }

  .col-divider {
    background: var(--rule);
    align-self: stretch;
  }

  /* ── Column header ── */
  .col-head {
    padding-bottom: 28px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0;
  }

  .col-eyebrow {
    font-family: var(--sans); font-size: 10px; font-weight: 300;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--stone); display: block; margin-bottom: 12px;
  }

  .col-title {
    font-family: var(--serif);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 300; line-height: 1.05;
    color: var(--ink); margin: 0 0 14px;
  }
  .col-title em { font-style: italic; }

  .col-sub {
    font-family: var(--sans); font-size: 13px; font-weight: 300;
    color: var(--stone); line-height: 1.65; margin: 0;
  }

  /* ── Item list ── */
  .col-items { display: flex; flex-direction: column; }

  .d-item {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 16px;
    padding: 24px 0;
    border-bottom: 1px solid rgba(226,222,219,0.7);
    text-decoration: none; color: inherit;
    transition: opacity 0.2s;
  }
  .d-item:first-child { border-top: 1px solid rgba(226,222,219,0.7); }
  .d-item:not(.d-item--coming):hover { opacity: 0.6; }
  .d-item--coming { opacity: 0.42; cursor: default; pointer-events: none; }

  .item-body { flex: 1; min-width: 0; }

  .item-num {
    font-family: var(--sans); font-size: 9px; font-weight: 300;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--stone); display: block; margin-bottom: 8px;
  }

  .item-title {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 22px);
    font-weight: 300; font-style: italic;
    color: var(--ink); line-height: 1.25;
    margin: 0 0 7px;
  }

  .item-sub {
    font-family: var(--sans); font-size: 12.5px; font-weight: 300;
    color: var(--stone); line-height: 1.6; margin: 0 0 12px;
  }

  .item-foot {
    display: flex; align-items: center;
    flex-wrap: wrap; gap: 8px;
  }

  .item-tags { display: flex; gap: 6px; flex-wrap: wrap; }

  .i-tag {
    font-family: var(--sans); font-size: 9px; font-weight: 300;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--rose); border: 1px solid rgba(193,125,157,0.32);
    padding: 2px 8px; border-radius: 2px;
  }

  .item-meta {
    font-family: var(--sans); font-size: 10px; font-weight: 300;
    color: var(--stone); letter-spacing: 0.04em;
  }

  .live-badge {
    font-family: var(--sans); font-size: 9px; font-weight: 400;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--rose); background: rgba(193,125,157,0.09);
    border: 1px solid rgba(193,125,157,0.32);
    padding: 2px 8px; border-radius: 2px;
  }

  .soon-badge {
    font-family: var(--sans); font-size: 9px; font-weight: 300;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--stone); border: 1px solid var(--rule);
    padding: 2px 8px; border-radius: 2px;
  }

  .item-arrow {
    font-size: 16px; color: var(--rule);
    flex-shrink: 0; margin-top: 4px;
    transition: transform 0.22s, color 0.22s;
  }
  .d-item:hover .item-arrow { transform: translateX(5px); color: var(--rose); }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .decoding-grid {
      grid-template-columns: 1fr;
      gap: 52px 0;
    }
    .col-divider { width: 100%; height: 1px; align-self: auto; }
    .d-item { padding: 20px 0; }
  }
</style>
