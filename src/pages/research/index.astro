---
import BaseLayout from '../../layouts/BaseLayout.astro';

const industryItems = [
  {
    num: '01',
    title: 'Organon: Was the Failure Avoidable?',
    sub: '15 decision points · what-if interactive analysis',
    tags: ['Pharma', 'Stock Analysis'],
    href: '/organon-stock-analysis.html',
    live: true,
  },
];

const dataProjects = [
  {
    num: '01',
    title: "US NSFG Survey",
    sub: "Female Respondent — 2022–2023 · Variable explorer",
    tags: ['Survey', 'Reproductive Health'],
    href: '/research/data',
    live: true,
    coming: false,
  },
  {
    num: '02',
    title: "NSFG Individual Reports",
    sub: "11 method deep-dives · trends & age analysis",
    tags: ['Survey', 'Reproductive Health'],
    href: '/nsfg-reports.html',
    live: true,
    coming: false,
  },
  {
    num: '03',
    title: "US MEPS Survey",
    sub: "Full-Year Consolidated File — 2023 · Variable explorer",
    tags: ['Survey', 'Healthcare & Costs'],
    href: '/research/meps',
    live: true,
    coming: false,
  },
  {
    num: '04',
    title: "MEPS Expenditure Analysis",
    sub: "Healthcare spending by payer — 2023",
    tags: ['Survey', 'Healthcare & Costs'],
    href: '/research/meps-expenditure',
    live: true,
    coming: false,
  },
];
---

<BaseLayout title="Decoding" description="Industry research and interactive data explorations">
  <div class="content-wrap">

    <div class="page-header">
      <h1 class="page-title">De<em>coding</em></h1>
      <p class="page-sub">Industry research, data analysis & market insights</p>
    </div>

    <div class="decoding-grid">

      <!-- Left: Industry Analysis -->
      <div class="d-col">
        <div class="col-label col-label--industry">
          <svg class="col-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M3 17 L8 10 L12 13 L17 6 L19 8" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="19" cy="5.5" r="1.8" fill="white"/>
          </svg>
          <span class="col-label-text">Industry Analysis</span>
        </div>
        <div class="col-items">
          {industryItems.map(item => (
            <a class="d-item" href={item.href}>
              <div class="item-body">
                <h3 class="item-title">{item.title}</h3>
                <p class="item-sub">{item.sub}</p>
                <div class="item-foot">
                  <div class="item-tags">
                    {item.tags.map(t => <span class="i-tag">{t}</span>)}
                  </div>
                  {item.live && <span class="live-badge">Live</span>}
                </div>
              </div>
              <span class="item-arrow">→</span>
            </a>
          ))}
          <a class="see-all-link" href="/research/industry">See all industry research →</a>
        </div>
      </div>

      <div class="col-divider"></div>

      <!-- Right: Play with the Data -->
      <div class="d-col">
        <div class="col-label">
          <svg class="col-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2.5" y="12" width="4" height="7" rx="1" fill="white"/>
            <rect x="9" y="8" width="4" height="11" rx="1" fill="white"/>
            <rect x="15.5" y="4" width="4" height="15" rx="1" fill="white"/>
          </svg>
          <span class="col-label-text">Play with the Data</span>
        </div>
        <div class="col-items">
          {dataProjects.map(item => (
            <a class={`d-item${item.coming ? ' d-item--coming' : ''}`} href={item.href}>
              <div class="item-body">
                <h3 class="item-title">{item.title}</h3>
                <p class="item-sub">{item.sub}</p>
                <div class="item-foot">
                  <div class="item-tags">
                    {item.tags.map(t => <span class="i-tag">{t}</span>)}
                  </div>
                  {item.live   && <span class="live-badge">Live</span>}
                  {item.coming && <span class="soon-badge">Coming soon</span>}
                </div>
              </div>
              {!item.coming && <span class="item-arrow">→</span>}
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Page header ── */
  .page-sub {
    font-family: var(--serif);
    font-size: clamp(15px, 1.6vw, 18px);
    font-weight: 300; font-style: italic;
    color: var(--stone);
    margin: 1em 0 0;
  }

  /* ── Two-column directory grid ── */
  .decoding-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0 56px;
    padding-top: 40px;
    padding-bottom: 100px;
    align-items: start;
  }

  .col-divider {
    background: var(--rule);
    align-self: stretch;
  }

  /* ── Column label (rose block) ── */
  .col-label {
    background: var(--rose);
    padding: 10px 16px;
    border-radius: 6px;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .col-icon { flex-shrink: 0; }

  .col-label-text {
    font-family: var(--serif);
    font-size: clamp(18px, 1.8vw, 24px);
    font-weight: 500; font-style: italic;
    color: #fff; line-height: 1.1;
  }

  /* ── Item list ── */
  .col-items { display: flex; flex-direction: column; }

  .d-item {
    display: flex; align-items: center;
    justify-content: space-between; gap: 16px;
    padding: 20px 12px;
    border-bottom: 1px solid rgba(226,222,219,0.7);
    text-decoration: none; color: inherit;
    border-radius: 6px;
    transition: background 0.18s;
    margin: 0 -12px;
  }
  .d-item:first-child { border-top: 1px solid rgba(226,222,219,0.7); }
  .d-item:not(.d-item--coming):hover {
    background: rgba(169,126,194,0.06);
  }
  .d-item--coming { opacity: 0.42; cursor: default; pointer-events: none; }

  .item-body { flex: 1; min-width: 0; }

  .item-title {
    font-family: var(--serif);
    font-size: clamp(17px, 1.8vw, 22px);
    font-weight: 300; font-style: italic;
    color: var(--ink); line-height: 1.25;
    margin: 0 0 6px;
  }

  .item-sub {
    font-family: var(--sans); font-size: 12.5px; font-weight: 300;
    color: var(--stone); line-height: 1.6; margin: 0 0 10px;
  }

  .item-foot {
    display: flex; align-items: center;
    flex-wrap: wrap; gap: 8px;
  }

  .item-tags { display: flex; gap: 6px; flex-wrap: wrap; }

  .i-tag {
    font-family: var(--sans); font-size: 9px; font-weight: 300;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--rose); border: 1px solid rgba(169,126,194,0.32);
    padding: 2px 8px; border-radius: 2px;
  }

  .item-meta {
    font-family: var(--sans); font-size: 10px; font-weight: 300;
    color: var(--stone); letter-spacing: 0.04em;
  }

  .live-badge {
    font-family: var(--sans); font-size: 9px; font-weight: 400;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--rose); background: rgba(169,126,194,0.09);
    border: 1px solid rgba(169,126,194,0.32);
    padding: 2px 8px; border-radius: 2px;
  }

  .soon-badge {
    font-family: var(--sans); font-size: 9px; font-weight: 300;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--stone); border: 1px solid var(--rule);
    padding: 2px 8px; border-radius: 2px;
  }

  .item-arrow {
    font-size: 18px; color: var(--stone);
    flex-shrink: 0;
    transition: transform 0.22s, color 0.22s;
  }
  .d-item:hover .item-arrow { transform: translateX(5px); color: var(--rose); }

  .col-label--industry { background: #475569; }

  .see-all-link {
    display: inline-block;
    margin-top: 16px;
    font-family: var(--sans); font-size: 11px; font-weight: 300;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--stone); text-decoration: none;
    transition: color 0.2s;
  }
  .see-all-link:hover { color: var(--ink); }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .decoding-grid {
      grid-template-columns: 1fr;
      gap: 36px 0;
      padding-top: 28px;
    }
    .col-divider { width: 100%; height: 1px; align-self: auto; }
    .d-item { padding: 18px 12px; }
  }
</style>
