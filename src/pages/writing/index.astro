---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'first-essay',
    title: 'Title of the First Essay — A Theme Worth Exploring',
    date: '2026-05-29', month: 'May', day: '29', year: '2026',
    excerpt: 'A short excerpt that draws the reader in. Restrained, precise, leaving just enough unsaid to make them want to read on.',
    readTime: '3 min read',
  },
  {
    slug: 'on-observation-and-writing',
    title: 'On Observation and Writing: Why I Started',
    date: '2026-05-15', month: 'May', day: '15', year: '2026',
    excerpt: 'Writing is a way of resisting forgetting. In an age of information overload, slowing down to put words to experience — that is why I write.',
    readTime: '5 min read',
  },
];
---

<BaseLayout title="Writing" description="Observations, reflections, and personal essays">
  <div class="content-wrap">

    <div class="page-header">
      <h1 class="page-title"><em>Wandering</em></h1>

      <div class="page-intro">
        <p>In an age where AI can generate words in seconds, there is still something meaningful about expressing my own thoughts by typing out every word myself.</p>
        <p>Although English is my working language, Chinese is the language in which I think. For that reason, every essay in this section is first written in Chinese and then translated into English. You'll find a language switch at the top of each page.</p>
        <div class="coffee-wrap">
          <audio id="coffee-audio" src="/audio/coffee-invite.m4a" preload="none"></audio>
          <button class="coffee-btn" id="coffee-btn" aria-label="Play a message" title="Click me">
          <svg class="coffee-svg" viewBox="0 0 82 90" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Steam wisps -->
            <path d="M24 30 Q20 20 24 9 Q28 20 24 30Z" fill="#EDE8F5"/>
            <path d="M38 27 Q34 15 38 3 Q42 15 38 27Z" fill="#D4CBE8"/>
            <path d="M52 30 Q48 20 52 9 Q56 20 52 30Z" fill="#EDE8F5"/>
            <!-- Saucer -->
            <ellipse cx="40" cy="74" rx="29" ry="6" fill="#D4CBE8"/>
            <!-- Cup body -->
            <path d="M12 32 L17 70 L63 70 L68 32Z" fill="#A97EC2"/>
            <!-- Handle -->
            <path d="M68 42 Q80 42 80 52 Q80 63 68 63 L68 59 Q75 59 75 52 Q75 45 68 45Z" fill="#D4CBE8"/>
            <!-- Coffee surface -->
            <ellipse cx="40" cy="33" rx="28" ry="6" fill="#A97EC2"/>
            <!-- Reflection -->
            <ellipse cx="33" cy="32" rx="9" ry="2" fill="#A97EC2" opacity="0.45"/>
          </svg>
          </button>
          <div>
            <p>Please allow me to offer you a cup of tea — or coffee, if you prefer.</p>
            <p class="invite">Let's sit down and have a conversation.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="blog-list">
      {posts.map(post => (
        <a class="blog-item fade-up" href={`/writing/${post.slug}`}>
          <div class="blog-date">
            <div class="blog-month">{post.month}</div>
            <div class="blog-day">{post.day}</div>
            <div class="blog-year">{post.year}</div>
          </div>
          <div>
            <div class="blog-title">{post.title}</div>
            <p class="blog-excerpt">{post.excerpt}</p>
            <span class="blog-cta">Read →</span>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .page-header { padding-top: 64px; padding-bottom: 52px; border-bottom: 1px solid var(--rule); }
  .page-title {
    font-family: var(--serif);
    font-size: clamp(44px, 8vw, 88px);
    font-weight: 300; font-style: italic;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--ink); margin-bottom: 28px;
  }

  /* Intro text */
  .page-intro { max-width: 900px; }
  .page-intro p {
    font-family: var(--serif);
    font-size: clamp(15px, 1.4vw, 17px);
    font-weight: 300; line-height: 1.8;
    color: var(--ink); margin-bottom: 0.9em;
  }
  .page-intro p.invite {
    font-style: italic; color: var(--stone);
    margin-bottom: 0;
  }
  .coffee-wrap {
    display: flex; align-items: flex-start; gap: 28px;
    margin-top: 0.4em;
  }
  .coffee-btn {
    background: none; border: none; padding: 0; cursor: pointer;
    flex-shrink: 0; margin-top: 4px;
    transition: transform 0.2s;
  }
  .coffee-btn:hover { transform: translateY(-3px); }
  .coffee-btn.playing .coffee-svg { filter: drop-shadow(0 0 8px rgba(169,126,194,0.5)); }
  .coffee-svg {
    width: 56px; height: auto;
    display: block;
    transition: filter 0.3s;
  }
  /* Steam animation when playing */
  @keyframes steam-rise {
    0%   { opacity: 0.4; transform: translateY(0); }
    50%  { opacity: 1;   transform: translateY(-4px); }
    100% { opacity: 0.4; transform: translateY(0); }
  }
  .coffee-btn.playing svg path:nth-child(1),
  .coffee-btn.playing svg path:nth-child(2),
  .coffee-btn.playing svg path:nth-child(3) {
    animation: steam-rise 1.4s ease-in-out infinite;
  }
  .coffee-btn.playing svg path:nth-child(2) { animation-delay: 0.25s; }
  .coffee-btn.playing svg path:nth-child(3) { animation-delay: 0.5s; }

  .blog-list { padding-top: 64px; }
  .blog-item {
    display: grid; grid-template-columns: 100px 1fr;
    gap: 40px; padding: 44px 0;
    border-bottom: 1px solid rgba(26,26,26,0.08);
    text-decoration: none; color: inherit;
    transition: opacity 0.22s;
  }
  .blog-item:first-child { border-top: 1px solid rgba(26,26,26,0.08); }
  .blog-item:hover { opacity: 0.55; }
  .blog-date { text-align: right; padding-top: 2px; }
  .blog-month { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .blog-day   { font-family: var(--serif); font-size: 40px; font-weight: 300; color: var(--light); line-height: 1; }
  .blog-year  { font-size: 10px; color: var(--light); }
  .blog-title {
    font-family: var(--serif);
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 300; line-height: 1.28; margin-bottom: 10px;
  }
  .blog-excerpt { font-size: 13px; font-weight: 300; color: var(--muted); line-height: 1.82; max-width: 460px; }
  .blog-cta {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 14px; font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--accent);
  }
</style>

<script>
  // Coffee cup easter egg
  const btn = document.getElementById('coffee-btn');
  const audio = document.getElementById('coffee-audio');
  btn.addEventListener('click', () => {
    if (audio.paused) {
      audio.play();
      btn.classList.add('playing');
    } else {
      audio.pause();
      audio.currentTime = 0;
      btn.classList.remove('playing');
    }
  });
  audio.addEventListener('ended', () => btn.classList.remove('playing'));

  // Fade-in cards
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) { setTimeout(() => e.target.classList.add('visible'), i * 90); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
</script>
