---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'first-post',
    title: '第一篇文章',
    date: '2026-05-29',
    excerpt: '这是第一篇文章的摘要，简短介绍文章内容，吸引读者点击阅读全文。',
    readTime: '3 分钟',
  },
];
---

<BaseLayout title="个人文章" description="思考、观察与生活随笔">
  <div class="max-w-3xl mx-auto px-6 pt-20 pb-24">

    <div class="mb-14">
      <p class="text-xs text-[#6b7280] uppercase tracking-widest mb-4">04 — 个人文章</p>
      <h1 class="text-3xl font-light mb-4">文字记录</h1>
      <p class="text-[#6b7280] leading-relaxed">
        思考、观察与日常随笔。
      </p>
    </div>

    <div class="divide-y divide-[#e5e7eb]">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}`}
          class="group flex items-start justify-between gap-6 py-7 hover:opacity-80 transition-opacity"
        >
          <div>
            <h2 class="font-medium mb-1.5 group-hover:text-[#2563eb] transition-colors">{post.title}</h2>
            <p class="text-sm text-[#6b7280] leading-relaxed">{post.excerpt}</p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-xs text-[#9ca3af]">{post.date}</div>
            <div class="text-xs text-[#9ca3af] mt-1">{post.readTime}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
