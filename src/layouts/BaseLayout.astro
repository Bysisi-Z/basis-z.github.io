---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const { title, description = 'Si', hideNav = false, hideFooter = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title === 'Home' ? 'Si' : `${title} — Si`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Inter:wght@200;300;400;600&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
    <style>
      img {
        -webkit-user-drag: none;
        -webkit-touch-callout: none; /* blocks iOS long-press save menu */
      }
    </style>
    <script>
      // Block right-click and drag on all images (deters casual downloading)
      document.addEventListener('contextmenu', e => {
        if (e.target instanceof HTMLImageElement) e.preventDefault();
      });
      document.addEventListener('dragstart', e => {
        if (e.target instanceof HTMLImageElement) e.preventDefault();
      });
    </script>
  </head>
  <body>
    {!hideNav && <Nav />}
    <main>
      <slot />
    </main>
    {!hideFooter && <Footer />}

    <!-- Late-night popup -->
    <div id="nightPopup">
      <div class="np-card">
        <p class="np-l1">It's past midnight.</p>
        <p class="np-l2">I hope you're doing alright.</p>
        <p class="np-l3">Take care of yourself.</p>
        <button class="np-close" id="nightPopupClose">Close</button>
        <svg class="np-heart" id="nightHeart" viewBox="0 0 24 22" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 21.6C6.37 16.06 1 11.3 1 6.19 1 3.78 3.11 2 6 2c1.99 0 3.76 1.04 5 2.5C12.24 3.04 14.01 2 16 2c2.89 0 5 1.78 5 5.19 0 5.11-5.37 9.87-11 15.41z"/>
        </svg>
      </div>
    </div>
  </body>
</html>

<style>
  #nightPopup {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(6, 4, 16, 0.72);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  #nightPopup.np-visible {
    opacity: 1;
  }
  .np-card {
    background: rgba(22, 17, 40, 0.97);
    border: 1px solid rgba(180, 160, 215, 0.18);
    border-radius: 16px;
    padding: 44px 52px;
    max-width: 400px;
    width: calc(100% - 48px);
    text-align: center;
    box-shadow: 0 12px 60px rgba(0, 0, 0, 0.5);
  }
  .np-l1, .np-l2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 300;
    font-style: italic;
    color: rgba(235, 228, 250, 0.92);
    margin: 0 0 10px;
    line-height: 1.7;
  }
  .np-l3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 300;
    font-style: italic;
    color: rgba(185, 168, 215, 0.7);
    margin: 0 0 32px;
    line-height: 1.7;
  }
  .np-close {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(185, 168, 215, 0.7);
    background: none;
    border: 1px solid rgba(180, 160, 215, 0.25);
    border-radius: 20px;
    padding: 8px 28px;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .np-close:hover {
    border-color: rgba(180, 160, 215, 0.6);
    color: rgba(235, 228, 250, 0.9);
  }
  .np-heart {
    display: block;
    width: 18px;
    height: 18px;
    margin: 20px auto 0;
    fill: rgba(255, 255, 255, 0.35);
  }
  @media (max-width: 640px) {
    .np-card {
      padding: 36px 32px;
    }
  }
</style>

<script>
  (function () {
    var h = new Date().getHours();
    if (h >= 0 && h < 6 && !sessionStorage.getItem('sisi-night-popup')) {
      // Record arrival time once per session, persist across page navigations
      if (!sessionStorage.getItem('sisi-arrival')) {
        sessionStorage.setItem('sisi-arrival', String(Date.now()));
      }
      var elapsed  = Date.now() - parseInt(sessionStorage.getItem('sisi-arrival')!);
      var remaining = Math.max(0, 30000 - elapsed);

      var popup = document.getElementById('nightPopup') as HTMLElement;
      var btn   = document.getElementById('nightPopupClose') as HTMLButtonElement;

      function placeHeart() {
        var h = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        h.setAttribute('viewBox', '0 0 24 22');
        h.setAttribute('id', 'sisiHeart');
        h.style.cssText = 'position:fixed;left:22px;bottom:22px;width:18px;height:18px;fill:#B8A9D4;z-index:10000;pointer-events:none;opacity:0.85;';
        var p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        p.setAttribute('d', 'M12 21.6C6.37 16.06 1 11.3 1 6.19 1 3.78 3.11 2 6 2c1.99 0 3.76 1.04 5 2.5C12.24 3.04 14.01 2 16 2c2.89 0 5 1.78 5 5.19 0 5.11-5.37 9.87-11 15.41z');
        h.appendChild(p);
        document.body.appendChild(h);
      }

      function closePopup() {
        var heartEl = document.getElementById('nightHeart') as SVGElement;
        if (heartEl) {
          var r = heartEl.getBoundingClientRect();
          document.body.appendChild(heartEl);
          heartEl.style.position      = 'fixed';
          heartEl.style.left          = r.left + 'px';
          heartEl.style.top           = r.top  + 'px';
          heartEl.style.width         = '18px';
          heartEl.style.height        = '18px';
          heartEl.style.fill          = 'rgba(255,255,255,0.6)';
          heartEl.style.zIndex        = '10000';
          heartEl.style.pointerEvents = 'none';
          heartEl.style.transition    = 'left 0.7s cubic-bezier(0.34,1.56,0.64,1), top 0.7s cubic-bezier(0.34,1.56,0.64,1), fill 0.9s ease 0.2s';
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              heartEl.style.left = '22px';
              heartEl.style.top  = (window.innerHeight - 40) + 'px';
              heartEl.style.fill = '#B8A9D4';
            });
          });
          localStorage.setItem('sisi-heart', '1');
        }
        popup.classList.remove('np-visible');
        setTimeout(function () { popup.style.display = 'none'; }, 420);
      }

      setTimeout(function () {
        popup.style.display = 'flex';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            popup.classList.add('np-visible');
          });
        });
        sessionStorage.setItem('sisi-night-popup', '1');
      }, remaining);

      btn.addEventListener('click', closePopup);
      popup.addEventListener('click', function (e) {
        if (e.target === popup) closePopup();
      });
    }

    // Restore heart on any page if previously earned
    if (localStorage.getItem('sisi-heart') && !document.getElementById('sisiHeart')) {
      var h2 = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      h2.setAttribute('viewBox', '0 0 24 22');
      h2.setAttribute('id', 'sisiHeart');
      h2.style.cssText = 'position:fixed;left:22px;bottom:22px;width:18px;height:18px;fill:#B8A9D4;z-index:10000;pointer-events:none;opacity:0.85;';
      var p2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      p2.setAttribute('d', 'M12 21.6C6.37 16.06 1 11.3 1 6.19 1 3.78 3.11 2 6 2c1.99 0 3.76 1.04 5 2.5C12.24 3.04 14.01 2 16 2c2.89 0 5 1.78 5 5.19 0 5.11-5.37 9.87-11 15.41z');
      h2.appendChild(p2);
      document.body.appendChild(h2);
    }
  })();
</script>
